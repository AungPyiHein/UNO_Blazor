@inherits LayoutComponentBase
@using UnoApp.Services
@inject NavigationState NavigationState

<div class="page @(NavigationState.IsArenaMode ? "arena-mode" : "")">
    @if (!NavigationState.IsArenaMode)
    {
        <div class="sidebar">
            <NavMenu />
        </div>
    }

    <main>
        @if (!NavigationState.IsArenaMode)
        {
            <div class="top-row px-4">
                <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
            </div>
        }

        <article class="content @(NavigationState.IsArenaMode ? "p-0" : "px-4")">
            @Body
        </article>
    </main>
</div>

<style>
    .arena-mode main {
        width: 100vw;
        height: 100vh;
        margin: 0;
        padding: 0;
    }
    .p-0 { padding: 0 !important; }
</style>

@code {
    protected override void OnInitialized()
    {
        NavigationState.OnStateChanged += () => InvokeAsync(StateHasChanged);
    }
}
