@inherits LayoutComponentBase
@using UnoApp.Services
@inject NavigationState NavigationState

<div class="page">
    <main>
        <article class="content p-0">
            @Body
        </article>
    </main>
</div>

<style>
    /* Make the entire app full screen and remove default Blazor padding/margins */
    html, body {
        margin: 0;
        padding: 0;
        width: 100vw;
        height: 100vh;
        overflow: hidden;
        background-color: #0b0f19; /* Dark background to match Uno theme */
    }

    .page {
        width: 100vw;
        height: 100vh;
        display: flex;
        flex-direction: column;
    }

    main {
        flex: 1;
        display: flex;
        flex-direction: column;
        width: 100vw;
        height: 100vh;
        margin: 0;
        padding: 0;
    }

    .content {
        flex: 1;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        padding: 0 !important;
        margin: 0 !important;
    }
</style>

@code {
    protected override void OnInitialized()
    {
        NavigationState.OnStateChanged += () => InvokeAsync(StateHasChanged);
    }
}
