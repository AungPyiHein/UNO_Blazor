@page "/profile"
@using UnoApp.Services
@inject SupabaseService Supabase
@inject NavigationManager Navigation
@inject NavigationState NavigationState

<div class="login-screen">
    <!-- Top Nav -->
    <div class="top-nav">
        <button class="glass-btn" @onclick='() => Navigation.NavigateTo("/home")'>← Back to Game</button>
        <button class="glass-btn btn-danger" @onclick="SignOut">Sign Out</button>
    </div>

    <div class="profile-container">
        <!-- Left Column: Profile / Register & Stats -->
        <div class="profile-sidebar">
            @if (!Supabase.IsGuest)
            {
                <!-- Registered User Profile Card -->
                <div class="glass-card text-center">
                    <h2>My Profile</h2>
                    
                    <div class="avatar-section">
                        @if (!string.IsNullOrEmpty(_profile?.AvatarUrl))
                        {
                            <img src="@_profile.AvatarUrl" class="avatar-img" />
                        }
                        else
                        {
                            <div class="avatar-img placeholder">@(string.IsNullOrEmpty(_profile?.DisplayName) ? "?" : _profile.DisplayName[0].ToString())</div>
                        }
                        
                        <div class="avatar-upload-overlay">
                            <label for="avatarUpload" class="upload-btn">📷</label>
                            <InputFile id="avatarUpload" OnChange="HandleFileSelected" accept="image/png, image/jpeg" style="display: none;" />
                        </div>
                    </div>

                    <div class="form-group mt-3">
                        <label>Display Name</label>
                        <div style="display: flex; gap: 10px;">
                            <input type="text" @bind="_editName" class="form-control" />
                            <button class="glass-btn" @onclick="SaveProfile" disabled="@_isSaving">
                                @if (_isSaving) { <span class="spinner-sm"></span> } else { <span>Save</span> }
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <div class="text-danger mt-2" style="font-size: 0.85rem;">@_errorMessage</div>
                        }
                    </div>
                </div>
            }
            else
            {
                <!-- Unified Guest Session & Registration Card -->
                <div class="glass-card">
                    <div class="text-center mb-3">
                        <div class="avatar-section" style="margin-bottom: 12px;">
                            <div class="avatar-img placeholder">@(string.IsNullOrEmpty(_profile?.DisplayName) ? "G" : _profile.DisplayName[0].ToString())</div>
                        </div>
                        <div class="guest-session-badge">🔒 Guest Session</div>
                        <h3 class="mt-2" style="font-size: 1.25rem; margin-bottom: 4px;">@(_profile?.DisplayName ?? "Guest")</h3>
                    </div>

                    @if (!_showGuestSignIn)
                    {
                        <!-- Register Account Form -->
                        <div class="guest-auth-form">
                            <h4 class="form-subtitle">Register Account</h4>
                            <p class="form-desc">Register your guest session with an email address to save your stats & customize your profile.</p>

                            <div class="form-group">
                                <label>Display Name</label>
                                <input type="text" @bind="_regDisplayName" class="form-control" placeholder="Your name (2-20 chars)" maxlength="20" />
                            </div>
                            <div class="form-group mt-2">
                                <label>Email</label>
                                <input type="email" @bind="_regEmail" class="form-control" placeholder="player@example.com" />
                            </div>
                            <div class="form-group mt-2">
                                <label>Password</label>
                                <input type="password" @bind="_regPassword" class="form-control" placeholder="Min 6 characters" />
                            </div>

                            @if (!string.IsNullOrEmpty(_regError))
                            {
                                <div class="text-danger mt-2" style="font-size: 0.85rem;">@_regError</div>
                            }
                            @if (!string.IsNullOrEmpty(_regSuccess))
                            {
                                <div class="text-success mt-2" style="font-size: 0.85rem;">@_regSuccess</div>
                            }

                            <button class="glass-btn btn-register-action w-100 mt-3" @onclick="RegisterGuestAccount" disabled="@_isRegistering">
                                @if (_isRegistering) { <span class="spinner-sm"></span> } else { <span>✨ Register Account</span> }
                            </button>

                            <div class="auth-toggle-link text-center mt-3">
                                <button type="button" class="btn-link-toggle" @onclick="ToggleGuestAuthMode">
                                    Already have an account? <strong>Sign In</strong>
                                </button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <!-- Sign In Form -->
                        <div class="guest-auth-form">
                            <h4 class="form-subtitle">Sign In</h4>
                            <p class="form-desc">Sign in to your existing account to load your profile and lifetime stats.</p>

                            <div class="form-group">
                                <label>Email</label>
                                <input type="email" @bind="_regEmail" class="form-control" placeholder="player@example.com" />
                            </div>
                            <div class="form-group mt-2">
                                <label>Password</label>
                                <input type="password" @bind="_regPassword" class="form-control" placeholder="••••••••" />
                            </div>

                            @if (!string.IsNullOrEmpty(_regError))
                            {
                                <div class="text-danger mt-2" style="font-size: 0.85rem;">@_regError</div>
                            }

                            <button class="glass-btn btn-register-action w-100 mt-3" @onclick="SignInFromProfile" disabled="@_isRegistering">
                                @if (_isRegistering) { <span class="spinner-sm"></span> } else { <span>🔑 Sign In</span> }
                            </button>

                            <div class="auth-toggle-link text-center mt-3">
                                <button type="button" class="btn-link-toggle" @onclick="ToggleGuestAuthMode">
                                    Need an account? <strong>Register</strong>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="glass-card stats-card mt-4">
                <h3>Lifetime Stats</h3>
                @if (_stats != null)
                {
                    <div class="stats-grid">
                        <div class="stat-box">
                            <span class="stat-label">Wins</span>
                            <span class="stat-value text-success">@_stats.TotalWins</span>
                        </div>
                        <div class="stat-box">
                            <span class="stat-label">Losses</span>
                            <span class="stat-value text-danger">@_stats.TotalLosses</span>
                        </div>
                        <div class="stat-box">
                            <span class="stat-label">Games</span>
                            <span class="stat-value">@_stats.TotalGames</span>
                        </div>
                        <div class="stat-box">
                            <span class="stat-label">Win Rate</span>
                            <span class="stat-value text-warning">@(_stats.WinRate.ToString("0.0"))%</span>
                        </div>
                    </div>
                }
                else
                {
                    <p>No stats recorded yet.</p>
                }
            </div>
        </div>

        <!-- Right Column: Match History -->
        <div class="profile-main">
            <div class="glass-card match-history-card">
                <h3>Recent Matches</h3>
                
                @if (_history == null)
                {
                    <p>Loading history...</p>
                }
                else if (_history.Count == 0)
                {
                    <p>You haven't played any matches yet.</p>
                }
                else
                {
                    <div class="history-list">
                        @foreach (var match in _history)
                        {
                            <div class="history-item @(match.IsWinner ? "history-win" : "history-loss")">
                                <div class="h-left">
                                    <span class="h-result">@(match.IsWinner ? "VICTORY" : "DEFEAT")</span>
                                    <span class="h-placement">@(match.FinalPlacement)@(GetOrdinal(match.FinalPlacement)) Place</span>
                                </div>
                                <div class="h-mid">
                                    <span class="h-score">Score: @match.TotalScore</span>
                                    <span class="h-cards">Cards Left: @match.CardsRemaining</span>
                                </div>
                                <div class="h-right">
                                    <span class="h-date">Match ID: @match.MatchId.Substring(0, 8)</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    /* Consistent Background */
    .login-screen {
        width: 100vw;
        height: 100vh;
        background: linear-gradient(135deg, #0a0a1a 0%, #1a1a3e 40%, #0d0d2b 100%);
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        color: white;
        overflow-y: auto;
        position: relative;
    }
    
    .login-screen::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at 20% 30%, rgba(99, 102, 241, 0.15) 0%, transparent 50%),
            radial-gradient(circle at 80% 70%, rgba(244, 63, 94, 0.1) 0%, transparent 50%);
        pointer-events: none;
        position: fixed;
    }

    .top-nav {
        position: fixed;
        top: 20px;
        left: 20px;
        right: 20px;
        display: flex;
        justify-content: space-between;
        z-index: 10;
    }

    .profile-container {
        position: relative;
        z-index: 1;
        max-width: 1200px;
        margin: 80px auto;
        display: grid;
        grid-template-columns: 350px 1fr;
        gap: 30px;
        padding: 0 20px;
        padding-bottom: 50px;
    }

    @@media (max-width: 900px) {
        .profile-container { grid-template-columns: 1fr; }
    }

    /* Glassmorphism */
    .glass-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .glass-btn {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: white;
        padding: 10px 20px;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.2s;
    }
    .glass-btn:hover { background: rgba(255, 255, 255, 0.2); transform: translateY(-2px); }
    .glass-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    
    .btn-danger { background: rgba(239, 68, 68, 0.2); border-color: rgba(239, 68, 68, 0.5); }
    .btn-danger:hover { background: rgba(239, 68, 68, 0.4); }

    /* Typography & Utilities */
    h2, h3 { margin-top: 0; margin-bottom: 20px; font-weight: 700; background: linear-gradient(135deg, #fff 0%, #a5b4fc 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .text-center { text-align: center; }
    .mt-3 { margin-top: 15px; }
    .mt-4 { margin-top: 30px; }
    .text-success { color: #34d399; }
    .text-danger { color: #f87171; }
    .text-warning { color: #fbbf24; }

    /* Forms */
    .form-group label { display: block; text-align: left; margin-bottom: 6px; color: #cbd5e1; font-size: 0.85rem; font-weight: 600; }
    input.form-control {
        width: 100%;
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 10px;
        padding: 10px 14px;
        color: #ffffff;
        font-size: 0.95rem;
        outline: none;
        box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.3);
        transition: all 0.2s;
    }
    input.form-control::placeholder {
        color: rgba(255, 255, 255, 0.45);
    }
    input.form-control:focus {
        border-color: #6366f1;
        box-shadow: 0 0 12px rgba(99, 102, 241, 0.4);
    }

    .guest-session-badge {
        display: inline-block;
        background: rgba(245, 158, 11, 0.15);
        border: 1px solid rgba(245, 158, 11, 0.4);
        color: #fcd34d;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        padding: 4px 12px;
        border-radius: 20px;
        text-transform: uppercase;
    }
    .form-subtitle {
        font-size: 1.1rem;
        font-weight: 700;
        margin-top: 15px;
        margin-bottom: 6px;
        color: #fff;
        background: linear-gradient(135deg, #fff 0%, #a5b4fc 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .form-desc {
        font-size: 0.82rem;
        color: #94a3b8;
        margin-bottom: 16px;
        line-height: 1.4;
    }
    .btn-register-action {
        background: linear-gradient(135deg, #6366f1 0%, #3b82f6 100%);
        border: none;
        color: white;
        font-weight: 700;
        box-shadow: 0 4px 15px rgba(99, 102, 241, 0.4);
    }
    .btn-register-action:hover {
        background: linear-gradient(135deg, #4f46e5 0%, #2563eb 100%);
        box-shadow: 0 6px 20px rgba(99, 102, 241, 0.6);
        transform: translateY(-2px);
    }
    .btn-link-toggle {
        background: none;
        border: none;
        color: #a5b4fc;
        font-size: 0.85rem;
        cursor: pointer;
        transition: color 0.2s;
    }
    .btn-link-toggle:hover {
        color: #ffffff;
        text-decoration: underline;
    }

    /* Avatar */
    .avatar-section { display: flex; justify-content: center; margin-bottom: 20px; position: relative; width: 120px; margin: 0 auto 20px auto; }
    .avatar-img { width: 120px; height: 120px; border-radius: 50%; object-fit: cover; border: 3px solid #6366f1; box-shadow: 0 0 20px rgba(99, 102, 241, 0.4); }
    .avatar-img.placeholder { background: linear-gradient(135deg, #6366f1, #3b82f6); display: flex; align-items: center; justify-content: center; font-size: 3rem; font-weight: bold; width: 120px; height: 120px; border-radius: 50%; }

    .avatar-upload-overlay { position: absolute; bottom: 0; right: 0; }
    .upload-btn { background: rgba(255, 255, 255, 0.2); backdrop-filter: blur(5px); border-radius: 50%; width: 35px; height: 35px; display: flex; align-items: center; justify-content: center; cursor: pointer; border: 1px solid rgba(255, 255, 255, 0.4); font-size: 1.2rem; transition: transform 0.2s; }
    .upload-btn:hover { transform: scale(1.1); background: rgba(255, 255, 255, 0.3); }

    /* Stats Grid */
    .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
    .stat-box { background: rgba(0,0,0,0.2); border-radius: 12px; padding: 15px; text-align: center; border: 1px solid rgba(255,255,255,0.05); }
    .stat-label { display: block; font-size: 0.8rem; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px; }
    .stat-value { display: block; font-size: 1.8rem; font-weight: bold; }

    /* Match History */
    .match-history-card { min-height: 500px; }
    .history-list { display: flex; flex-direction: column; gap: 15px; }
    .history-item { 
        display: flex; justify-content: space-between; align-items: center; 
        background: rgba(0,0,0,0.2); border-radius: 12px; padding: 15px 20px; 
        border-left: 4px solid #6366f1; 
    }
    .history-win { border-left-color: #34d399; background: linear-gradient(to right, rgba(52, 211, 153, 0.1), rgba(0,0,0,0.2)); }
    .history-loss { border-left-color: #f87171; }
    
    .h-left { display: flex; flex-direction: column; width: 100px; }
    .h-result { font-weight: bold; font-size: 1.1rem; }
    .h-placement { font-size: 0.8rem; color: #94a3b8; }
    
    .h-mid { display: flex; flex-direction: column; flex-grow: 1; padding: 0 20px; }
    .h-score { font-weight: 600; }
    .h-cards { font-size: 0.85rem; color: #cbd5e1; }
    
    .h-right { text-align: right; font-size: 0.8rem; color: #64748b; }

    .spinner-sm {
        display: inline-block;
        width: 16px; height: 16px;
        border: 2px solid rgba(255,255,255,0.3);
        border-radius: 50%;
        border-top-color: white;
        animation: spin 1s ease-in-out infinite;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

@code {
    private ProfileModel? _profile;
    private PlayerStatsModel? _stats;
    private List<MatchPlayerModel>? _history;
    private string _editName = "";
    private bool _isSaving = false;
    private string _errorMessage = "";

    // Guest registration fields
    private string _regDisplayName = "";
    private string _regEmail = "";
    private string _regPassword = "";
    private string _regError = "";
    private string _regSuccess = "";
    private bool _isRegistering = false;
    private bool _showGuestSignIn = false;

    private void ToggleGuestAuthMode()
    {
        _showGuestSignIn = !_showGuestSignIn;
        _regError = "";
        _regSuccess = "";
    }

    private async Task SignInFromProfile()
    {
        if (string.IsNullOrWhiteSpace(_regEmail) || string.IsNullOrWhiteSpace(_regPassword))
        {
            _regError = "Please enter your email and password.";
            return;
        }
        _isRegistering = true;
        _regError = "";
        _regSuccess = "";
        try
        {
            await Supabase.SignInWithEmail(_regEmail, _regPassword);
            Navigation.NavigateTo("/home", forceLoad: true);
        }
        catch
        {
            _regError = "Invalid email or password.";
            _isRegistering = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        NavigationState.IsArenaMode = true;
        
        var uid = Supabase.CurrentUserId;
        if (uid == null)
        {
            Navigation.NavigateTo("/");
            return;
        }

        _profile = await Supabase.GetProfile(uid);
        _editName = _profile?.DisplayName ?? "";
        _regDisplayName = _profile?.DisplayName ?? "";
        
        _stats = await Supabase.GetMyStats();
        _history = await Supabase.GetMatchHistory(uid);
    }

    private async Task RegisterGuestAccount()
    {
        if (string.IsNullOrWhiteSpace(_regDisplayName) || _regDisplayName.Length < 2 || _regDisplayName.Length > 20)
        {
            _regError = "Display name must be 2-20 characters.";
            return;
        }
        if (string.IsNullOrWhiteSpace(_regEmail) || !System.Text.RegularExpressions.Regex.IsMatch(_regEmail, @"^[^@\s]+@[^@\s]+\.[^@\s]+$"))
        {
            _regError = "Please enter a valid email address (e.g., player@example.com).";
            return;
        }
        if (string.IsNullOrWhiteSpace(_regPassword) || _regPassword.Length < 6)
        {
            _regError = "Password must be at least 6 characters.";
            return;
        }

        _isRegistering = true;
        _regError = "";
        _regSuccess = "";

        try
        {
            await Supabase.ConvertGuestToRegistered(_regEmail, _regPassword, _regDisplayName);
            _regSuccess = "Account successfully registered!";
            if (Supabase.CurrentUserId != null)
            {
                _profile = await Supabase.GetProfile(Supabase.CurrentUserId);
                _editName = _profile?.DisplayName ?? "";
            }
        }
        catch (Exception ex)
        {
            _regError = $"Registration failed: {ex.Message}";
        }

        _isRegistering = false;
    }

    private async Task SaveProfile()
    {
        if (Supabase.IsGuest) return;
        if (string.IsNullOrWhiteSpace(_editName) || _profile == null) return;
        
        _isSaving = true;
        _errorMessage = "";
        
        try
        {
            await Supabase.UpdateDisplayName(_editName);
            _profile.DisplayName = _editName;
        }
        catch (Supabase.Postgrest.Exceptions.PostgrestException ex) when (ex.Message.Contains("unique constraint"))
        {
            _errorMessage = "That display name is already taken!";
        }
        catch (Exception ex)
        {
            _errorMessage = "Failed to update profile.";
        }
        
        _isSaving = false;
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        // Limit to 5MB
        if (file.Size > 5 * 1024 * 1024) return;
        
        try
        {
            using var stream = file.OpenReadStream(5 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();
            
            var newUrl = await Supabase.UploadAvatar(bytes, file.Name);
            if (newUrl != null && _profile != null)
            {
                _profile.AvatarUrl = newUrl;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error uploading avatar: {ex.Message}");
        }
    }

    private async Task SignOut()
    {
        await Supabase.SignOut();
        Navigation.NavigateTo("/");
    }

    private string GetOrdinal(int num)
    {
        if (num <= 0) return "";
        switch (num % 100)
        {
            case 11:
            case 12:
            case 13:
                return "th";
        }
        switch (num % 10)
        {
            case 1: return "st";
            case 2: return "nd";
            case 3: return "rd";
            default: return "th";
        }
    }
}
