    private UnoGame? _game;

    private bool _showRulesModal = false;
    private bool _showRuleBookModal = false;

    private List<RulePresetProfile> _presets = new();
    private RulePresetProfile _selectedPreset = null!;
    
    private RulePresetProfile? _editingPreset;
    private GameSettings? _editingSettings;

    private string _activeTab = "general";

    private enum RuleType
    {
        Toggle,
        Slider
    }

    private class RuleItem
    {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Icon { get; set; } = "";
        public RuleType Type { get; set; }
        public Func<GameSettings, bool> GetBoolValue { get; set; } = _ => false;
        public Action<GameSettings, bool> SetBoolValue { get; set; } = (_, _) => { };
        public Func<GameSettings, double> GetNumberValue { get; set; } = _ => 0;
        public Action<GameSettings, double> SetNumberValue { get; set; } = (_, _) => { };
        public double Min { get; set; }
        public double Max { get; set; }
        public double Step { get; set; } = 1.0;
        public string Unit { get; set; } = "";
        public string Format { get; set; } = "0";
        public Func<GameSettings, bool> IsVisible { get; set; } = _ => true;
    }

    private List<RuleItem> _ruleItems = new();

    private void InitializeRuleItems()
    {
        _ruleItems = new List<RuleItem>
        {
            new RuleItem
            {
                Title = "Starting Hand Size",
                Description = "Cards dealt to each player at the match start (Clamped 3 to 10).",
                Icon = "🃏",
                Type = RuleType.Slider,
                Min = 3, Max = 10, Step = 1, Unit = "Cards", Format = "0",
                GetNumberValue = s => s.StartingHandSize,
                SetNumberValue = (s, v) => s.StartingHandSize = (int)v
            },
            new RuleItem
            {
                Title = "Stacking (+2 / +4)",
                Description = "Stack draw penalty cards to pass the accumulated total downstream.",
                Icon = "🔥",
                Type = RuleType.Toggle,
                GetBoolValue = s => s.Stacking,
                SetBoolValue = (s, v) => s.Stacking = v
            },
            new RuleItem
            {
                Title = "Draw Until Playable",
                Description = "Must draw continuous cards until a playable card is pulled.",
                Icon = "🔄",
                Type = RuleType.Toggle,
                GetBoolValue = s => s.DrawUntilPlayable,
                SetBoolValue = (s, v) => s.DrawUntilPlayable = v
            },
            new RuleItem
            {
                Title = "Forced Play",
                Description = "Players MUST play a card if they have a match in hand (disables reneging/drawing).",
                Icon = "🔒",
                Type = RuleType.Toggle,
                GetBoolValue = s => s.ForcedPlay,
                SetBoolValue = (s, v) => s.ForcedPlay = v
            },
            new RuleItem
            {
                Title = "Wild Draw 4 Challenge",
                Description = "Targets can challenge played +4s for illegal matching color.",
                Icon = "⚔️",
                Type = RuleType.Toggle,
                GetBoolValue = s => s.EnableWildDraw4Challenge,
                SetBoolValue = (s, v) => s.EnableWildDraw4Challenge = v
            },
            new RuleItem
            {
                Title = "7-Swap",
                Description = "Forces hand-swaps with another player when a 7 is played.",
                Icon = "🃏",
                Type = RuleType.Toggle,
                GetBoolValue = s => s.SevenSwap,
                SetBoolValue = (s, v) => s.SevenSwap = v
            },
            new RuleItem
            {
                Title = "Zero Rotate",
                Description = "Rotates everyone's hands along direction of play on a 0.",
                Icon = "🔃",
                Type = RuleType.Toggle,
                GetBoolValue = s => s.ZeroRotate,
                SetBoolValue = (s, v) => s.ZeroRotate = v
            },
            new RuleItem
            {
                Title = "Jump-In Rule",
                Description = "Play out of turn if you hold an exact color AND value duplicate match.",
                Icon = "⚡",
                Type = RuleType.Toggle,
                GetBoolValue = s => s.JumpInRule,
                SetBoolValue = (s, v) => s.JumpInRule = v
            },
            new RuleItem
            {
                Title = "Vortex",
                Description = "Vortex swallows all the card and redistribute everyone's hand.",
                Icon = "🌀",
                Type = RuleType.Toggle,
                GetBoolValue = s => s.EnableVortex,
                SetBoolValue = (s, v) => s.EnableVortex = v
            },
            new RuleItem
            {
                Title = "Uno Call Failure Penalty",
                Description = "Cards drawn if caught failing to call UNO (Clamped 1 to 5).",
                Icon = "🔔",
                Type = RuleType.Slider,
                Min = 1, Max = 5, Step = 1, Unit = "Cards", Format = "0",
                GetNumberValue = s => s.UnoFailurePenaltyCards,
                SetNumberValue = (s, v) => s.UnoFailurePenaltyCards = (int)v
            },
            new RuleItem
            {
                Title = "Jump-In QTE Timer",
                Description = "Speed window (seconds) to intercept duplicates out of turn.",
                Icon = "⏱️",
                Type = RuleType.Slider,
                Min = 1.0, Max = 5.0, Step = 0.5, Unit = "s", Format = "0.0",
                GetNumberValue = s => s.JumpInTimerSeconds,
                SetNumberValue = (s, v) => s.JumpInTimerSeconds = v,
                IsVisible = s => s.JumpInRule
            }
        };
    }

