    // ── AFK Timer ─────────────────────────────────────────────────────────────
    private void ManageAfkTimer()
    {
        if (_game == null || _game.Status == GameStatus.GameOver) { CancelAfkTimer(); return; }
        if (!_game.Settings.AfkEnabled) { CancelAfkTimer(); return; }

        int curIdx = -1;
        Player? curPlayer = null;

        // Determine which player we're waiting on based on game status
        if (_game.Status == GameStatus.Playing)
        {
            curIdx = _game.CurrentPlayerIndex;
            curPlayer = _game.Players[curIdx];
        }
        else if (_game.Status == GameStatus.WaitingForColorSelection && _game.PendingColorSelector != null)
        {
            curIdx = _game.Players.IndexOf(_game.PendingColorSelector);
            curPlayer = _game.PendingColorSelector;
        }
        else if (_game.Status == GameStatus.WaitingForSwapTarget)
        {
            curIdx = _game.CurrentPlayerIndex;
            curPlayer = _game.Players[curIdx];
        }
        else if (_game.Status == GameStatus.WaitingForWd4Challenge)
        {
            curIdx = _game.Wd4ChallengerIndex;
            if (curIdx >= 0 && curIdx < _game.Players.Count)
                curPlayer = _game.Players[curIdx];
        }
        // WaitingForUnoCall and WaitingForJumpIn already have their own timers in UnoGame, so skip those

        if (curPlayer == null || !curPlayer.IsHuman)
        {
            CancelAfkTimer();
            return;
        }

        // If the current player is a remote human and we're NOT the host, don't start timer here.
        if (_game.RemotePlayerIndices.Contains(curIdx) && !_isMultiplayerHost)
        {
            CancelAfkTimer();
            return;
        }

        // Same player still their turn and same status — timer already running
        if (_afkTimerPlayerIndex == curIdx && _afkCts != null && _afkTimerStatus == _game.Status) return;

        // New turn or meaningful local action/status change for the same player — restart timer
        CancelAfkTimer();
        _afkTimerPlayerIndex = curIdx;
        _afkTimerStatus = _game.Status;
        _afkCts = new CancellationTokenSource();
        var token = _afkCts.Token;
        var timeoutMs = (int)(_game.Settings.AfkTimeoutSeconds * 1000);

        _ = Task.Run(async () =>
        {
            await Task.Delay(timeoutMs, token);
            if (token.IsCancellationRequested) return;
            if (_game != null && _game.Status == _afkTimerStatus && _game.Status != GameStatus.GameOver)
            {
                // Verify we're still waiting on the same player
                bool stillWaiting = false;
                if (_game.Status == GameStatus.Playing)
                    stillWaiting = _game.CurrentPlayerIndex == curIdx;
                else if (_game.Status == GameStatus.WaitingForColorSelection)
                    stillWaiting = _game.PendingColorSelector == curPlayer;
                else if (_game.Status == GameStatus.WaitingForSwapTarget)
                    stillWaiting = _game.CurrentPlayerIndex == curIdx;
                else if (_game.Status == GameStatus.WaitingForWd4Challenge)
                    stillWaiting = _game.Wd4ChallengerIndex == curIdx;

                if (stillWaiting)
                {
                    if (_isMultiplayerHost && _game.RemotePlayerIndices.Contains(curIdx))
                    {
                        if (_pendingRemoteMoves.TryGetValue(curIdx, out var tcs))
                            tcs.TrySetResult(new MoveDto { PlayerIndex = curIdx, Type = "afk" });
                        else
                            // If not in pendingRemoteMoves, just call ApplyRemoteMoveAsync directly
                            await InvokeAsync(async () => await _game.ApplyRemoteMoveAsync(new MoveDto { PlayerIndex = curIdx, Type = "afk" }));
                    }
                    else
                    {
                        await InvokeAsync(async () => await _game.ApplyAfkPenaltyAsync());
                    }
                }
            }
        }, token);
    }

    private void CancelAfkTimer()
    {
        _afkCts?.Cancel();
        _afkCts = null;
        _afkTimerPlayerIndex = -1;
        _afkTimerStatus = null;
    }

    // ── Leaderboard ────────────────────────────────────────────────────────────
    private void UpdateLeaderboard()
    {
        if (_game == null) return;
        var winner = _game.Winner;
        foreach (var player in _game.Players)
        {
            if (!player.IsHuman) continue;
            var entry = _leaderboard.FirstOrDefault(e => e.Name == player.Name);
            if (entry == null)
            {
                entry = new LeaderboardEntry { Name = player.Name };
                _leaderboard.Add(entry);
            }
            if (player == winner) entry.Wins++;
            else entry.Losses++;
            entry.LastPlayed = DateTime.Now;
        }
        _leaderboard = _leaderboard.OrderByDescending(e => e.Wins).ThenBy(e => e.Losses).ToList();
    }

