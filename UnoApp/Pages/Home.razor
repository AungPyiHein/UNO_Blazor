        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.2s;
    }
    .sidebar-tab:hover {
        background: rgba(255, 255, 255, 0.06);
        color: #ffffff;
    }
    .sidebar-tab.active {
        background: rgba(59, 130, 246, 0.15);
        color: #60a5fa;
        border-left: 3px solid #3b82f6;
    }

    .rulebook-content { 
        flex: 1;
        overflow-y: auto;
        padding: 0 10px 10px 5px;
    }


    .tab-pane h3 {
        font-size: 1.8rem;
        font-weight: 900;
        margin-top: 0;
        margin-bottom: 20px;
        color: #ffffff;
    }
    .tab-pane h4 {
        font-size: 1.3rem;
        font-weight: 800;
        color: #3b82f6;
        margin-bottom: 10px;
    }
    .tab-pane p {
        font-size: 1.05rem;
        color: #cbd5e1;
        line-height: 1.8;
    }
    .tab-pane ul {
        padding-left: 24px;
        color: #cbd5e1;
        line-height: 1.8;
    }
    .tab-pane li {
        margin-bottom: 10px;
        font-size: 1rem;
    }
    .text-orange h4 { color: #f59e0b !important; }
 
    .action-card-desc { display: flex; gap: 20px; align-items: flex-start; margin-bottom: 24px; }
    .action-card-desc p { margin: 0; font-size: 0.85rem; line-height: 1.4; color: #94a3b8; }

    /* ── RULEBOOK REDESIGN (More Readable) ── */
    .rb-intro {
        font-size: 1rem;
        color: #cbd5e1;
        margin: 0 0 24px 0;
        line-height: 1.7;
    }
    .rb-section {
        margin-bottom: 30px;
        padding-bottom: 30px;
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .rb-section:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
    .rb-section h4 { margin: 0 0 12px 0; }
    .rb-section p { margin: 0 0 12px 0; }
    .rb-section p:last-child { margin-bottom: 0; }
    .rb-section ul { margin: 10px 0 0 0; }

    .rb-card-row {
        display: flex;
        gap: 20px;
        align-items: flex-start;
        margin-bottom: 24px;
        padding-bottom: 24px;
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .rb-card-row:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
    .rb-card-info {
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex: 1;
    }
    .rb-card-info strong {
        font-size: 1.2rem;
        font-weight: 800;
        color: #ffffff;
    }
    .rb-card-info p {
        margin: 0;
        font-size: 1rem;
        color: #cbd5e1;
        line-height: 1.7;
    }

    .rb-badge {
        display: inline-block;
        font-size: 0.8rem;
        font-weight: 800;
        padding: 4px 12px;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        width: fit-content;
    }
    .rb-badge-red    { background: rgba(239,68,68,0.2);  color: #fca5a5; border: 1px solid rgba(239,68,68,0.4); }
    .rb-badge-blue   { background: rgba(59,130,246,0.2); color: #93c5fd; border: 1px solid rgba(59,130,246,0.4); }
    .rb-badge-green  { background: rgba(34,197,94,0.2);  color: #86efac; border: 1px solid rgba(34,197,94,0.4); }
    .rb-badge-wild   { background: rgba(245,158,11,0.2); color: #fcd34d; border: 1px solid rgba(245,158,11,0.4); }
    .rb-badge-purple { background: rgba(168,85,247,0.2); color: #c4b5fd; border: 1px solid rgba(168,85,247,0.4); }

    .rb-info-box {
        margin-top: 14px;
        padding: 14px 18px;
        border-radius: 12px;
        font-size: 0.95rem;
        line-height: 1.7;
    }
    .rb-info-tip {
        background: rgba(59,130,246,0.12);
        border: 1px solid rgba(59,130,246,0.3);
        color: #bfdbfe;
    }
    .rb-info-warn {
        background: rgba(245,158,11,0.12);
        border: 1px solid rgba(245,158,11,0.3);
        color: #fde68a;
    }
    .rb-info-tip strong, .rb-info-warn strong { color: inherit; }

    .rb-score-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 1rem;
        margin-top: 16px;
    }
    .rb-score-table thead tr {
        border-bottom: 2px solid rgba(255,255,255,0.15);
    }
    .rb-score-table th {
        padding: 12px 14px;
        text-align: left;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #94a3b8;
        font-weight: 800;
    }
    .rb-score-table td {
        padding: 12px 14px;
        color: #e2e8f0;
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .rb-score-table td:last-child {
        text-align: right;
        font-weight: 800;
        color: #4ade80;
        font-variant-numeric: tabular-nums;
        font-size: 1.05rem;
    }
    .rb-score-table tr:last-child td { border-bottom: none; }

    .rb-vortex-row .rb-card-info p,
    .rb-vortex-section p,
    .rb-vortex-section ul {
        color: #c084fc !important;
    }
    .rb-vortex-section h4 { color: #a855f7 !important; }

    .house-rule-desc {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 14px;
        margin-bottom: 15px;
    }
    .house-rule-desc h4 { color: #f59e0b; margin: 0 0 6px 0; }
    .house-rule-desc p { margin: 0; font-size: 0.85rem; }

    /* Stacked cards for Draw Until Playable */
    .rule-icon.stacked-cards {
        position: relative;
        display: inline-flex;
        width: 70px;
        height: 40px;
        align-items: center;
        margin-right: 10px;
        flex-shrink: 0;
    }
    
    /* Premium Rule Select Dropdown */
    .rule-select {
        background: rgba(30, 41, 59, 0.8);
        border: 1px solid rgba(59, 130, 246, 0.3);
        color: #e2e8f0;
        border-radius: 12px;
        padding: 10px 16px;
        font-weight: 800;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        outline: none;
        min-width: 120px;
    }
    .rule-select:hover {
        background: rgba(30, 41, 59, 1);
        border-color: rgba(59, 130, 246, 0.6);
        box-shadow: 0 0 20px rgba(59, 130, 246, 0.15);
    }
    .rule-select:focus {
        background: rgba(30, 41, 59, 1);
        border-color: #3b82f6;
        box-shadow: 0 0 25px rgba(59, 130, 246, 0.25);
    }
    .rule-select option {
        background: #1e293b;
        color: #e2e8f0;
        font-weight: 700;
        padding: 8px;
    }
    .rule-icon.stacked-cards span {
        position: absolute;
        font-size: 1.8rem;
        line-height: 1;
        transition: transform 0.2s ease;
    }
    .rule-icon.stacked-cards .card-1 {
        left: 0;
        z-index: 1;
    }
    .rule-icon.stacked-cards .card-2 {
        left: 10px;
        z-index: 2;
    }
    .rule-icon.stacked-cards .card-3 {
        left: 20px;
        z-index: 3;
    }

    /* Animations */
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
    @@keyframes slideUp {
        from { transform: translateY(30px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }

    /* ── INLINE LOBBY ── */
    .inline-lobby {
        position: absolute;
        inset: 0;
        overflow-y: auto;
        overflow-x: hidden;
        padding: 120px 20px 40px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        animation: fadeIn 0.25s ease;
        scrollbar-width: thin;
        scrollbar-color: rgba(255,255,255,0.15) transparent;
    }
    .inline-lobby::-webkit-scrollbar { width: 5px; }
    .inline-lobby::-webkit-scrollbar-track { background: transparent; }
    .inline-lobby::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 99px; }

    /* waiting room: no outer scroll, fills viewport, but has top padding for menu */
    .inline-lobby.lobby-in-waiting {
        overflow: hidden;
        padding-top: 100px;
        padding-bottom: 20px;
        padding-left: 0;
        padding-right: 0;
        display: block;
        align-items: unset;
        justify-content: unset;
    }

    /* ── TWO-COLUMN WAITING ROOM ── */
    .lobby-room-layout {
        display: grid;
        grid-template-columns: 1fr 280px;
        height: calc(100vh - 120px);
        width: 100%;
    }

    .lobby-room-left {
        overflow-y: auto;
        padding: 20px 24px 24px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        border-right: 1px solid rgba(255,255,255,0.07);
        scrollbar-width: thin;
        scrollbar-color: rgba(255,255,255,0.15) transparent;
    }
    .lobby-room-left::-webkit-scrollbar { width: 4px; }
    .lobby-room-left::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 99px; }

    .lobby-room-right {
        display: flex;
        flex-direction: column;
        background: rgba(0,0,0,0.14);
        overflow: hidden;
    }

    .lobby-room-chat-header {
        padding: 14px 14px 10px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 1px;
        color: rgba(255,255,255,0.35);
        text-transform: uppercase;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        flex-shrink: 0;
    }

    .lobby-chat-side {
        flex: 1;
        padding: 10px 12px 12px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        gap: 8px;
        min-height: 0;
    }

    .lobby-chat-messages-side {
        height: auto !important;
        flex: 1;
        min-height: 0;
    }

    /* ── ENTRY SCREEN ── */
    .inline-lobby-entry {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 32px;
        width: 100%;
        max-width: 680px;
    }

    .lobby-entry-heading {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        text-align: center;
    }
    .lobby-entry-icon { font-size: 2.8rem; line-height: 1; filter: drop-shadow(0 0 18px rgba(99,102,241,0.7)); }
    .lobby-entry-title {
        font-size: 2.6rem;
        font-weight: 900;
        letter-spacing: 3px;
        background: linear-gradient(135deg, #818cf8 0%, #6366f1 50%, #4f46e5 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-shadow: none;
        margin: 0;
        filter: drop-shadow(0 0 24px rgba(99,102,241,0.5));
    }
    .lobby-entry-sub {
        color: rgba(255,255,255,0.4);
        font-size: 0.95rem;
        margin: 0;
        letter-spacing: 0.3px;
    }

    /* ── MODE BOXES (side by side) ── */
    .lobby-mode-row {
        display: flex;
        gap: 20px;
        width: 100%;
    }

    .lobby-mode-box {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        padding: 32px 20px;
        border-radius: 22px;
        border: 2px solid transparent;
        background: rgba(255,255,255,0.03);
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease, background 0.2s ease;
        position: relative;
        overflow: hidden;
    }
    .lobby-mode-box::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 20px;
        opacity: 0;
        transition: opacity 0.2s ease;
    }
    .lobby-mode-box:hover { transform: translateY(-4px); }
    .lobby-mode-box:hover::before { opacity: 1; }

    .lobby-mode-create {
        border-color: rgba(34,197,94,0.35);
        box-shadow: 0 0 0 0 rgba(34,197,94,0);
    }
    .lobby-mode-create::before {
        background: radial-gradient(ellipse at 50% 0%, rgba(34,197,94,0.12) 0%, transparent 70%);
    }
    .lobby-mode-create:hover {
        border-color: #22c55e;
        box-shadow: 0 0 32px rgba(34,197,94,0.35), inset 0 0 20px rgba(34,197,94,0.06);
        background: rgba(34,197,94,0.06);
    }

    .lobby-mode-join {
        border-color: rgba(99,102,241,0.35);
        box-shadow: 0 0 0 0 rgba(99,102,241,0);
    }
    .lobby-mode-join::before {
        background: radial-gradient(ellipse at 50% 0%, rgba(99,102,241,0.14) 0%, transparent 70%);
    }
    .lobby-mode-join:hover {
        border-color: #6366f1;
        box-shadow: 0 0 32px rgba(99,102,241,0.4), inset 0 0 20px rgba(99,102,241,0.07);
        background: rgba(99,102,241,0.07);
    }

    .lmb-icon {
        font-size: 2.4rem;
        line-height: 1;
        transition: transform 0.2s ease;
    }
    .lobby-mode-box:hover .lmb-icon { transform: scale(1.15); }

    .lmb-label {
        font-size: 1.15rem;
        font-weight: 900;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #fff;
    }
    .lobby-mode-create .lmb-label { color: #4ade80; text-shadow: 0 0 12px rgba(34,197,94,0.5); }
    .lobby-mode-join     .lmb-label { color: #818cf8; text-shadow: 0 0 12px rgba(99,102,241,0.5); }



    .lmb-desc {
        font-size: 0.82rem;
        color: rgba(255,255,255,0.4);
        text-align: center;
        line-height: 1.4;
    }

    /* ── CANCEL BUTTON ── */
    .lobby-cancel-btn {
        background: transparent;
        border: 1.5px solid rgba(255,255,255,0.12);
        border-radius: 14px;
        color: rgba(255,255,255,0.45);
        font-size: 0.9rem;
        font-weight: 700;
        padding: 12px 36px;
        cursor: pointer;
        letter-spacing: 0.5px;
        transition: border-color 0.2s, color 0.2s, background 0.2s;
    }
    .lobby-cancel-btn:hover {
        border-color: rgba(255,255,255,0.3);
        color: rgba(255,255,255,0.75);
        background: rgba(255,255,255,0.04);
    }

    /* ── INNER LOBBY CARDS (create / join / spectate) ── */
    .inline-lobby-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 24px;
        padding: 24px 32px;
        width: 100%;
        max-width: 460px;
        display: flex;
        flex-direction: column;
        gap: 18px;
        animation: slideUp 0.22s ease;
    }
    .lobby-room-card { max-width: 480px; }

    .lobby-title  { font-size: 2rem; font-weight: 900; color: #22c55e; margin: 0; text-align: center; }
    .lobby-sub    { color: rgba(255,255,255,0.5); font-size: 0.9rem; text-align: center; margin: 0; }
    .lobby-logo   { font-size: 3.5rem; line-height: 1; text-align: center; }
    .lobby-error  { color: #ef4444; font-size: 0.9rem; margin: 0; text-align: center; }
    .lobby-waiting { color: rgba(255,255,255,0.5); font-size: 0.9rem; text-align: center; margin: 0; }

    .lobby-field { display: flex; flex-direction: column; gap: 6px; }
    .lobby-field label { color: rgba(255,255,255,0.6); font-size: 0.85rem; font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; }
    .lobby-hint { color: rgba(255,255,255,0.4); font-size: 0.8rem; margin: 2px 0 0; }

    .lobby-input {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 12px;
        padding: 12px 16px;
        color: #fff;
        font-size: 1rem;
        outline: none;
        transition: border-color 0.2s;
        flex: 1;
    }
    .lobby-input:focus { border-color: #22c55e; }
    .lobby-input-code { text-transform: uppercase; letter-spacing: 2px; font-weight: 700; }
    .room-code-row { display: flex; gap: 8px; }
    .gen-btn {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 12px;
        color: #fff;
        font-size: 1.1rem;
        padding: 0 14px;
        cursor: pointer;
        transition: background 0.2s;
        flex-shrink: 0;
    }
    .gen-btn:hover { background: rgba(255,255,255,0.14); }

    .cpu-selector { display: flex; gap: 6px; flex-wrap: wrap; }
    .cpu-btn {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 10px;
        color: rgba(255,255,255,0.7);
        padding: 8px 14px;
        font-size: 0.85rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s, border-color 0.2s, color 0.2s;
    }
    .cpu-btn.active { background: rgba(99,102,241,0.25); border-color: #6366f1; color: #a5b4fc; }
    .cpu-btn:hover:not(.active) { background: rgba(255,255,255,0.1); }

    .lobby-btn {
        background: #22c55e;
        color: #000;
        border: none;
        border-radius: 14px;
        padding: 14px 28px;
        font-size: 1rem;
        font-weight: 800;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.1s;
        letter-spacing: 0.5px;
        width: 100%;
    }
    .lobby-btn:hover:not(:disabled) { opacity: 0.9; transform: translateY(-1px); }
    .lobby-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .lobby-btn-create { background: #22c55e; color: #000; box-shadow: 0 0 18px rgba(34,197,94,0.3); }
    .lobby-btn-join   { background: rgba(99,102,241,0.85); color: #fff; box-shadow: 0 0 18px rgba(99,102,241,0.3); }
    .lobby-btn-start  { background: #22c55e; color: #000; font-size: 1.1rem; box-shadow: 0 0 18px rgba(34,197,94,0.3); }
    .lobby-btn-start:disabled { background: rgba(34,197,94,0.3) !important; color: rgba(0,0,0,0.5) !important; box-shadow: none !important; opacity: 1 !important; }
    .lobby-btn-ready-off { background: rgba(99,102,241,0.2); border: 1px solid rgba(99,102,241,0.4); color: #a5b4fc; font-size: 1rem; font-weight: 800; }
    .lobby-btn-ready-off:hover { background: rgba(99,102,241,0.35); }
    .lobby-btn-ready-on  { background: rgba(34,197,94,0.2); border: 1px solid rgba(34,197,94,0.5); color: #4ade80; font-size: 1rem; font-weight: 800; box-shadow: 0 0 12px rgba(34,197,94,0.2); }
    .lobby-btn-ready-on:hover { background: rgba(34,197,94,0.3); }
    .lobby-btn-apply-rules { background: rgba(99,102,241,0.25); border: 1px solid rgba(99,102,241,0.45); color: #a5b4fc; font-size: 0.9rem; font-weight: 700; margin-top: 4px; }
    .lobby-btn-apply-rules:hover { background: rgba(99,102,241,0.4); color: #fff; }
    .lobby-btn-leave  { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.6); font-size: 0.9rem; }
    .lobby-btn-leave:hover { background: rgba(239,68,68,0.2); color: #ef4444; }
    .lobby-btn-back   { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.5); font-size: 0.9rem; }
    .lobby-btn-back:hover { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.8); }

    .lobby-room-code { font-size: 1.4rem; font-weight: 800; color: rgba(255,255,255,0.8); text-align: center; margin: 0; display: flex; align-items: center; justify-content: center; gap: 10px; flex-wrap: wrap; }
    .lobby-room-code span.room-code-clickable { color: #22c55e; font-size: 1.8rem; letter-spacing: 3px; display: inline-block; text-shadow: 0 0 18px rgba(34,197,94,0.5); cursor: pointer; user-select: all; transition: text-shadow 0.2s; }
    .lobby-room-code span.room-code-clickable:hover { text-shadow: 0 0 25px rgba(34,197,94,0.8); }
    .copy-room-btn {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 12px;
        color: #fff;
        font-size: 1.1rem;
        padding: 6px 12px;
        cursor: pointer;
        transition: background 0.2s;
        flex-shrink: 0;
    }
    .copy-room-btn:hover { background: rgba(255,255,255,0.14); }
    .lobby-players { display: flex; flex-direction: column; gap: 10px; }
    .lobby-player {
        display: flex; align-items: center; gap: 12px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        padding: 10px 14px;
    }
    .lobby-player-me  { border-color: #22c55e; background: rgba(34,197,94,0.08); }
    .lobby-player-cpu { border-color: rgba(99,102,241,0.3); background: rgba(99,102,241,0.06); }
    .lobby-player-avatar {
        width: 36px; height: 36px; border-radius: 50%;
        background: #22c55e; color: #000;
        display: flex; align-items: center; justify-content: center;
        font-weight: 900; font-size: 1rem; flex-shrink: 0;
    }
    .lobby-player-name { flex: 1; color: #fff; font-weight: 600; }
    .lobby-badge {
        background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.6);
        font-size: 0.7rem; font-weight: 800; letter-spacing: 1px;
        padding: 3px 8px; border-radius: 20px; text-transform: uppercase;
    }
