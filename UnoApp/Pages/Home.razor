        _editingSettings = newPreset.Settings.Clone();
    }

    private void DeletePreset(RulePresetProfile preset)
    {
        if (preset.IsReadonly || preset.Name == "Chaos" || preset.Name == "Custom") return;
        
        _presets.Remove(preset);
        if (_editingPreset == preset)
        {
            _editingPreset = _presets.First(p => p.Name == "Classic");
            _editingSettings = _editingPreset.Settings.Clone();
        }
        if (_selectedPreset == preset)
        {
            _selectedPreset = _presets.First(p => p.Name == "Classic");
        }
    }

    private void ToggleRule(Action<bool> setter, ChangeEventArgs e)
    {
        if (_editingPreset?.IsReadonly == true) return;

        if (e.Value is bool val)
        {
            setter(val);
        }
    }

    private void ToggleDrawUntilPlayable(ChangeEventArgs e)
    {
        if (_editingPreset?.IsReadonly == true) return;

        if (e.Value is bool val)
        {
            _editingSettings.DrawUntilPlayable = val;
            if (val)
            {
                _editingSettings.ForcedPlay = true;
            }
        }
    }

    private void ToggleForcedPlay(ChangeEventArgs e)
    {
        if (_editingPreset?.IsReadonly == true) return;

        if (e.Value is bool val)
        {
            _editingSettings.ForcedPlay = val;
            if (!val && _editingSettings.DrawUntilPlayable)
            {
                _editingSettings.DrawUntilPlayable = false;
            }
        }
    }

    private void UpdateStartingHandSize(ChangeEventArgs e)
    {
        if (_editingPreset?.IsReadonly == true || _editingSettings == null) return;
        if (int.TryParse(e.Value?.ToString(), out var val))
        {
            _editingSettings.StartingHandSize = Math.Clamp(val, 3, 10);
        }
    }

    private void UpdateUnoPenaltyCards(ChangeEventArgs e)
    {
        if (_editingPreset?.IsReadonly == true || _editingSettings == null) return;
        if (int.TryParse(e.Value?.ToString(), out var val))
        {
            _editingSettings.UnoFailurePenaltyCards = Math.Clamp(val, 1, 5);
        }
    }

    private void UpdateWd4WrongPenalty(ChangeEventArgs e)
    {
        if (_editingPreset?.IsReadonly == true || _editingSettings == null) return;
        if (int.TryParse(e.Value?.ToString(), out var val))
        {
            _editingSettings.Wd4WrongChallengePenalty = Math.Clamp(val, 6, 10);
        }
    }

    private void UpdateTimer(ChangeEventArgs e)
    {
        if (_editingPreset?.IsReadonly == true || _editingSettings == null) return;

        if (double.TryParse(e.Value?.ToString(), out var seconds))
        {
            _editingSettings.JumpInTimerSeconds = seconds;
        }
    }

    private async Task StartMatch()
    {
        _spDrawnCardId = null;
        _pendingAnimTrigger = "";
        var players = new List<Player>
        {
            new Player { Id = Guid.NewGuid(), Name = string.IsNullOrWhiteSpace(_playerName) ? "PLAYER" : _playerName.ToUpper(), IsHuman = true }
        };

        for (int i = 1; i < _playerCount; i++)
        {
            players.Add(new Player { Id = Guid.NewGuid(), Name = $"CPU {i}", IsHuman = false });
        }

        // Pass the settings of the active selected preset directly to the game session!
        _game = new UnoGame(players, _selectedPreset.Settings);
        _leaderboardUpdated = false;
        _game.OnBoardAnimation += async (anim) =>
        {
            _pendingAnimTrigger = anim;
            if (_gameViewRef != null) await _gameViewRef.TriggerAnimation(anim);
            _pendingAnimTrigger = "";
        };
        _game.OnStateChanged += async () =>
        {
            ManageAfkTimer();
            if (_game.Status == GameStatus.GameOver && !_leaderboardUpdated)
            {
                UpdateLeaderboard();
                _leaderboardUpdated = true;
            }
            _spState = BuildSpState();
            await InvokeAsync(StateHasChanged);
        };

        _isGameStarted = true;
        await _game.DealStartingCardsAsync();
        _spState = BuildSpState();
        await _game.StartTurnAsync();
    }

    private void ResetGame()
    {
        CancelAfkTimer();
        _leaderboardUpdated = false;
        _isGameStarted = false;
        _game = null;
        _spState = null;
        _spDrawnCardId = null;
        _pendingAnimTrigger = "";
        if (_isMultiplayerHost)
        {
            LobbyService.MoveReceived -= OnRemoteMoveReceived;
            _isMultiplayerHost = false;
            LobbyService.ResetGame();
            foreach (var tcs in _pendingRemoteMoves.Values) tcs.TrySetResult(null);
            _pendingRemoteMoves.Clear();
        }
    }

    public async ValueTask DisposeAsync()
    {
        CancelAfkTimer();
        LobbyService.PlayersUpdated -= LobbyOnPlayersUpdated;
        LobbyService.GameStarted   -= LobbyOnGameStarted;
        LobbyService.RoomClosed    -= LobbyOnRoomClosed;
        LobbyService.RulesUpdated  -= LobbyOnRulesUpdated;
        LobbyService.PlayerKicked        -= LobbyOnPlayerKicked;
        LobbyService.ChatMessageReceived -= LobbyOnChatMessage;
        LobbyService.NextRoundRequested  -= LobbyOnNextRoundRequested;
        LobbyService.PlayerLeft          -= LobbyOnPlayerLeft;
        LobbyService.HubReconnecting     -= LobbyOnHubReconnecting;
        LobbyService.HubReconnected      -= LobbyOnHubReconnected;
        LobbyService.PlayerReadyUpdated  -= LobbyOnPlayerReadyUpdated;

        if (_isMultiplayerHost)
        {
            LobbyService.MoveReceived -= OnRemoteMoveReceived;
            foreach (var tcs in _pendingRemoteMoves.Values) tcs.TrySetResult(null);
        }
        await Task.CompletedTask;
    }

    private bool _nextRoundInProgress = false;

    private void LobbyOnHubReconnecting()
    {
        _hubReconnecting = true;
        InvokeAsync(StateHasChanged);
    }

    private void LobbyOnHubReconnected()
    {
        _hubReconnecting = false;
        InvokeAsync(StateHasChanged);
    }

    private void LobbyOnPlayerLeft(string playerName, bool wasHost)
    {
        if (!_isGameStarted || !_isMultiplayerHost || _game == null) return;

        int gameIdx = -1;
        for (int i = 0; i < _game.Players.Count; i++)
        {
            if (_game.Players[i].Name == playerName) { gameIdx = i; break; }
        }

        if (gameIdx >= 0)
        {
            if (_pendingRemoteMoves.TryGetValue(gameIdx, out var tcs))
            {
                _pendingRemoteMoves.Remove(gameIdx);
                tcs.TrySetResult(null);
            }

            _game.ConvertPlayerToAi(gameIdx);
        }

        _game.ActiveNotificationBanner = $"📶 {playerName.ToUpper()} DISCONNECTED";
        InvokeAsync(StateHasChanged);
    }

    private async void LobbyOnNextRoundRequested()
    {
        if (!_isMultiplayerHost || _nextRoundInProgress) return;
        if (_game?.Status != GameStatus.GameOver) return;
        _nextRoundInProgress = true;
        try
        {
            await InvokeAsync(async () =>
            {
                await HandleNextRound();
                StateHasChanged();
            });
        }
        finally { _nextRoundInProgress = false; }
    }

    private async Task HandleNextRound()
    {
        if (_game == null) return;
        _leaderboardUpdated = false;

        var prevPlayers = _game.Players.Select(p => new UnoEngine.Models.Player
        {
            Id = Guid.NewGuid(),
            Name = p.Name,
            IsHuman = p.IsHuman,
            TotalScore = p.TotalScore
        }).ToList();
        var settings = _game.Settings;
        int nextRound = _game.RoundNumber + 1;

        _game = new UnoGame(prevPlayers, settings);
        _game.RoundNumber = nextRound;

        if (_isMultiplayerHost)
        {
            int humanCount = LobbyService.AllPlayerNames.Length;
            for (int i = 1; i < humanCount; i++)
                _game.RemotePlayerIndices.Add(i);
            _game.GetRemoteHumanMove = GetRemoteMoveAsync;
            _game.OnBoardAnimation += async (anim) =>
            {
                _pendingAnimTrigger = anim;
                if (_gameViewRef != null) await _gameViewRef.TriggerAnimation(anim);
                await BroadcastStateAsync();
                _pendingAnimTrigger = "";
            };
            _game.OnStateChanged += async () =>
            {
                ManageAfkTimer();
                if (_game.Status == GameStatus.GameOver && !_leaderboardUpdated)
                {
                    UpdateLeaderboard();
                    _leaderboardUpdated = true;
                }
                _spState = BuildStateForPlayer(0);
                await BroadcastStateAsync();
                await InvokeAsync(StateHasChanged);
            };
            await _game.DealStartingCardsAsync();
            _spState = BuildStateForPlayer(0);
            await BroadcastStateAsync();
        }
        else
        {
            _game.OnBoardAnimation += async (anim) =>
            {
                _pendingAnimTrigger = anim;
                if (_gameViewRef != null) await _gameViewRef.TriggerAnimation(anim);
                _pendingAnimTrigger = "";
            };
            _game.OnStateChanged += async () =>
            {
                ManageAfkTimer();
                if (_game.Status == GameStatus.GameOver && !_leaderboardUpdated)
                {
                    UpdateLeaderboard();
                    _leaderboardUpdated = true;
                }
                _spState = BuildSpState();
                await InvokeAsync(StateHasChanged);
            };
            await _game.DealStartingCardsAsync();
            _spState = BuildSpState();
        }

        await _game.StartTurnAsync();
        StateHasChanged();
    }
}
