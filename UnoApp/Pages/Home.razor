@page "/"
@using UnoEngine
@using UnoEngine.Models
@using UnoApp.Components
@using UnoApp.Services
@using UnoApp.Multiplayer
@using System.Text.Json
@inject NavigationState NavigationState
@inject LobbyService LobbyService
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<div class="menu-screen @(_isGameStarted ? "game-active" : "")">
    @if (_isGameStarted)
    {
        <GameView @ref="_gameViewRef" State="@_spState" OnMove="HandleSpMove" OnNextRound="HandleNextRound" OnStartGame="ResetGame" OnAnimationMidpoint="HandleAnimMidpoint" ShowPauseButton="@(!_isMultiplayerHost)" OnPauseChanged="HandlePauseChanged" />
    }
    else
    {
        @if (!_showLobby)
        {
            <!-- Floating Header Action Buttons -->
            <div class="menu-header">
                <button class="glass-btn rulebook-trigger" @onclick="() => _showRuleBookModal = true">
                    <span class="icon">📖</span> Rule Book
                </button>
                <button class="glass-btn rules-trigger" @onclick="OpenRulesModal">
                    <span class="icon">⚙️</span> Manage Rules
                    <span class="active-preset-badge">@_selectedPreset.Name</span>
                </button>
                @if (_leaderboard.Count > 0)
                {
                    <button class="glass-btn leaderboard-trigger @(_leaderboardUpdated ? "leaderboard-updated" : "")"
                            @onclick="() => { _showLeaderboard = true; _leaderboardUpdated = false; }">
                        <span class="icon">🏆</span> Leaderboard
                        @if (_leaderboardUpdated) { <span class="lb-dot"></span> }
                    </button>
                }
            </div>

            <!-- Middle Tier: The Power Center -->
            <div class="center-stage">
                <button class="mega-start-btn" @onclick="StartMatch">START MATCH</button>
                <button class="mega-start-btn mega-start-btn-mp" @onclick="OpenLobby">🌐 MULTIPLAYER</button>
            </div>

            <!-- Bottom Tier: Player Identity & Setup -->
            <div class="identity-anchor">
                <div class="profile-input-box">
                    <div class="avatar-silhouette">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
                        </svg>
                    </div>
                    <input type="text" @bind="_playerName" placeholder="YOUR NAME" maxlength="12" />
                </div>
                
                <div class="player-count-box">
                    <span class="player-count-label">PLAYERS:</span>
                    <div class="count-selector">
                        @for (int i = 3; i <= 6; i++)
                        {
                            var currentVal = i;
                            <button type="button" class="count-btn @(_playerCount == currentVal ? "active" : "")" @onclick="() => _playerCount = currentVal">@currentVal</button>
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- Floating Header Action Buttons for Lobby -->
            <div class="menu-header lobby-menu-header">
                <button class="glass-btn rulebook-trigger" @onclick="() => _showRuleBookModal = true">
                    <span class="icon">📖</span> Rule Book
                </button>
                <button class="glass-btn lobby-back-btn" @onclick="CloseLobby">
                    <span class="icon">←</span> Back
                </button>
            </div>

            <!-- Inline Multiplayer Lobby -->
            <div class="inline-lobby @(_lobbyMode == "waiting" ? "lobby-in-waiting" : "")">
                @if (_lobbyMode == "entry")
                {
                    <div class="inline-lobby-entry">
                        @if (_wasKicked)
                        {
                            <div class="lobby-kicked-notice">
                                ⛔ You were removed from the room by the host.
                                <button class="lobby-kicked-dismiss" @onclick="() => _wasKicked = false">✕</button>
                            </div>
                        }
                        <div class="lobby-entry-heading">
                            <span class="lobby-entry-icon">🌐</span>
                            <h1 class="lobby-entry-title">MULTIPLAYER</h1>
                            <p class="lobby-entry-sub">Host a room or jump into a friend's game</p>
                        </div>

                        <div class="lobby-mode-row">
                            <button class="lobby-mode-box lobby-mode-create" @onclick='() => { _lobbyMode = "create"; LobbyGenerateRoomCode(); }'>
                                <span class="lmb-icon">➕</span>
                                <span class="lmb-label">Create Room</span>
                                <span class="lmb-desc">Host a new game and invite friends</span>
                            </button>
                            <button class="lobby-mode-box lobby-mode-join" @onclick='() => _lobbyMode = "join"'>
                                <span class="lmb-icon">🔗</span>
                                <span class="lmb-label">Join Room</span>
                                <span class="lmb-desc">Enter a code and jump in</span>
                            </button>
                        </div>

                        <button class="lobby-cancel-btn" @onclick="CloseLobby">← Back to Home</button>
                    </div>
                }
                else if (_lobbyMode == "create")
                {
                    <div class="inline-lobby-card">
                        <h1 class="lobby-title" style="font-size:1.5rem">Create Room</h1>
                        <div class="lobby-field">
                            <label>Your Name</label>
                            <input class="lobby-input" @bind="_lobbyPlayerName" placeholder="e.g. Alice" maxlength="20" />
                        </div>
                        <div class="lobby-field">
                            <label>Total Players</label>
                            <div class="count-selector">
                                @for (int n = 2; n <= 6; n++)
                                {
                                    var num = n;
                                    <button type="button" class="count-btn @(_lobbyTotalPlayers == num ? "active" : "")" @onclick="() => LobbySetTotalPlayers(num)">@num</button>
                                }
                            </div>
                            <p class="lobby-hint">1 human host + up to @(_lobbyTotalPlayers - 1) more seats</p>
                        </div>
                        <div class="lobby-field">
                            <label>CPU Players (fill empty seats)</label>
                            <div class="cpu-selector">
                                @for (int i = 0; i <= _lobbyTotalPlayers - 1; i++)
                                {
                                    var count = i;
                                    <button type="button" class="cpu-btn @(_lobbyCpuCount == count ? "active" : "")" @onclick="() => _lobbyCpuCount = count">
                                        @(count == 0 ? "None" : $"{count} CPU{(count > 1 ? "s" : "")}")
                                    </button>
                                }
                            </div>
                            @{
                                int humanSeats = _lobbyTotalPlayers - 1 - _lobbyCpuCount;
                            }
                            @if (humanSeats > 0)
                            {
                                <p class="lobby-hint">Waiting for @humanSeats more human@(humanSeats > 1 ? "s" : "") to join</p>
                            }
                            else
                            {
                                <p class="lobby-hint" style="color:#a5b4fc">All seats filled with CPUs — can start solo!</p>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(_lobbyError))
                        {
                            <p class="lobby-error">@_lobbyError</p>
                        }
                        <button class="lobby-btn lobby-btn-create" @onclick="LobbyCreateRoom" disabled="@_lobbyConnecting">
                            @(_lobbyConnecting ? "Creating…" : "Create Room")
                        </button>
                        <button class="lobby-btn lobby-btn-back" @onclick='() => _lobbyMode = "entry"'>← Back</button>
                    </div>
                }
                else if (_lobbyMode == "join")
                {
                    <div class="inline-lobby-card">
                        <h1 class="lobby-title" style="font-size:1.5rem">Join Room</h1>
                        <div class="lobby-field">
                            <label>Your Name</label>
                            <input class="lobby-input" @bind="_lobbyPlayerName" placeholder="e.g. Bob" maxlength="20" />
                        </div>
                        <div class="lobby-field">
                            <label>Room Code</label>
                            <input class="lobby-input lobby-input-code" @bind="_lobbyRoomCode" placeholder="e.g. GAME01" maxlength="8" @oninput="LobbyUpperRoomCode" />
                        </div>
                        @if (!string.IsNullOrEmpty(_lobbyError))
                        {
                            <p class="lobby-error">@_lobbyError</p>
                        }
                        <button class="lobby-btn" @onclick="LobbyJoinRoom" disabled="@_lobbyConnecting">
                            @(_lobbyConnecting ? "Joining…" : "Join Room")
                        </button>
                        <button class="lobby-btn lobby-btn-back" @onclick='() => _lobbyMode = "entry"'>← Back</button>
                    </div>
                }
                else if (_lobbyMode == "waiting")
                {
                    <div class="lobby-room-layout">
            <!-- LEFT: players, rules, start -->
            <div class="lobby-room-left">
                <h2 class="lobby-room-code">
                    Room 
                    <span class="room-code-clickable" @onclick="CopyRoomCode">@_lobbyRoomCode.ToUpperInvariant()</span>
                    <button class="copy-room-btn" @onclick="CopyRoomCode" title="Copy room code">📋</button>
                </h2>

                            <div class="lobby-players">
                                @foreach (var (player, idx) in _lobbyPlayers.Select((p, i) => (p, i)))
                                {
                                    var playerName = player;
                                    <div class="lobby-player @(player == _lobbyPlayerName.Trim() ? "lobby-player-me" : "")">
                                        <span class="lobby-player-avatar">@(player.Length > 0 ? player[0].ToString().ToUpper() : "?")</span>
                                        <span class="lobby-player-name">@player</span>
                                        @if (idx == 0) { <span class="lobby-badge">HOST</span> }
                                        @if (player == _lobbyPlayerName.Trim()) { <span class="lobby-badge lobby-badge-you">YOU</span> }
                                        @if (idx > 0 && _guestReadyStates.TryGetValue(player, out var rBadge) && rBadge) { <span class="lobby-badge lobby-badge-ready">✓ READY</span> }
                                        @if (_lobbyIsHost && idx != 0)
                                        {
                                            <button class="lobby-kick-btn" title="Kick @player"
                                                    @onclick="async () => await LobbyKickPlayer(playerName)">✕</button>
                                        }
                                    </div>
                                }
                                @for (int i = 0; i < _lobbyCpuCount; i++)
                                {
                                    var cpuNum = i + 1;
                                    <div class="lobby-player lobby-player-cpu">
                                        <span class="lobby-player-avatar" style="background:#6366f1;">🤖</span>
                                        <span class="lobby-player-name">CPU @cpuNum</span>
                                        <span class="lobby-badge lobby-badge-cpu">AI</span>
                                    </div>
                                }
                            </div>

                            @if (_lobbyIsHost)
                            {
                                <div class="lobby-field">
                                <label>CPU Players</label>
                                <div class="cpu-selector">
                                    @for (int i = 0; i <= 4; i++)
                                    {
                                        var count = i;
                                        <button type="button" class="cpu-btn @(_lobbyCpuCount == count ? "active" : "")" @onclick="async () => await SetLobbyCpuCount(count)">
                                            @(count == 0 ? "None" : $"{count}")
                                        </button>
                                    }
                                </div>
                            </div>
                            }

                            @if (_lobbyIsHost)
                            {
                                <div class="lobby-preset-switcher">
                                    <span class="lobby-preset-switcher-label">Game Rules</span>
                                    <div class="lobby-preset-switcher-row">
                                        @foreach (var preset in _presets)
                                        {
                                            var p = preset;
                                            <button class="lobby-preset-pill @(_selectedPreset.Name == p.Name ? "pill-active" : "")"
                                                    @onclick="async () => await LobbySelectPresetOrCustom(p)">
                                                @p.Name
                                            </button>
                                        }
                                    </div>
                                </div>

                                @if (_selectedPreset.Name == "Custom" && _lobbyCustomSettings != null)
                                {
                                    <div class="lobby-custom-rules-panel">
                                        <div class="lobby-custom-rules-title">⚙️ Custom Configuration</div>
                                        <div class="lobby-custom-rules-grid">
                                            <label class="lcr-toggle"><input type="checkbox" @bind="_lobbyCustomSettings.Stacking" /> Stacking</label>
                                            <label class="lcr-toggle"><input type="checkbox" @bind="_lobbyCustomSettings.DrawUntilPlayable" /> Draw Until Playable</label>
                                            <label class="lcr-toggle"><input type="checkbox" @bind="_lobbyCustomSettings.ForcedPlay" /> Forced Play</label>
                                            <label class="lcr-toggle"><input type="checkbox" @bind="_lobbyCustomSettings.EnableWildDraw4Challenge" /> WD4 Challenge</label>
                                            <label class="lcr-toggle"><input type="checkbox" @bind="_lobbyCustomSettings.SevenSwap" /> 7-Swap</label>
                                            <label class="lcr-toggle"><input type="checkbox" @bind="_lobbyCustomSettings.ZeroRotate" /> 0-Rotate</label>
                                            <label class="lcr-toggle"><input type="checkbox" @bind="_lobbyCustomSettings.JumpInRule" /> Jump-In</label>
                                            <label class="lcr-toggle"><input type="checkbox" @bind="_lobbyCustomSettings.EnableVortex" /> Vortex</label>
                                            <label class="lcr-toggle"><input type="checkbox" @bind="_lobbyCustomSettings.AfkEnabled" /> AFK Penalty</label>
                                        </div>
                                        <div class="lobby-custom-rules-sliders">
                                            <div class="lcr-slider-row">
                                                <span>Starting Hand: @_lobbyCustomSettings.StartingHandSize cards</span>
                                                <input type="range" min="3" max="12" @bind="_lobbyCustomSettings.StartingHandSize" @bind:event="oninput" />
                                            </div>
                                        </div>
                                        <button class="lobby-btn lobby-btn-apply-rules" @onclick="LobbyApplyCustomRules">✓ Apply Custom Rules</button>
                                    </div>
                                }
                            }

                            @if (_lobbyRules != null)
                            {
                                <div class="lobby-rules-panel">
                                    <div class="lobby-rules-header">
                                        <span class="lobby-rules-title">⚙️ Active Rules</span>
                                        <span class="lobby-rules-preset-badge">@_lobbyRules.PresetName</span>
                                    </div>
                                    <div class="lobby-rules-grid">
                                        <div class="lobby-rule-chip @(_lobbyRules.Stacking ? "chip-on" : "chip-off")">🔥 Stacking</div>
                                        <div class="lobby-rule-chip @(_lobbyRules.SevenSwap ? "chip-on" : "chip-off")">🃏 7-Swap</div>
                                        <div class="lobby-rule-chip @(_lobbyRules.ZeroRotate ? "chip-on" : "chip-off")">🔄 0-Rotate</div>
                                        <div class="lobby-rule-chip @(_lobbyRules.JumpInRule ? "chip-on" : "chip-off")">⚡ Jump-In</div>
                                        <div class="lobby-rule-chip @(_lobbyRules.EnableVortex ? "chip-on" : "chip-off")">🌀 Vortex</div>
                                        <div class="lobby-rule-chip @(_lobbyRules.DrawUntilPlayable ? "chip-on" : "chip-off")">📥 Draw Until Playable</div>
                                        <div class="lobby-rule-chip @(_lobbyRules.EnableWildDraw4Challenge ? "chip-on" : "chip-off")">⚔️ WD4 Challenge</div>
                                        <div class="lobby-rule-chip @(_lobbyRules.ForcedPlay ? "chip-on" : "chip-off")">🔒 Forced Play</div>
                                    </div>
                                    <div class="lobby-rules-meta">
                                        <span>🃏 Hand: @_lobbyRules.StartingHandSize cards</span>
                                        <span>🔔 UNO penalty: @_lobbyRules.UnoFailurePenaltyCards cards</span>
                                        <span>🤖 AI: @_lobbyRules.CpuDifficulty</span>
                                        <span>⏰ AFK penalty: @(_lobbyRules.AfkEnabled ? $"{_lobbyRules.AfkPenaltyCards} cards" : "Off")</span>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="lobby-rules-panel" style="opacity:0.4; text-align:center; font-size:0.85rem; color:rgba(255,255,255,0.5); padding:12px;">
                                    ⏳ Waiting for host to set rules…
                                </div>
                            }

                            @if (_lobbyIsHost)
                            {
                                @if (_lobbyPlayers.Count + _lobbyCpuCount < 2)
                                {
                                    <p class="lobby-waiting">Need at least 2 players total to start…</p>
                                }
                                else
                                {
                                    @if (_lobbyPlayers.Count > 1 && !AllGuestsReady())
                                    {
                                        <p class="lobby-waiting">⏳ Waiting for guests to ready up…</p>
                                    }
                                    <button class="lobby-btn lobby-btn-start"
                                            disabled="@(_lobbyPlayers.Count > 1 && !AllGuestsReady())"
                                            @onclick="LobbyStartGame">
                                        ▶ Start Game (@(_lobbyPlayers.Count + _lobbyCpuCount) players)
                                    </button>
                                }
                            }
                            else
                            {
                                <button class="lobby-btn @(_myReadyState ? "lobby-btn-ready-on" : "lobby-btn-ready-off")"
                                        @onclick="async () => await ToggleLobbyReady()">
                                    @(_myReadyState ? "✓ Ready!" : "Ready Up")
                                </button>
                                <p class="lobby-waiting">Waiting for <strong>@(_lobbyPlayers.Count > 0 ? _lobbyPlayers[0] : "host")</strong> to start the game…</p>
                            }

                            <button class="lobby-btn lobby-btn-leave" @onclick="LobbyLeaveRoom">Leave Room</button>
                        </div>

                        <!-- RIGHT: Chat -->
                        <div class="lobby-room-right">
                            <div class="lobby-room-chat-header">💬 Chat</div>
                            <div class="lobby-chat lobby-chat-side">
                                <div class="lobby-chat-messages lobby-chat-messages-side" id="lobbyChatMessages">
                                    @foreach (var (sender, msg, isMe) in _chatMessages)
                                    {
                                        <div class="lobby-chat-msg @(isMe ? "chat-me" : "")">
                                            @if (!isMe) { <span class="chat-sender">@sender</span> }
                                            <span class="chat-bubble">@msg</span>
                                        </div>
                                    }
                                    @if (_chatMessages.Count == 0)
                                    {
                                        <div class="lobby-chat-empty">No messages yet — say hi! 👋</div>
                                    }
                                </div>
                                <div class="lobby-chat-input-row">
                                    <input class="lobby-chat-input" type="text" placeholder="Message…"
                                           @bind="_chatInput" @bind:event="oninput"
                                           @onkeydown="LobbyChatKeyDown" maxlength="200" />
                                    <button class="lobby-chat-send" @onclick="LobbySendChat" disabled="@(string.IsNullOrWhiteSpace(_chatInput))">
                                        ➤
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- MODAL 1: Manage Rules -->
        @if (_showRulesModal && _editingPreset != null && _editingSettings != null)
        {
            <div class="modal-backdrop" @onclick="() => _showRulesModal = false">
                <div class="modal-card rules-modal" @onclick:stopPropagation>
                    <div class="modal-header">
                        <h2>⚙️ Manage Rules</h2>
                        <button class="close-btn" @onclick="() => _showRulesModal = false">×</button>
                    </div>

                    <!-- Preset Selector Section -->
                    <div class="presets-section">
                        <h3>Rule Presets</h3>
                        <div class="presets-row">
                            @foreach (var preset in _presets)
                            {
                                <div class="preset-card @(_editingPreset.Id == preset.Id ? "active" : "")" @onclick="() => SelectPreset(preset)">
                                    <div class="preset-card-body">
                                        @if (!preset.IsReadonly && preset.Name != "Chaos" && preset.Name != "Custom")
                                        {
                                            <input type="text" class="preset-rename-input" @bind="preset.Name" @onclick:stopPropagation />
                                            <button class="delete-preset-btn" @onclick="() => DeletePreset(preset)" @onclick:stopPropagation>🗑️</button>
                                        }
                                        else
                                        {
                                            <span class="preset-name">@preset.Name</span>
                                            @if (preset.IsReadonly)
                                            {
                                                <span class="readonly-badge">🔒 Locked</span>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                            <button class="add-preset-btn" @onclick="CreateCustomPreset">
                                <span>➕</span> New Preset
                            </button>
                        </div>
                    </div>

                    <!-- Rule Checkboxes Section -->
                    <div class="rules-section">
                        <div class="rules-section-header">
                            <h3>Configure Rules (@_editingPreset.Name)</h3>
                            @if (_editingPreset.IsReadonly)
                            {
                                <span class="rules-locked-banner">⚠️ @_editingPreset.Name rules are locked and cannot be edited. Create a New Preset to customize.</span>
                            }
                        </div>

                        @if (_editingPreset.Name == "Classic" || _editingPreset.Name == "Chaos")
                        {
                            <!-- Unified Read-Only Status Board for Locked System Presets -->
                            <div class="classic-guide-card" style="background: rgba(34, 197, 94, 0.05); border: 2px solid rgba(34, 197, 94, 0.2); border-radius: 16px; padding: 24px; display: flex; flex-direction: column; gap: 18px; margin-top: 10px;">
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    <span style="font-size: 2.5rem; line-height: 1;">🏆</span>
                                    <div>
                                        <h4 style="margin: 0; font-size: 1.3rem; font-weight: 900; color: #22c55e;">@_editingPreset.Name UNO Rules</h4>
                                        <span style="font-size: 0.85rem; color: #94a3b8; font-weight: 500;">
                                            @(_editingPreset.Name == "Classic" ? "The authentic, standard, out-of-the-box UNO experience." : "All current and future rule modifiers are fully unlocked and forced active!")
                                        </span>
                                    </div>
                                </div>
                                
                                <div style="border-top: 1px solid rgba(255, 255, 255, 0.08); padding-top: 18px; display: flex; flex-direction: column; gap: 12px;">
                                    @foreach (var rule in _ruleItems.Where(r => r.IsVisible(_editingSettings)))
                                    {
                                        var isChaos = _editingPreset.Name == "Chaos";
                                        
                                        <div class="rule-readonly-row" style="background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 12px; padding: 12px 18px; display: flex; justify-content: space-between; align-items: center; gap: 15px;">
                                            <div style="display: flex; gap: 12px; align-items: center;">
                                                <span style="font-size: 1.5rem; line-height: 1;">@rule.Icon</span>
                                                <div style="display: flex; flex-direction: column;">
                                                    <span style="font-weight: 700; color: #f1f5f9; font-size: 0.95rem;">@rule.Title</span>
                                                    <span style="font-size: 0.8rem; color: #64748b;">@rule.Description</span>
                                                </div>
                                            </div>
                                            
                                            <div class="rule-readonly-badge">
                                                @if (rule.Type == RuleType.Toggle)
                                                {
                                                    var isEnabled = isChaos || rule.GetBoolValue(_editingSettings);
                                                    @if (isEnabled)
                                                    {
                                                        <span class="passive-badge enabled" style="background: rgba(34, 197, 94, 0.15); color: #4ade80; border: 1px solid rgba(34, 197, 94, 0.3); padding: 6px 14px; border-radius: 20px; font-size: 0.8rem; font-weight: 800; text-transform: uppercase;">Enabled</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="passive-badge disabled" style="background: rgba(255, 255, 255, 0.05); color: #94a3b8; border: 1px solid rgba(255, 255, 255, 0.1); padding: 6px 14px; border-radius: 20px; font-size: 0.8rem; font-weight: 800; text-transform: uppercase;">Disabled</span>
                                                    }
                                                }
                                                else if (rule.Type == RuleType.Select)
                                                {
                                                    var value = rule.GetSelectValue(_editingSettings);
                                                    var label = rule.SelectOptions.FirstOrDefault(o => Equals(o.Value, value)).Label;
                                                    <span class="readonly-value-badge" style="color: @(isChaos ? "#f59e0b" : "#4ade80"); background: @(isChaos ? "rgba(245, 158, 11, 0.1)" : "rgba(34, 197, 94, 0.1)"); border: 1px solid @(isChaos ? "rgba(245, 158, 11, 0.2)" : "rgba(34, 197, 94, 0.2)"); padding: 6px 14px; border-radius: 8px; font-weight: 800; font-size: 0.9rem;">
                                                        @label
                                                    </span>
                                                }
                                                else
                                                {
                                                    var value = rule.GetNumberValue(_editingSettings);
                                                    <span class="readonly-value-badge" style="color: @(isChaos ? "#f59e0b" : "#4ade80"); background: @(isChaos ? "rgba(245, 158, 11, 0.1)" : "rgba(34, 197, 94, 0.1)"); border: 1px solid @(isChaos ? "rgba(245, 158, 11, 0.2)" : "rgba(34, 197, 94, 0.2)"); padding: 6px 14px; border-radius: 8px; font-weight: 800; font-size: 0.9rem;">
                                                        @(value.ToString(rule.Format)) @rule.Unit
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <!-- Starting Hand Size (Editable for Custom Presets) -->
                            <div class="hand-size-config">
                                <div class="hand-size-meta">
                                    <span class="rule-icon">🃏</span>
                                    <div class="rule-text">
                                        <span class="rule-title">Starting Hand Size</span>
                                        <span class="rule-desc">Cards dealt to each player at the match start (Clamped 3 to 10).</span>
                                    </div>
                                </div>
                                <div class="hand-size-control">
                                    <span class="hand-size-val">@_editingSettings.StartingHandSize Cards</span>
                                    <input type="range" min="3" max="10" step="1" 
                                           value="@_editingSettings.StartingHandSize" 
                                           @onchange="UpdateStartingHandSize" />
                                </div>
                            </div>

                            <!-- Core Rules Grid -->
                            <div class="rules-grid">
                                <!-- Stacking -->
            <div class="rule-card @(_editingSettings.Stacking ? "active" : "")">
                <div class="rule-meta">
                    <span class="rule-icon">🔥</span>
                    <div class="rule-text">
                        <span class="rule-title">Stacking (+2 / +4)</span>
                        <span class="rule-desc">Stack draw penalty cards to pass the accumulated total downstream.</span>
                    </div>
                </div>
                <div class="rule-control">
                    <label class="switch">
                        <input type="checkbox" checked="@_editingSettings.Stacking" 
                               @onchange="(e) => ToggleRule(val => _editingSettings.Stacking = val, e)" />
                        <span class="slider"></span>
                    </label>
                </div>
            </div>

                                <!-- Draw Until Playable -->
            <div class="rule-card @(_editingSettings.DrawUntilPlayable ? "active" : "")">
                <div class="rule-meta">
                    <span class="rule-icon stacked-cards">
                        <span class="card-1">🃏</span>
                        <span class="card-2">🎴</span>
                        <span class="card-3">🃏</span>
                    </span>
                    <div class="rule-text">
                        <span class="rule-title">Draw Until Playable</span>
                        <span class="rule-desc">Must draw continuous cards until a playable card is pulled. (Auto-enables Forced Play)</span>
                    </div>
                </div>
                <div class="rule-control">
                    <label class="switch">
                        <input type="checkbox" checked="@_editingSettings.DrawUntilPlayable" 
                               @onchange="ToggleDrawUntilPlayable" />
                        <span class="slider"></span>
                    </label>
                </div>
            </div>
                            </div>

                            <!-- Conditional Advanced Options Section -->
                            <div class="advanced-options-container">
                                <h4>🛠️ Advanced Options</h4>
                                <div class="rules-grid">
                                    <!-- Forced Play -->
                                    <div class="rule-card @(_editingSettings.ForcedPlay ? "active" : "")">
                                        <div class="rule-meta">
                                            <span class="rule-icon">🔒</span>
                                            <div class="rule-text">
                                                <span class="rule-title">Forced Play</span>
                                                <span class="rule-desc">Players MUST play a card if they have a match in hand (disables reneging/drawing). Auto-enabled by Draw Until Playable.</span>
                                            </div>
                                        </div>
                                        <div class="rule-control">
                                            <label class="switch">
                                                <input type="checkbox" checked="@_editingSettings.ForcedPlay" 
                                                       @onchange="(e) => ToggleForcedPlay(e)" />
                                                <span class="slider"></span>
                                            </label>
                                        </div>
                                    </div>


                                    <!-- Wild Draw 4 Challenge -->
                                    <div class="wd4-section">
                                        <div class="rule-card @(_editingSettings.EnableWildDraw4Challenge ? "active" : "")">
                                            <div class="rule-meta">
                                                <span class="rule-icon">⚔️</span>
                                                <div class="rule-text">
                                                    <span class="rule-title">Wild Draw 4 Challenge</span>
                                                    <span class="rule-desc">Targets can challenge played +4s for illegal matching color.</span>
                                                </div>
                                            </div>
                                            <div class="rule-control">
                                                <label class="switch">
                                                    <input type="checkbox" checked="@_editingSettings.EnableWildDraw4Challenge" 
                                                           @onchange="(e) => ToggleRule(val => _editingSettings.EnableWildDraw4Challenge = val, e)" />
                                                    <span class="slider"></span>
                                                </label>
                                            </div>
                                        </div>
                                        @if (_editingSettings.EnableWildDraw4Challenge)
                                        {
                                            <div class="hand-size-config uno-penalty-config">
                                                <div class="hand-size-meta">
                                                    <span class="rule-icon">📥</span>
                                                    <div class="rule-text">
                                                        <span class="rule-title">Wrong Challenge Penalty</span>
                                                        <span class="rule-desc">Cards drawn by challenger when WD4 bluff is NOT confirmed.</span>
                                                    </div>
                                                </div>
                                                <div class="hand-size-control">
                                                    <span class="hand-size-val">@_editingSettings.Wd4WrongChallengePenalty Cards</span>
                                                    <input type="range" min="6" max="10" step="1"
                                                           value="@_editingSettings.Wd4WrongChallengePenalty"
                                                           @onchange="UpdateWd4WrongPenalty" />
                                                </div>
                                            </div>
                                        }
                                    </div>

                                    <!-- 7-Swap -->
                                    <div class="rule-card @(_editingSettings.SevenSwap ? "active" : "")">
                                        <div class="rule-meta">
                                            <span class="rule-icon">🃏</span>
                                            <div class="rule-text">
                                                <span class="rule-title">7-Swap</span>
                                                <span class="rule-desc">Forces hand-swaps with another player when a 7 is played.</span>
                                            </div>
                                        </div>
                                        <div class="rule-control">
                                            <label class="switch">
                                                <input type="checkbox" checked="@_editingSettings.SevenSwap" 
                                                       @onchange="(e) => ToggleRule(val => _editingSettings.SevenSwap = val, e)" />
                                                <span class="slider"></span>
                                            </label>
                                        </div>
                                    </div>

                                    <!-- Zero Rotate -->
                                    <div class="rule-card @(_editingSettings.ZeroRotate ? "active" : "")">
                                        <div class="rule-meta">
                                            <span class="rule-icon">🔄</span>
                                            <div class="rule-text">
                                                <span class="rule-title">Zero Rotate</span>
                                                <span class="rule-desc">Rotates everyone's hands along direction of play on a 0.</span>
                                            </div>
                                        </div>
                                        <div class="rule-control">
                                            <label class="switch">
                                                <input type="checkbox" checked="@_editingSettings.ZeroRotate" 
                                                       @onchange="(e) => ToggleRule(val => _editingSettings.ZeroRotate = val, e)" />
                                                <span class="slider"></span>
                                            </label>
                                        </div>
                                    </div>

                                    <!-- Jump-In -->
                                    <div class="rule-card @(_editingSettings.JumpInRule ? "active" : "")">
                                        <div class="rule-meta">
                                            <span class="rule-icon">⚡</span>
                                            <div class="rule-text">
                                                <span class="rule-title">Jump-In Rule</span>
                                                <span class="rule-desc">Play out of turn if you hold an exact color AND value duplicate match.</span>
                                            </div>
                                        </div>
                                        <div class="rule-control">
                                            <label class="switch">
                                                <input type="checkbox" checked="@_editingSettings.JumpInRule" 
                                                       @onchange="(e) => ToggleRule(val => _editingSettings.JumpInRule = val, e)" />
                                                <span class="slider"></span>
                                            </label>
                                        </div>
                                    </div>

                                    <!-- Jump-In UI Glow -->
                                    @if (_editingSettings.JumpInRule)
                                    {
                                        <div class="rule-card @(_editingSettings.ShowJumpInGlow ? "active" : "")">
                                            <div class="rule-meta">
                                                <span class="rule-icon">✨</span>
                                                <div class="rule-text">
                                                    <span class="rule-title">Jump-In UI Glow</span>
                                                    <span class="rule-desc">Adds a red glowing border to cards that can be jumped in.</span>
                                                </div>
                                            </div>
                                            <div class="rule-control">
                                                <label class="switch">
                                                    <input type="checkbox" checked="@_editingSettings.ShowJumpInGlow" 
                                                           @onchange="(e) => ToggleRule(val => _editingSettings.ShowJumpInGlow = val, e)" />
                                                    <span class="slider"></span>
                                                </label>
                                            </div>
                                        </div>
                                    }

                                    <!-- Vortex -->
                                    <div class="rule-card @(_editingSettings.EnableVortex ? "active" : "")">
                                        <div class="rule-meta">
                                            <span class="rule-icon">🌀</span>
                                            <div class="rule-text">
                                                <span class="rule-title">Vortex</span>
                                                <span class="rule-desc">Adds 4 Vortex cards to pool and redistribute everyone's hand.</span>
                                            </div>
                                        </div>
                                        <div class="rule-control">
                                            <label class="switch">
                                                <input type="checkbox" checked="@_editingSettings.EnableVortex" 
                                                       @onchange="(e) => ToggleRule(val => _editingSettings.EnableVortex = val, e)" />
                                                <span class="slider"></span>
                                            </label>
                                        </div>
                                    </div>

                                    <!-- AI Difficulty -->
                                    <div class="rule-card">
                                        <div class="rule-meta">
                                            <span class="rule-icon">🤖</span>
                                            <div class="rule-text">
                                                <span class="rule-title">AI Difficulty</span>
                                                <span class="rule-desc">How smart the computer opponents are.</span>
                                            </div>
                                        </div>
                                        <div class="rule-control">
                                            <select class="rule-select" value="@_editingSettings.CpuDifficulty" 
                                                    @onchange="(e) => _editingSettings.CpuDifficulty = Enum.Parse<AiDifficulty>(e.Value?.ToString() ?? AiDifficulty.Normal.ToString())">
                                                <option value="@AiDifficulty.Easy">Easy</option>
                                                <option value="@AiDifficulty.Normal">Normal</option>
                                                <option value="@AiDifficulty.Hard">Hard</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <!-- Uno Call Penalty Sliders -->
                                <div class="hand-size-config uno-penalty-config">
                                    <div class="hand-size-meta">
                                        <span class="rule-icon">🔔</span>
                                        <div class="rule-text">
                                            <span class="rule-title">Uno Call Failure Penalty</span>
                                            <span class="rule-desc">Cards drawn if caught failing to call UNO (Clamped 1 to 5).</span>
                                        </div>
                                    </div>
                                    <div class="hand-size-control">
                                        <span class="hand-size-val">@_editingSettings.UnoFailurePenaltyCards Cards</span>
                                        <input type="range" min="1" max="5" step="1" 
                                               value="@_editingSettings.UnoFailurePenaltyCards" 
                                               @onchange="UpdateUnoPenaltyCards" />
                                    </div>
                                </div>

                                <!-- QTE Timer (Only shown if Jump-In is active) -->
                                @if (_editingSettings.JumpInRule)
                                {
                                    <div class="timer-config-card">
                                        <div class="timer-meta">
                                            <span class="rule-icon">⏱️</span>
                                            <div class="rule-text">
                                                <span class="rule-title">Jump-In QTE Timer</span>
                                                <span class="rule-desc">Speed window (seconds) to intercept duplicates out of turn.</span>
                                            </div>
                                        </div>
                                        <div class="timer-slider-control">
                                            <span class="timer-val">@_editingSettings.JumpInTimerSeconds.ToString("0.0")s</span>
                                            <input type="range" min="1.0" max="5.0" step="0.5" 
                                                   value="@_editingSettings.JumpInTimerSeconds" 
                                                   @onchange="UpdateTimer" />
                                        </div>
                                    </div>
                                }

                                <!-- AFK Penalty -->
            <div class="rule-card @(_editingSettings.AfkEnabled ? "active" : "")">
                <div class="rule-meta">
                    <span class="rule-icon">⏰</span>
                    <div class="rule-text">
                        <span class="rule-title">AFK Penalty</span>
                        <span class="rule-desc">Auto-draw cards if a human player idles too long.</span>
                    </div>
                </div>
                <div class="rule-control">
                    <label class="switch">
                        <input type="checkbox" checked="@_editingSettings.AfkEnabled"
                               @onchange="e => _editingSettings.AfkEnabled = (bool)(e.Value ?? false)" />
                        <span class="slider"></span>
                    </label>
                </div>
            </div>
                                @if (_editingSettings.AfkEnabled)
                                {
                                    <div class="timer-config-card">
                                        <div class="timer-meta">
                                            <span class="rule-icon">⏳</span>
                                            <div class="rule-text">
                                                <span class="rule-title">AFK Timeout</span>
                                                <span class="rule-desc">Seconds before AFK penalty triggers.</span>
                                            </div>
                                        </div>
                                        <div class="timer-slider-control">
                                            <span class="timer-val">@_editingSettings.AfkTimeoutSeconds s</span>
                                            <input type="range" min="5" max="60" step="5"
                                                   value="@_editingSettings.AfkTimeoutSeconds"
                                                   @onchange="e => _editingSettings.AfkTimeoutSeconds = int.Parse(e.Value!.ToString()!)" />
                                        </div>
                                    </div>
                                    <div class="timer-config-card">
                                        <div class="timer-meta">
                                            <span class="rule-icon">🃏</span>
                                            <div class="rule-text">
                                                <span class="rule-title">AFK Penalty Cards</span>
                                                <span class="rule-desc">Cards drawn as punishment for going AFK.</span>
                                            </div>
                                        </div>
                                        <div class="timer-slider-control">
                                            <span class="timer-val">@_editingSettings.AfkPenaltyCards</span>
                                            <input type="range" min="1" max="10" step="1"
                                                   value="@_editingSettings.AfkPenaltyCards"
                                                   @onchange="e => _editingSettings.AfkPenaltyCards = int.Parse(e.Value!.ToString()!)" />
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="modal-footer">
                        <button class="confirm-rules-btn" @onclick="SaveAndApplyRules">Save & Apply</button>
                    </div>
                </div>
            </div>
        }

        <!-- MODAL: Leaderboard -->
        @if (_showLeaderboard)
        {
            <div class="modal-backdrop" @onclick="() => _showLeaderboard = false">
                <div class="modal-card leaderboard-modal" @onclick:stopPropagation>
                    <div class="modal-header">
                        <h2>🏆 Session Leaderboard</h2>
                        <button class="close-btn" @onclick="() => _showLeaderboard = false">×</button>
                    </div>
                    <div class="leaderboard-body">
                        <table class="lb-table">
                            <thead>
                                <tr><th>#</th><th>Player</th><th>W</th><th>L</th><th>Games</th><th>Last Played</th></tr>
                            </thead>
                            <tbody>
                                @for (int ri = 0; ri < _leaderboard.Count; ri++)
                                {
                                    var e = _leaderboard[ri];
                                    int rank = ri + 1;
                                    <tr class="@(rank == 1 ? "lb-top" : "")">
                                        <td>@(rank == 1 ? "🥇" : rank == 2 ? "🥈" : rank == 3 ? "🥉" : rank.ToString())</td>
                                        <td>@e.Name</td>
                                        <td class="lb-win">@e.Wins</td>
                                        <td class="lb-lose">@e.Losses</td>
                                        <td>@e.GamesPlayed</td>
                                        <td class="lb-date">@e.LastPlayed.ToString("HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- MODAL 2: Rule Book -->
        @if (_showRuleBookModal)
        {
            <div class="modal-backdrop" @onclick="() => _showRuleBookModal = false">
                <div class="modal-card rulebook-modal" @onclick:stopPropagation>
                    <div class="modal-header">
                        <h2>📖 Rule Book</h2>
                        <button class="close-btn" @onclick="() => _showRuleBookModal = false">×</button>
                    </div>

                    <div class="rulebook-layout">
                        <div class="rulebook-sidebar">
                            <button class="sidebar-tab @(_activeTab == "general" ? "active" : "")" @onclick='() => _activeTab = "general"'>🎮 Basics</button>
                            <button class="sidebar-tab @(_activeTab == "cards" ? "active" : "")" @onclick='() => _activeTab = "cards"'>🃏 Cards Guide</button>
                            <button class="sidebar-tab @(_activeTab == "uno" ? "active" : "")" @onclick='() => _activeTab = "uno"'>📣 UNO &amp; Scoring</button>
                            <button class="sidebar-tab @(_activeTab == "house" ? "active" : "")" @onclick='() => _activeTab = "house"'>⚙️ Standard Rules</button>
                            <button class="sidebar-tab @(_activeTab == "chaos" ? "active" : "")" @onclick='() => _activeTab = "chaos"'>💥 House Rules</button>
                        </div>

                        <div class="rulebook-content">

                            @if (_activeTab == "general")
                            {
                                <div class="tab-pane">
                                    <h3>Basics</h3>

                                    <div class="rb-section">
                                        <h4>🎯 Objective</h4>
                                        <p>Be the first player to empty your hand. Shout <strong>UNO</strong> when you're down to one card — or get penalized for forgetting.</p>
                                    </div>

                                    <div class="rb-section">
                                        <h4>🃏 Setup</h4>
                                        <ul>
                                            <li>Each player is dealt <strong>7 cards</strong> to start (configurable from 3–10 in rules).</li>
                                            <li>The remaining cards form the <strong>Draw Pile</strong>.</li>
                                            <li>One card is flipped to start the <strong>Discard Pile</strong>. If it's a Wild Draw 4, it's returned and a new card is drawn instead.</li>
                                            <li>If an Action card is flipped as the starting card, its effect applies immediately to the first player.</li>
                                        </ul>
                                    </div>

                                    <div class="rb-section">
                                        <h4>🔄 Turn Flow</h4>
                                        <ul>
                                            <li><strong>Play a card</strong> — match the top discard by color, number, or symbol.</li>
                                            <li><strong>Draw a card</strong> — if you have no legal play (or choose to renege). If the drawn card is playable, you may play it immediately.</li>
                                            <li><strong>Pass</strong> — if the drawn card is not playable, your turn ends automatically.</li>
                                        </ul>
                                    </div>

                                    <div class="rb-section">
                                        <h4>♾️ Draw Pile</h4>
                                        <p>The draw pile is <strong>infinite</strong>. When it runs out, the discard pile is reshuffled back in. If even the discard pile is empty, a fresh deck is injected automatically — the game never stops.</p>
                                    </div>

                                    <div class="rb-section">
                                        <h4>🔁 Multi-Round Play</h4>
                                        <p>When a round ends, the winner earns points from opponents' leftover cards. Scores accumulate across rounds. Hit <strong>Next Round</strong> on the game-over screen to replay with the same players while keeping total scores.</p>
                                    </div>
                                </div>
                            }
                            else if (_activeTab == "cards")
                            {
                                <div class="tab-pane">
                                    <h3>Cards Guide</h3>
                                    <p class="rb-intro">Match the top discard by <strong>color</strong>, <strong>number</strong>, or <strong>symbol</strong>. Wild cards can always be played.</p>

                                    <div class="rb-card-row">
                                        <UnoCardView Color="CardColor.Red" Value="CardValue.Zero" SizeClass="w-16 h-24" />
                                        <div class="rb-card-info">
                                            <strong>Number Cards (0–9)</strong>
                                            <p>Standard cards. Match by color or number. Worth their face value in scoring.</p>
                                        </div>
                                    </div>

                                    <div class="rb-card-row">
                                        <UnoCardView Color="CardColor.Red" Value="CardValue.Skip" SizeClass="w-16 h-24" />
                                        <div class="rb-card-info">
                                            <strong>Skip</strong>
                                            <span class="rb-badge rb-badge-red">20 pts</span>
                                            <p>The next player loses their turn entirely. In a 2-player game, you get another turn.</p>
                                        </div>
                                    </div>

                                    <div class="rb-card-row">
                                        <UnoCardView Color="CardColor.Blue" Value="CardValue.Reverse" SizeClass="w-16 h-24" />
                                        <div class="rb-card-info">
                                            <strong>Reverse</strong>
                                            <span class="rb-badge rb-badge-blue">20 pts</span>
                                            <p>Flips the direction of play (clockwise ↔ counter-clockwise). Acts as a Skip in a 2-player game.</p>
                                        </div>
                                    </div>

                                    <div class="rb-card-row">
                                        <UnoCardView Color="CardColor.Green" Value="CardValue.Draw2" SizeClass="w-16 h-24" />
                                        <div class="rb-card-info">
                                            <strong>Draw Two (+2)</strong>
                                            <span class="rb-badge rb-badge-green">20 pts</span>
                                            <p>The next player draws 2 cards and skips their turn. Can be stacked if the Stacking rule is enabled.</p>
                                        </div>
                                    </div>

                                    <div class="rb-card-row">
                                        <UnoCardView Color="CardColor.Wild" Value="CardValue.Wild" SizeClass="w-16 h-24" />
                                        <div class="rb-card-info">
                                            <strong>Wild</strong>
                                            <span class="rb-badge rb-badge-wild">50 pts</span>
                                            <p>Playable on any card. You choose the new active color for the next player to follow.</p>
                                        </div>
                                    </div>

                                    <div class="rb-card-row">
                                        <UnoCardView Color="CardColor.Wild" Value="CardValue.WildDraw4" SizeClass="w-16 h-24" />
                                        <div class="rb-card-info">
                                            <strong>Wild Draw Four (+4)</strong>
                                            <span class="rb-badge rb-badge-wild">50 pts</span>
                                            <p><strong>Legal only</strong> when you have no cards matching the current active color. You choose the new color; the next player draws 4 and loses their turn. Can be challenged — see Standard Rules.</p>
                                        </div>
                                    </div>

                                    <div class="rb-card-row rb-vortex-row">
                                        <UnoCardView Color="CardColor.Wild" Value="CardValue.Vortex" SizeClass="w-16 h-24" />
                                        <div class="rb-card-info">
                                            <strong>Vortex</strong>
                                            <span class="rb-badge rb-badge-purple">House Rule</span>
                                            <p>Collects every card from all players' hands, shuffles the pool, and redistributes evenly. Remainder cards go clockwise from the active player. The active color does <strong>not</strong> change. Enabled via the Vortex house rule.</p>
                                        </div>
                                    </div>
                                </div>
                            }
                            else if (_activeTab == "uno")
                            {
                                <div class="tab-pane">
                                    <h3>UNO &amp; Scoring</h3>

                                    <div class="rb-section">
                                        <h4>📣 Calling UNO</h4>
                                        <p>When you play down to <strong>one card</strong>, you must call UNO before the card leaves your hand. Use the <strong>UNO button</strong> that appears — or tap it proactively before playing your second-to-last card.</p>
                                        <div class="rb-info-box rb-info-warn">
                                            <strong>Caught!</strong> If an opponent presses <em>Catch</em> before the next turn starts and you haven't called UNO, you draw penalty cards (configurable, default 2).
                                        </div>
                                    </div>

                                    <div class="rb-section">
                                        <h4>⚡ In-Game Action Bonuses</h4>
                                        <p>Playing certain cards earns you instant points <em>added immediately</em> to your score — no need to wait until the round ends.</p>
                                        <table class="rb-score-table">
                                            <thead><tr><th>Card played</th><th>Instant bonus</th></tr></thead>
                                            <tbody>
                                                <tr><td>Skip</td><td>+5 pts</td></tr>
                                                <tr><td>Reverse</td><td>+5 pts</td></tr>
                                                <tr><td>Draw Two</td><td>+10 pts</td></tr>
                                                <tr><td>Wild</td><td>+15 pts</td></tr>
                                                <tr><td>Wild Draw Four</td><td>+20 pts</td></tr>
                                                <tr><td>Vortex</td><td>+20 pts</td></tr>
                                            </tbody>
                                        </table>
                                    </div>

                                    <div class="rb-section">
                                        <h4>🏆 Round-End Scoring</h4>
                                        <p><strong>Every player</strong> — winner and losers alike — earns points at the end of a round based on how few cards they have left. Fewer cards = bigger reward.</p>
