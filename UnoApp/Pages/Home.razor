            Settings = new GameSettings
            {
                StartingHandSize = 7,
                Stacking = true,
                DrawUntilPlayable = true,
                ForcedPlay = false,
                EnableWildDraw4Challenge = false,
                SevenSwap = true,
                ZeroRotate = true,
                JumpInRule = true,
                JumpInTimerSeconds = 2.5,
                EnableVortex = false,
                UnoFailurePenaltyCards = 2
            }
        };

        _presets.Add(classicPreset);
        _presets.Add(chaosPreset);
        _presets.Add(customPreset);

        // Set default preset
        _selectedPreset = classicPreset;
    }

    private void OpenRulesModal()
    {
        _editingPreset = _selectedPreset;
        _editingSettings = _selectedPreset.Settings.Clone();
        _showRulesModal = true;
    }

    private void SaveAndApplyRules()
    {
        if (_editingPreset != null && _editingSettings != null)
        {
            _editingPreset.Settings = _editingSettings;
            _selectedPreset = _editingPreset;
        }
        _showRulesModal = false;
    }

    private void SelectPreset(RulePresetProfile preset)
    {
        _editingPreset = preset;
        _editingSettings = preset.Settings.Clone();
    }

    private void CreateCustomPreset()
    {
        var newPreset = new RulePresetProfile
        {
            Name = $"Preset {_presets.Count - 1}",
            IsReadonly = false,
            Settings = (_editingSettings ?? _selectedPreset.Settings).Clone() // Clones currently selected start settings
        };
        _presets.Add(newPreset);
        _editingPreset = newPreset;
        _editingSettings = newPreset.Settings.Clone();
    }

    private void DeletePreset(RulePresetProfile preset)
    {
        if (preset.IsReadonly || preset.Name == "Chaos" || preset.Name == "Custom") return;
        
        _presets.Remove(preset);
        if (_editingPreset == preset)
        {
            _editingPreset = _presets.First(p => p.Name == "Classic");
            _editingSettings = _editingPreset.Settings.Clone();
        }
        if (_selectedPreset == preset)
        {
            _selectedPreset = _presets.First(p => p.Name == "Classic");
        }
    }

    private void ToggleRule(Action<bool> setter, ChangeEventArgs e)
    {
        if (_editingPreset?.IsReadonly == true) return;

        if (e.Value is bool val)
        {
            setter(val);
        }
    }

    private void ToggleForcedPlay(ChangeEventArgs e)
    {
        if (_editingPreset?.IsReadonly == true) return;

        if (e.Value is bool val)
        {
            _editingSettings.ForcedPlay = val;
        }
    }

    private void UpdateStartingHandSize(ChangeEventArgs e)
    {
        if (_editingPreset?.IsReadonly == true || _editingSettings == null) return;
        if (int.TryParse(e.Value?.ToString(), out var val))
        {
            _editingSettings.StartingHandSize = Math.Clamp(val, 3, 10);
        }
    }

    private void UpdateUnoPenaltyCards(ChangeEventArgs e)
    {
        if (_editingPreset?.IsReadonly == true || _editingSettings == null) return;
        if (int.TryParse(e.Value?.ToString(), out var val))
        {
            _editingSettings.UnoFailurePenaltyCards = Math.Clamp(val, 1, 5);
        }
    }

    private void UpdateTimer(ChangeEventArgs e)
    {
        if (_editingPreset?.IsReadonly == true || _editingSettings == null) return;

        if (double.TryParse(e.Value?.ToString(), out var seconds))
        {
            _editingSettings.JumpInTimerSeconds = seconds;
        }
    }

    private async Task StartMatch()
    {
        var players = new List<Player>
        {
            new Player { Id = Guid.NewGuid(), Name = string.IsNullOrWhiteSpace(_playerName) ? "PLAYER" : _playerName.ToUpper(), IsHuman = true }
        };

        for (int i = 1; i < _playerCount; i++)
        {
            players.Add(new Player { Id = Guid.NewGuid(), Name = $"CPU {i}", IsHuman = false });
        }

        // Pass the settings of the active selected preset directly to the game session!
        _game = new UnoGame(players, _selectedPreset.Settings);
        _game.OnStateChanged += () => InvokeAsync(StateHasChanged);
        
        _isGameStarted = true;
        await _game.StartTurnAsync();
    }

    private void ResetGame()
    {
        _isGameStarted = false;
        _game = null;
    }
}
