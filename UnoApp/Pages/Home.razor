    private async Task StartMultiplayerGame()
    {
        var humanNames = LobbyService.AllPlayerNames;
        int cpuCount = LobbyService.CpuCount;

        var players = new List<Player>();
        for (int i = 0; i < humanNames.Length; i++)
        {
            players.Add(new Player
            {
                Id = Guid.NewGuid(),
                Name = humanNames[i],
                IsHuman = true
            });
        }
        for (int i = 0; i < cpuCount; i++)
        {
            players.Add(new Player
            {
                Id = Guid.NewGuid(),
                Name = $"CPU {i + 1}",
                IsHuman = false
            });
        }

        _game = new UnoGame(players, _selectedPreset.Settings);

        for (int i = 1; i < humanNames.Length; i++)
            _game.RemotePlayerIndices.Add(i);

        _game.GetRemoteHumanMove = GetRemoteMoveAsync;
        _leaderboardUpdated = false;
        _game.OnBoardAnimation += async (anim) =>
        {
            _pendingAnimTrigger = anim;
            if (_gameViewRef != null) await _gameViewRef.TriggerAnimation(anim);
            await BroadcastStateAsync();
            _pendingAnimTrigger = "";
        };
        _game.OnStateChanged += async () =>
        {
            ManageAfkTimer();
            if (_game.Status == GameStatus.GameOver && !_leaderboardUpdated)
            {
                UpdateLeaderboard();
                _leaderboardUpdated = true;
            }
            _spState = BuildStateForPlayer(0);
            await BroadcastStateAsync();
            await InvokeAsync(StateHasChanged);
        };

        LobbyService.MoveReceived += OnRemoteMoveReceived;

        _isMultiplayerHost = true;
        _isGameStarted = true;

        await _game.DealStartingCardsAsync();
        _spState = BuildStateForPlayer(0);
        await BroadcastStateAsync();
        await _game.StartTurnAsync();
    }

    private async void OnRemoteMoveReceived(string json)
    {
        try
        {
            var move = JsonSerializer.Deserialize<MoveDto>(json, _mpJsonOpts);
            if (move != null)
            {
                if (_pendingRemoteMoves.TryGetValue(move.PlayerIndex, out var tcs))
                {
                    _pendingRemoteMoves.Remove(move.PlayerIndex);
                    tcs.TrySetResult(move);
                }
                else if (_isMultiplayerHost && _game != null)
                {
                    // If not waiting for a specific move, just apply it directly!
                    await _game.ApplyRemoteMoveAsync(move);
                }
            }
        }
        catch { }
    }

    private async Task<MoveDto?> GetRemoteMoveAsync(int playerIndex)
    {
        var tcs = new TaskCompletionSource<MoveDto?>();
        _pendingRemoteMoves[playerIndex] = tcs;
        await BroadcastStateAsync();
        return await tcs.Task;
    }

    private async Task BroadcastStateAsync()
    {
        if (_game == null || !_isMultiplayerHost) return;
        int humanCount = LobbyService.AllPlayerNames.Length;
        for (int i = 1; i < humanCount; i++)
        {
            try
            {
                var dto = BuildStateForPlayer(i);
                var json = JsonSerializer.Serialize(dto);
                await LobbyService.SendStateToPlayerAsync(i, json);
            }
            catch { }
        }
    }

    // Returns the apparent CW/CCW direction for a player given their seat.
    // Each seat sees the table from a different angle, so the same game direction
    // may appear clockwise or counterclockwise depending on who you are.
    // We compute a signed area (shoelace) of the flow polygon to determine orientation.
    private static int GetApparentDirection(int myIndex, int n, int gameDirection)
    {
        if (n <= 2) return gameDirection;
        int total = n - 1;
        var pts = new List<(double x, double y)> { (50.0, 85.0) }; // self at bottom
        for (int k = 1; k < n; k++)
        {
            int pi = (myIndex + k) % n;
            int j  = pi < myIndex ? pi : pi - 1; // visual slot index
            pts.Add(GetPositionForSlot(j, total));
        }
        double area = 0;
        for (int i = 0; i < pts.Count; i++)
        {
            var (x1, y1) = pts[i];
            var (x2, y2) = pts[(i + 1) % pts.Count];
            area += x1 * y2 - x2 * y1;
        }
        // Screen coords: positive signed area = clockwise.
        // Host (index 0) always has positive area → direction unchanged.
        // Guests with negative area see opposite spin → flip.
        return area >= 0 ? gameDirection : -gameDirection;
    }

    private static (double x, double y) GetPositionForSlot(int j, int total)
    {
        if (total == 1) return (50, 15);
        if (total == 2) return j == 0 ? (10, 45) : (90, 45);
        if (total == 3) { if (j == 0) return (10, 45); if (j == 1) return (50, 15); return (90, 45); }
        if (total == 4) { if (j == 0) return (10, 45); if (j == 1) return (35, 15); if (j == 2) return (65, 15); return (90, 45); }
        if (j == 0) return (10, 45); if (j == 1) return (25, 15); if (j == 2) return (50, 15); if (j == 3) return (75, 15); return (90, 45);
    }

    private GameStateDto BuildStateForPlayer(int playerIndex)
    {
        var game = _game!;
        var player = game.Players[playerIndex];
        var topCard = game.TopCard;

        bool isMyTurn = 
            game.CurrentPlayerIndex == playerIndex || 
            (game.Status == GameStatus.WaitingForWd4Challenge && game.Wd4ChallengerIndex == playerIndex) ||
            (game.Status == GameStatus.WaitingForColorSelection && game.PendingColorSelector == player) ||
            (game.Status == GameStatus.WaitingForSwapTarget && game.CurrentPlayerIndex == playerIndex);

        return new GameStateDto
        {
            CurrentPlayerIndex   = game.CurrentPlayerIndex,
            TopCard              = topCard != null ? new CardDto { Id = topCard.Id.ToString(), Color = topCard.Color.ToString(), Value = topCard.Value.ToString(), RotationAngle = topCard.RotationAngle } : null,
            ActiveColor          = game.LastValidColor.ToString(),
            HandCounts           = game.Players.Select(p => p.Hand.Count).ToArray(),
            PlayerNames          = game.Players.Select(p => p.Name).ToArray(),
            MyHand               = player.Hand.Select(c => new CardDto { Id = c.Id.ToString(), Color = c.Color.ToString(), Value = c.Value.ToString(), IsPlayable = game.CurrentPlayerIndex == playerIndex && game.Status == GameStatus.Playing && game.CanPlayCard(c), RotationAngle = c.RotationAngle }).ToList(),
            IsMyTurn             = isMyTurn,
            Status               = game.Status.ToString(),
            Direction            = GetApparentDirection(playerIndex, game.Players.Count, game.GameDirection),
            IsGameOver           = game.Status == GameStatus.GameOver,
            WinnerIndex          = game.Winner != null ? game.Players.IndexOf(game.Winner) : null,
            PendingDraw          = game.PendingDrawCount,
            NotificationBanner   = game.ActiveNotificationBanner,
            Wd4ChallengerIndex   = game.Wd4ChallengerIndex,
            MatchTimestamp       = game.MatchTimestamp?.ToString("o") ?? "",
            TotalScores          = game.Players.Select(p => p.TotalScore).ToArray(),
            RoundScores          = game.Players.Select(p => p.RoundScore).ToArray(),
            PlayerStatuses       = game.Players.Select(p => p.CurrentStatus).ToArray(),
            DiscardHistory       = game.DiscardHistory.Select(c => new CardDto { Id = c.Id.ToString(), Color = c.Color.ToString(), Value = c.Value.ToString(), RotationAngle = c.RotationAngle }).ToList(),
            GameLog              = game.GameLog.TakeLast(60).ToList(),
            AnimationTrigger     = _pendingAnimTrigger,
            DrawnCardId          = playerIndex == 0 ? _spDrawnCardId : (_game.RemoteDrawnCardIds.TryGetValue(playerIndex, out var rdc) ? rdc : null),
            RoundNumber          = game.RoundNumber,
            LastPlayerIndex      = game.LastPlayerIndex,
            CanCallUno           = (game.CurrentPlayerIndex == playerIndex && game.Players[playerIndex].Hand.Count == 2 && !game.IsUnoCalled && game.Status == GameStatus.Playing) || (game.Status == GameStatus.WaitingForUnoCall && game.PlayerAtRisk == game.Players[playerIndex]),
            CanCatchUno          = game.Status == GameStatus.WaitingForUnoCall && game.PlayerAtRisk != null && game.PlayerAtRisk != game.Players[playerIndex],
            JumpInTimerSeconds   = game.Settings.JumpInTimerSeconds,
            ForcedPlay           = game.Settings.ForcedPlay,
            Wd4BluffCards        = game.Wd4BluffRevealCards?.Select(c => new CardDto { Id = c.Id.ToString(), Color = c.Color.ToString(), Value = c.Value.ToString() }).ToList() ?? new(),
            Wd4BluffPlayerIndex  = game.Wd4BluffPlayer != null ? game.Players.IndexOf(game.Wd4BluffPlayer) : -1,
            MyPlayerIndex        = playerIndex,
        };
    }

    private GameStateDto BuildSpState()
    {
        if (_game == null) return new GameStateDto();
        var dto = BuildStateForPlayer(0);
        dto.DrawnCardId = _spDrawnCardId;
        return dto;
    }

    private async Task HandleSpMove(MoveDto move)
    {
        if (_game == null) return;
        var player = _game.Players[0];

        switch (move.Type)
        {
            case "play":
                var playCard = player.Hand.FirstOrDefault(c => c.Id.ToString() == move.CardId);
                if (playCard != null)
                {
                    CardColor? declaredColor = null;
                    if (!string.IsNullOrEmpty(move.Color) && Enum.TryParse<CardColor>(move.Color, out var wc))
                        declaredColor = wc;
                    await _game.PlayCardAsync(player, playCard, declaredColor);
                }
                break;

            case "play-drawn":
                if (_spDrawnCardId != null)
                {
                    var drawnCard = player.Hand.FirstOrDefault(c => c.Id.ToString() == _spDrawnCardId);
                    _spDrawnCardId = null;
                    if (drawnCard != null) await _game.PlayCardAsync(player, drawnCard);
                }
                break;

            case "keep-drawn":
                _spDrawnCardId = null;
                _game.LogAction($"{player.Name} drew and kept the card.");
                await _game.PassTurnAfterDraw();
                break;

            case "draw":
                if (_game.PendingDrawCount > 0)
                {
                    await _game.HandlePendingDrawAsync();
                }
                else
                {
                    var drawn = await _game.DrawCardAsync(player);
                    if (drawn == null)
                    {
                        _game.ActiveNotificationBanner = "YOU MUST PLAY A CARD!";
                        _spState = BuildSpState();
                        await InvokeAsync(StateHasChanged);
                    }
                    else if (!_game.CanPlayCard(drawn))
                    {
                        _game.LogAction($"{player.Name} drew and passed.");
                        await Task.Delay(600);
                        await _game.PassTurnAfterDraw();
                    }
                    else
                    {
                        _game.LogAction($"{player.Name} drew a playable card.");
                        _spDrawnCardId = drawn.Id.ToString();
                        _spState = BuildSpState();
                        await InvokeAsync(StateHasChanged);
                    }
                }
                break;

            case "color":
                if (Enum.TryParse<CardColor>(move.Color, out var c))
                    await _game.SetWildColorAsync(c);
                break;

            case "challenge":
                await _game.ResolveChallengeAsync(true);
                break;

            case "accept":
                await _game.ResolveChallengeAsync(false);
                break;

            case "uno":
                if (_game.Status == GameStatus.WaitingForUnoCall)
                    await _game.AttemptUnoCallAsync(player);
                else
                {
                    _game.IsUnoCalled = true;
                    _game.LogAction("PLAYER proactively declared UNO!");
                    _game.ActiveNotificationBanner = "YOU DECLARED UNO!";
                    _spState = BuildSpState();
                    await InvokeAsync(StateHasChanged);
                }
                break;

            case "catch":
                await _game.AttemptUnoCallAsync(player);
                break;

            case "jump-in":
                var jumpCard = player.Hand.FirstOrDefault(c => c.Id.ToString() == move.CardId);
                if (jumpCard != null)
                    await _game.JumpInAsync(player, jumpCard);
                break;

            case "swap":
                if (move.TargetIndex.HasValue && _game.PendingCard != null)
                {
                    var swapTarget = _game.Players[move.TargetIndex.Value];
                    await _game.PlayCardAsync(player, _game.PendingCard, null, swapTarget);
                }
                break;
        }
    }

    private async Task HandleAnimMidpoint(string signal)
    {
        if (_game == null) return;
        if (signal == "resolve-vortex")
        {
            var activePlayer = _game.Players[_game.LastPlayerIndex];
            _game.ResolveVortex(activePlayer);
            _spState = BuildSpState();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task HandlePauseChanged(bool paused)
    {
        if (_game == null) return;
        _game.IsPaused = paused;
        if (!paused)
        {
            // Resume the game loop
            await _game.StartTurnAsync();
        }
    }

