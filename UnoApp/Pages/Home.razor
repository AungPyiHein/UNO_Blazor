@page "/"
@using UnoEngine
@using UnoEngine.Models
@using UnoApp.Components
@using UnoApp.Services
@inject NavigationState NavigationState

<div class="menu-screen @(_isGameStarted ? "game-active" : "")">
    @if (!_isGameStarted)
    {
        <!-- Top Tier: Floating Rules Bar -->
        <div class="rules-bar">
            <div class="rule-toggle">
                <input type="checkbox" id="rule-draw" @bind="_settings.DrawUntilPlayable" />
                <label for="rule-draw"><span>🔄</span> Draw Until Playable</label>
            </div>
            <div class="rule-toggle">
                <input type="checkbox" id="rule-seven" @bind="_settings.SevenSwap" />
                <label for="rule-seven"><span>🃏</span> 7-Swap</label>
            </div>
            <div class="rule-toggle">
                <input type="checkbox" id="rule-zero" @bind="_settings.ZeroRotate" />
                <label for="rule-zero"><span>🔃</span> Zero Rotate</label>
            </div>
            <div class="rule-toggle">
                <input type="checkbox" id="rule-jump" @bind="_settings.JumpInRule" />
                <label for="rule-jump"><span>⚡</span> Jump-In</label>
            </div>
            <div class="rule-toggle">
                <input type="checkbox" id="rule-stack" @bind="_settings.Stacking" />
                <label for="rule-stack"><span>🔥</span> Stacking</label>
            </div>
            @if (_settings.JumpInRule)
            {
                <div class="rule-toggle timer-setting">
                    <label><span>⏱️</span> QTE: @_settings.JumpInTimerSeconds.ToString("0.0")s</label>
                    <input type="range" min="1.0" max="5.0" step="0.5" @bind="_settings.JumpInTimerSeconds" />
                </div>
            }
        </div>

        <!-- Middle Tier: The Power Center -->
        <div class="center-stage">
            <button class="mega-start-btn" @onclick="StartMatch">START MATCH</button>
        </div>

        <!-- Bottom Tier: Player Identity -->
        <div class="identity-anchor">
            <div class="profile-input-box">
                <div class="avatar-silhouette">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
                    </svg>
                </div>
                <input type="text" @bind="_playerName" placeholder="YOUR NAME" maxlength="12" />
            </div>
        </div>
    }
    else
    {
        <GameBoard Game="_game" OnStartGame="ResetGame" />
    }
</div>

<style>
    .menu-screen {
        position: fixed; inset: 0;
        background: radial-gradient(circle at center, #1e293b 0%, #000000 100%);
        color: white; font-family: 'Outfit', sans-serif;
        overflow: hidden; z-index: 2000;
    }

    /* Top Tier: Rules Bar */
    .rules-bar {
        position: absolute; top: 0; left: 0; right: 0; height: 70px;
        background: rgba(0, 0, 0, 0.4); backdrop-filter: blur(15px);
        display: flex; align-items: center; justify-content: center; gap: 30px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1); z-index: 10;
    }
    .rule-toggle { display: flex; align-items: center; gap: 10px; }
    .rule-toggle input { width: 18px; height: 18px; cursor: pointer; accent-color: #22c55e; }
    .rule-toggle label { 
        font-size: 0.9rem; font-weight: 700; color: #94a3b8; cursor: pointer;
        display: flex; align-items: center; gap: 6px; transition: color 0.3s;
    }
    .rule-toggle input:checked + label { color: white; }
    .rule-toggle span { font-size: 1.2rem; }
    .timer-setting { flex-direction: column; align-items: flex-start; gap: 2px; }
    .timer-setting label { color: #facc15; }
    .timer-setting input[type="range"] { width: 100px; }

    /* Middle Tier: Center Stage */
    .center-stage {
        display: flex; justify-content: center; align-items: center; height: 100vh;
    }
    .mega-start-btn {
        background: transparent; border: 4px solid #22c55e; color: #22c55e;
        padding: 25px 80px; font-size: 3.5rem; font-weight: 900; letter-spacing: 6px;
        border-radius: 100px; cursor: pointer; position: relative;
        box-shadow: 0 0 30px rgba(34, 197, 94, 0.2);
        text-shadow: 0 0 15px rgba(34, 197, 94, 0.5);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .mega-start-btn:hover {
        transform: scale(1.05);
        background: rgba(34, 197, 94, 0.1);
        box-shadow: 0 0 50px rgba(34, 197, 94, 0.4);
        border-color: #4ade80; color: #4ade80;
    }

    /* Bottom Tier: Identity */
    .identity-anchor {
        position: absolute; bottom: 50px; left: 50%; transform: translateX(-50%);
        width: 300px;
    }
    .profile-input-box {
        display: flex; align-items: center; gap: 15px; background: rgba(255, 255, 255, 0.05);
        padding: 12px 25px; border-radius: 50px; border: 1px solid rgba(255, 255, 255, 0.1);
    }
    .avatar-silhouette { width: 40px; height: 40px; color: #64748b; }
    .profile-input-box input {
        background: transparent; border: none; color: white; font-size: 1.3rem;
        font-weight: 700; width: 100%; text-align: center;
    }
    .profile-input-box input:focus { outline: none; }
</style>

@code {
    private bool _isGameStarted = false;
    private string _playerName = "PLAYER";
    private GameSettings _settings = new();
    private UnoGame? _game;

    protected override void OnInitialized()
    {
        // Hide sidebar on the home page by default
        NavigationState.IsArenaMode = true;
    }

    private async Task StartMatch()
    {
        var players = new List<Player>
        {
            new Player { Id = Guid.NewGuid(), Name = string.IsNullOrWhiteSpace(_playerName) ? "PLAYER" : _playerName.ToUpper(), IsHuman = true },
            new Player { Id = Guid.NewGuid(), Name = "CPU 1", IsHuman = false },
            new Player { Id = Guid.NewGuid(), Name = "CPU 2", IsHuman = false },
            new Player { Id = Guid.NewGuid(), Name = "CPU 3", IsHuman = false }
        };

        _game = new UnoGame(players, _settings);
        _game.OnStateChanged += () => InvokeAsync(StateHasChanged);
        
        _isGameStarted = true;
        await _game.StartTurnAsync();
    }

    private void ResetGame()
    {
        _isGameStarted = false;
        _game = null;
    }
}
