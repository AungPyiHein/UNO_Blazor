        color: #94a3b8;
        line-height: 1.5;
    }

    .rb-badge {
        display: inline-block;
        font-size: 0.7rem;
        font-weight: 800;
        padding: 2px 8px;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        width: fit-content;
    }
    .rb-badge-red    { background: rgba(239,68,68,0.15);  color: #f87171; border: 1px solid rgba(239,68,68,0.3); }
    .rb-badge-blue   { background: rgba(59,130,246,0.15); color: #60a5fa; border: 1px solid rgba(59,130,246,0.3); }
    .rb-badge-green  { background: rgba(34,197,94,0.15);  color: #4ade80; border: 1px solid rgba(34,197,94,0.3); }
    .rb-badge-wild   { background: rgba(245,158,11,0.15); color: #fbbf24; border: 1px solid rgba(245,158,11,0.3); }
    .rb-badge-purple { background: rgba(168,85,247,0.15); color: #c084fc; border: 1px solid rgba(168,85,247,0.3); }

    .rb-info-box {
        margin-top: 10px;
        padding: 10px 14px;
        border-radius: 10px;
        font-size: 0.83rem;
        line-height: 1.5;
    }
    .rb-info-tip {
        background: rgba(59,130,246,0.08);
        border: 1px solid rgba(59,130,246,0.2);
        color: #93c5fd;
    }
    .rb-info-warn {
        background: rgba(245,158,11,0.08);
        border: 1px solid rgba(245,158,11,0.2);
        color: #fcd34d;
    }
    .rb-info-tip strong, .rb-info-warn strong { color: inherit; }

    .rb-score-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.87rem;
        margin-top: 10px;
    }
    .rb-score-table thead tr {
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    .rb-score-table th {
        padding: 7px 10px;
        text-align: left;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #475569;
        font-weight: 700;
    }
    .rb-score-table td {
        padding: 8px 10px;
        color: #cbd5e1;
        border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .rb-score-table td:last-child {
        text-align: right;
        font-weight: 800;
        color: #22c55e;
        font-variant-numeric: tabular-nums;
    }
    .rb-score-table tr:last-child td { border-bottom: none; }

    .rb-vortex-row .rb-card-info p,
    .rb-vortex-section p,
    .rb-vortex-section ul {
        color: #c084fc !important;
    }
    .rb-vortex-section h4 { color: #a855f7 !important; }

    .house-rule-desc {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 14px;
        margin-bottom: 15px;
    }
    .house-rule-desc h4 { color: #f59e0b; margin: 0 0 6px 0; }
    .house-rule-desc p { margin: 0; font-size: 0.85rem; }

    /* Animations */
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
    @@keyframes slideUp {
        from { transform: translateY(30px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
</style>

@code {
    private bool _isGameStarted = false;
    private string _playerName = "PLAYER";
    private int _playerCount = 4;
    private UnoGame? _game;

    private bool _showRulesModal = false;
    private bool _showRuleBookModal = false;

    private List<RulePresetProfile> _presets = new();
    private RulePresetProfile _selectedPreset = null!;
    
    private RulePresetProfile? _editingPreset;
    private GameSettings? _editingSettings;

    private string _activeTab = "general";

    private enum RuleType
    {
        Toggle,
        Slider
    }

    private class RuleItem
    {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Icon { get; set; } = "";
        public RuleType Type { get; set; }
        public Func<GameSettings, bool> GetBoolValue { get; set; } = _ => false;
        public Action<GameSettings, bool> SetBoolValue { get; set; } = (_, _) => { };
        public Func<GameSettings, double> GetNumberValue { get; set; } = _ => 0;
        public Action<GameSettings, double> SetNumberValue { get; set; } = (_, _) => { };
        public double Min { get; set; }
        public double Max { get; set; }
        public double Step { get; set; } = 1.0;
        public string Unit { get; set; } = "";
        public string Format { get; set; } = "0";
        public Func<GameSettings, bool> IsVisible { get; set; } = _ => true;
    }

    private List<RuleItem> _ruleItems = new();

    private void InitializeRuleItems()
    {
        _ruleItems = new List<RuleItem>
        {
            new RuleItem
            {
                Title = "Starting Hand Size",
                Description = "Cards dealt to each player at the match start (Clamped 3 to 10).",
                Icon = "🃏",
                Type = RuleType.Slider,
                Min = 3, Max = 10, Step = 1, Unit = "Cards", Format = "0",
                GetNumberValue = s => s.StartingHandSize,
                SetNumberValue = (s, v) => s.StartingHandSize = (int)v
            },
            new RuleItem
            {
                Title = "Stacking (+2 / +4)",
                Description = "Stack draw penalty cards to pass the accumulated total downstream.",
                Icon = "🔥",
                Type = RuleType.Toggle,
                GetBoolValue = s => s.Stacking,
                SetBoolValue = (s, v) => s.Stacking = v
            },
            new RuleItem
            {
                Title = "Draw Until Playable",
                Description = "Must draw continuous cards until a playable card is pulled. (Auto-enables Forced Play)",
                Icon = "🔄",
                Type = RuleType.Toggle,
                GetBoolValue = s => s.DrawUntilPlayable,
                SetBoolValue = (s, v) => { 
                    s.DrawUntilPlayable = v; 
                    if (v) s.ForcedPlay = true; 
                }
            },
            new RuleItem
            {
                Title = "Forced Play",
                Description = "Players MUST play a card if they have a match in hand (disables reneging/drawing).",
                Icon = "🔒",
                Type = RuleType.Toggle,
                GetBoolValue = s => s.ForcedPlay,
                SetBoolValue = (s, v) => {
                    s.ForcedPlay = v;
                    if (!v && s.DrawUntilPlayable) s.DrawUntilPlayable = false;
                }
            },
            new RuleItem
            {
                Title = "Wild Draw 4 Challenge",
                Description = "Targets can challenge played +4s for illegal matching color.",
                Icon = "⚔️",
                Type = RuleType.Toggle,
                GetBoolValue = s => s.EnableWildDraw4Challenge,
                SetBoolValue = (s, v) => s.EnableWildDraw4Challenge = v
            },
            new RuleItem
            {
                Title = "7-Swap",
                Description = "Forces hand-swaps with another player when a 7 is played.",
                Icon = "🃏",
                Type = RuleType.Toggle,
                GetBoolValue = s => s.SevenSwap,
                SetBoolValue = (s, v) => s.SevenSwap = v
            },
            new RuleItem
            {
                Title = "Zero Rotate",
                Description = "Rotates everyone's hands along direction of play on a 0.",
                Icon = "🔃",
                Type = RuleType.Toggle,
                GetBoolValue = s => s.ZeroRotate,
                SetBoolValue = (s, v) => s.ZeroRotate = v
            },
            new RuleItem
            {
                Title = "Jump-In Rule",
                Description = "Play out of turn if you hold an exact color AND value duplicate match.",
                Icon = "⚡",
                Type = RuleType.Toggle,
                GetBoolValue = s => s.JumpInRule,
                SetBoolValue = (s, v) => s.JumpInRule = v
            },
            new RuleItem
            {
                Title = "Jump-In UI Glow",
                Description = "Adds a red glowing border to cards that can be jumped in.",
                Icon = "✨",
                Type = RuleType.Toggle,
                GetBoolValue = s => s.ShowJumpInGlow,
                SetBoolValue = (s, v) => s.ShowJumpInGlow = v,
                IsVisible = s => s.JumpInRule
            },
            new RuleItem
            {
                Title = "Vortex",
                Description = "Vortex swallows all the card and redistribute everyone's hand.",
                Icon = "🌀",
                Type = RuleType.Toggle,
                GetBoolValue = s => s.EnableVortex,
                SetBoolValue = (s, v) => s.EnableVortex = v
            },
            new RuleItem
            {
                Title = "Uno Call Failure Penalty",
                Description = "Cards drawn if caught failing to call UNO (Clamped 1 to 5).",
                Icon = "🔔",
                Type = RuleType.Slider,
                Min = 1, Max = 5, Step = 1, Unit = "Cards", Format = "0",
                GetNumberValue = s => s.UnoFailurePenaltyCards,
                SetNumberValue = (s, v) => s.UnoFailurePenaltyCards = (int)v
            },
            new RuleItem
            {
                Title = "Jump-In QTE Timer",
                Description = "Speed window (seconds) to intercept duplicates out of turn.",
                Icon = "⏱️",
                Type = RuleType.Slider,
                Min = 1.0, Max = 5.0, Step = 0.5, Unit = "s", Format = "0.0",
                GetNumberValue = s => s.JumpInTimerSeconds,
                SetNumberValue = (s, v) => s.JumpInTimerSeconds = v,
                IsVisible = s => s.JumpInRule
            }
        };
    }

    protected override void OnInitialized()
    {
        NavigationState.IsArenaMode = true;
        InitializeRuleItems();

        // Initialize Presets
        var classicPreset = new RulePresetProfile
        {
            Name = "Classic",
            IsReadonly = true,
            Settings = new GameSettings
            {
                StartingHandSize = 7,
                Stacking = false,
                DrawUntilPlayable = false,
                ForcedPlay = false,
                EnableWildDraw4Challenge = true,
                SevenSwap = false,
                ZeroRotate = false,
                JumpInRule = false,
                EnableVortex = false,
                UnoFailurePenaltyCards = 2
            }
        };

        var chaosPreset = new RulePresetProfile
        {
            Name = "Chaos",
            IsReadonly = true, // Locked system preset forcing all modifiers to max
            Settings = new GameSettings
            {
                StartingHandSize = 6, // 6 cards starting hand for Chaos
                Stacking = true,
                DrawUntilPlayable = true,
                ForcedPlay = false,
                EnableWildDraw4Challenge = true,
                SevenSwap = true,
                ZeroRotate = true,
                JumpInRule = true,
                ShowJumpInGlow = false, // Disabled in Chaos
                JumpInTimerSeconds = 1.0, // 1 second QTE timer for ultimate speed/chaos
                EnableVortex = true,
                UnoFailurePenaltyCards = 5 // Max draw penalty
            }
        };

        var customPreset = new RulePresetProfile
        {
            Name = "Custom",
            IsReadonly = false,
            Settings = new GameSettings
            {
                StartingHandSize = 7,
                Stacking = true,
                DrawUntilPlayable = true,
                ForcedPlay = false,
                EnableWildDraw4Challenge = false,
                SevenSwap = true,
                ZeroRotate = true,
                JumpInRule = true,
                JumpInTimerSeconds = 2.5,
                EnableVortex = false,
                UnoFailurePenaltyCards = 2
            }
        };

        _presets.Add(classicPreset);
        _presets.Add(chaosPreset);
        _presets.Add(customPreset);

        // Set default preset
        _selectedPreset = classicPreset;
    }

    private void OpenRulesModal()
    {
        _editingPreset = _selectedPreset;
        _editingSettings = _selectedPreset.Settings.Clone();
        _showRulesModal = true;
    }

    private void SaveAndApplyRules()
    {
        if (_editingPreset != null && _editingSettings != null)
        {
            _editingPreset.Settings = _editingSettings;
            _selectedPreset = _editingPreset;
        }
        _showRulesModal = false;
    }

    private void SelectPreset(RulePresetProfile preset)
    {
        _editingPreset = preset;
        _editingSettings = preset.Settings.Clone();
    }

    private void CreateCustomPreset()
    {
        var newPreset = new RulePresetProfile
        {
            Name = $"Preset {_presets.Count - 1}",
            IsReadonly = false,
            Settings = (_editingSettings ?? _selectedPreset.Settings).Clone() // Clones currently selected start settings
        };
        _presets.Add(newPreset);
        _editingPreset = newPreset;
        _editingSettings = newPreset.Settings.Clone();
    }

    private void DeletePreset(RulePresetProfile preset)
    {
        if (preset.IsReadonly || preset.Name == "Chaos" || preset.Name == "Custom") return;
        
        _presets.Remove(preset);
        if (_editingPreset == preset)
        {
            _editingPreset = _presets.First(p => p.Name == "Classic");
            _editingSettings = _editingPreset.Settings.Clone();
        }
        if (_selectedPreset == preset)
        {
            _selectedPreset = _presets.First(p => p.Name == "Classic");
        }
    }

    private void ToggleRule(Action<bool> setter, ChangeEventArgs e)
    {
        if (_editingPreset?.IsReadonly == true) return;

        if (e.Value is bool val)
        {
            setter(val);
        }
    }

    private void ToggleDrawUntilPlayable(ChangeEventArgs e)
    {
        if (_editingPreset?.IsReadonly == true) return;

        if (e.Value is bool val)
        {
            _editingSettings.DrawUntilPlayable = val;
            if (val)
            {
                _editingSettings.ForcedPlay = true;
            }
        }
    }

    private void ToggleForcedPlay(ChangeEventArgs e)
    {
        if (_editingPreset?.IsReadonly == true) return;

        if (e.Value is bool val)
        {
            _editingSettings.ForcedPlay = val;
            if (!val && _editingSettings.DrawUntilPlayable)
            {
                _editingSettings.DrawUntilPlayable = false;
            }
        }
    }

    private void UpdateStartingHandSize(ChangeEventArgs e)
    {
        if (_editingPreset?.IsReadonly == true || _editingSettings == null) return;
        if (int.TryParse(e.Value?.ToString(), out var val))
        {
            _editingSettings.StartingHandSize = Math.Clamp(val, 3, 10);
        }
    }

    private void UpdateUnoPenaltyCards(ChangeEventArgs e)
    {
        if (_editingPreset?.IsReadonly == true || _editingSettings == null) return;
        if (int.TryParse(e.Value?.ToString(), out var val))
        {
            _editingSettings.UnoFailurePenaltyCards = Math.Clamp(val, 1, 5);
        }
    }

    private void UpdateTimer(ChangeEventArgs e)
    {
        if (_editingPreset?.IsReadonly == true || _editingSettings == null) return;

        if (double.TryParse(e.Value?.ToString(), out var seconds))
        {
            _editingSettings.JumpInTimerSeconds = seconds;
        }
    }

    private async Task StartMatch()
    {
        var players = new List<Player>
        {
            new Player { Id = Guid.NewGuid(), Name = string.IsNullOrWhiteSpace(_playerName) ? "PLAYER" : _playerName.ToUpper(), IsHuman = true }
        };

        for (int i = 1; i < _playerCount; i++)
        {
            players.Add(new Player { Id = Guid.NewGuid(), Name = $"CPU {i}", IsHuman = false });
        }

        // Pass the settings of the active selected preset directly to the game session!
        _game = new UnoGame(players, _selectedPreset.Settings);
        _game.OnStateChanged += () => InvokeAsync(StateHasChanged);
        
        _isGameStarted = true;
        await _game.DealStartingCardsAsync();
        await _game.StartTurnAsync();
    }

    private void ResetGame()
    {
        _isGameStarted = false;
        _game = null;
    }

    private async Task HandleNextRound()
    {
        if (_game == null) return;

        var prevPlayers = _game.Players.Select(p => new UnoEngine.Models.Player
        {
            Id = Guid.NewGuid(),
            Name = p.Name,
            IsHuman = p.IsHuman,
            TotalScore = p.TotalScore
        }).ToList();
        var settings = _game.Settings;
        int nextRound = _game.RoundNumber + 1;

        _game = new UnoGame(prevPlayers, settings);
        _game.RoundNumber = nextRound;
        _game.OnStateChanged += () => InvokeAsync(StateHasChanged);

        await _game.DealStartingCardsAsync();
        await _game.StartTurnAsync();
        StateHasChanged();
    }
}
