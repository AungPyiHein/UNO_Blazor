                                                <tr><td>2</td><td>50 pts</td></tr>
                                                <tr><td>3</td><td>45 pts</td></tr>
                                                <tr><td>4</td><td>40 pts</td></tr>
                                                <tr><td>5</td><td>35 pts</td></tr>
