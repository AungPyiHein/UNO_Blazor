@page "/multiplayer-game"
@inject UnoApp.Services.LobbyService LobbyService
@inject NavigationManager Nav
@implements IDisposable
@using UnoApp.Multiplayer
@using System.Text.Json

<div class="mpg-arena">
    @if (_state == null)
    {
        <div class="mpg-loading">
            <div class="mpg-loading-spinner"></div>
            <p>Connecting to game…</p>
        </div>
    }
    else if (_state.IsGameOver)
    {
        <div class="mpg-gameover">
            <div class="mpg-gameover-trophy">🏆</div>
            <h2>@(_state.WinnerIndex.HasValue ? _state.PlayerNames[_state.WinnerIndex.Value] + " Wins!" : "Game Over!")</h2>
            <button class="mpg-action-btn" @onclick="BackToLobby">← Back to Lobby</button>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(_state.NotificationBanner))
        {
            <div class="mpg-banner">@_state.NotificationBanner</div>
        }

        <!-- Top bar: players -->
        <div class="mpg-players-bar">
            @for (int i = 0; i < _state.PlayerNames.Length; i++)
            {
                int idx = i;
                bool isCurrent = idx == _state.CurrentPlayerIndex;
                bool isMe = idx == LobbyService.MyPlayerIndex;
                <div class="mpg-pslot @(isCurrent ? "pslot-active" : "") @(isMe ? "pslot-me" : "")">
                    <div class="pslot-avatar" style="background:@AvatarColor(idx)">@FirstLetter(_state.PlayerNames[idx])</div>
                    <div class="pslot-info">
                        <div class="pslot-name">@_state.PlayerNames[idx]@(isMe ? " (You)" : "")</div>
                        <div class="pslot-count">🃏 @_state.HandCounts[idx]</div>
                    </div>
                    @if (isCurrent) { <div class="pslot-turn-dot"></div> }
                </div>
            }
        </div>

        <!-- Middle: top card + direction -->
        <div class="mpg-center">
            @if (_state.TopCard != null)
            {
                string activeColor = (_state.ActiveColor ?? _state.TopCard.Color).ToLower();
                <div class="mpg-topcard-wrap">
                    <div class="uno-card uno-card-@activeColor">
                        <div class="uno-card-corner uno-card-corner-tl">@FormatLabel(_state.TopCard.Value)</div>
                        <div class="uno-card-oval">
                            <span class="uno-card-center-val">@FormatLabel(_state.TopCard.Value)</span>
                        </div>
                        <div class="uno-card-corner uno-card-corner-br">@FormatLabel(_state.TopCard.Value)</div>
                    </div>
                    @if (_state.PendingDraw > 0)
                    {
                        <div class="mpg-stacked-badge">+@_state.PendingDraw</div>
                    }
                </div>
            }
            <div class="mpg-dir-badge">@(_state.Direction == 1 ? "▶ Clockwise" : "◀ Counter-clockwise")</div>
        </div>

        <!-- Bottom: action zone -->
        <div class="mpg-bottom">
            @if (_pendingWildCardId != null)
            {
                <p class="mpg-turn-label">Choose a color for your Wild:</p>
                <div class="mpg-color-row">
                    @foreach (var col in new[] { "Red", "Blue", "Green", "Yellow" })
                    {
                        var c = col;
                        <button class="mpg-color-btn mpg-color-btn-@c.ToLower()" @onclick='() => SendColorMove(c)'>@c</button>
                    }
                    <button class="mpg-cancel-btn" @onclick='() => { _pendingWildCardId = null; }'>✕</button>
                </div>
            }
            else if (_state.IsMyTurn)
            {
                @if (_state.Status == "WaitingForWd4Challenge")
                {
                    <p class="mpg-turn-label">Wild Draw 4 played on you!</p>
                    <div class="mpg-btns-row">
                        <button class="mpg-action-btn mpg-btn-danger" @onclick='() => SendSimpleMove("challenge")'>⚔️ Challenge</button>
                        <button class="mpg-action-btn" @onclick='() => SendSimpleMove("accept")'>📥 Accept +4</button>
                    </div>
                }
                else if (_state.Status == "WaitingForColorSelection")
                {
                    <p class="mpg-turn-label">Pick a color:</p>
                    <div class="mpg-color-row">
                        @foreach (var col in new[] { "Red", "Blue", "Green", "Yellow" })
                        {
                            var c = col;
                            <button class="mpg-color-btn mpg-color-btn-@c.ToLower()" @onclick='() => SendColorOnlyMove(c)'>@c</button>
                        }
                    </div>
                }
                else
                {
                    <p class="mpg-turn-label">✨ Your turn!</p>
                    <div class="mpg-hand">
                        @foreach (var card in _state.MyHand)
                        {
                            var cc = card;
                            string cardColor = cc.Color.ToLower();
                            <div class="uno-card uno-card-@cardColor @(cc.IsPlayable ? "uno-card-playable" : "uno-card-dim")"
                                 @onclick='() => OnCardClicked(cc)'>
                                <div class="uno-card-corner uno-card-corner-tl">@FormatLabel(cc.Value)</div>
                                <div class="uno-card-oval">
                                    <span class="uno-card-center-val">@FormatLabel(cc.Value)</span>
                                </div>
                                <div class="uno-card-corner uno-card-corner-br">@FormatLabel(cc.Value)</div>
                            </div>
                        }
                    </div>
                    <div class="mpg-btns-row">
                        <button class="mpg-action-btn" @onclick='() => SendSimpleMove("draw")'>🃏 Draw</button>
                        <button class="mpg-action-btn mpg-btn-uno" @onclick="SendUno">UNO!</button>
                    </div>
                }
            }
            else
            {
                <div class="mpg-waiting-msg">
                    Waiting for <strong>@_state.PlayerNames[_state.CurrentPlayerIndex]</strong>…
                </div>
                @if (_state.Status == "WaitingForUnoCall")
                {
                    <button class="mpg-action-btn mpg-btn-uno" @onclick="SendUno">⚡ Catch UNO!</button>
                }
                <!-- Show hand face-down while waiting -->
                <div class="mpg-hand mpg-hand-waiting">
                    @foreach (var card in _state.MyHand)
                    {
                        <div class="uno-card uno-card-back"></div>
                    }
                </div>
            }
        </div>
    }
</div>

<style>
/* ── Arena shell ─────────────────────────────────────────────── */
.mpg-arena {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: radial-gradient(ellipse at 50% 0%, #0d1a0d 0%, #080810 60%);
    color: #fff;
    font-family: inherit;
    overflow: hidden;
}

/* ── Loading ─────────────────────────────────────────────────── */
.mpg-loading {
    margin: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    color: rgba(255,255,255,0.4);
    font-size: 1.1rem;
}
.mpg-loading-spinner {
    width: 48px; height: 48px;
    border: 4px solid rgba(255,255,255,0.1);
    border-top-color: #22c55e;
    border-radius: 50%;
    animation: spin 0.9s linear infinite;
}
@@keyframes spin { to { transform: rotate(360deg); } }

/* ── Game over ───────────────────────────────────────────────── */
.mpg-gameover {
    margin: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
}
.mpg-gameover-trophy { font-size: 5rem; animation: popIn 0.5s cubic-bezier(0.175,0.885,0.32,1.275); }
.mpg-gameover h2 { font-size: 2.5rem; font-weight: 900; letter-spacing: 2px; color: #22c55e; }
@@keyframes popIn { from { transform: scale(0); opacity: 0; } to { transform: scale(1); opacity: 1; } }

/* ── Notification banner ─────────────────────────────────────── */
.mpg-banner {
    background: rgba(239,68,68,0.12);
    border-bottom: 1px solid rgba(239,68,68,0.3);
    padding: 10px 20px;
    text-align: center;
    font-weight: 800;
    letter-spacing: 1px;
    color: #ef4444;
    font-size: 0.9rem;
    flex-shrink: 0;
}

/* ── Players bar ─────────────────────────────────────────────── */
.mpg-players-bar {
    display: flex;
    gap: 10px;
    padding: 14px 18px;
    background: rgba(255,255,255,0.03);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    flex-wrap: wrap;
    flex-shrink: 0;
}
.mpg-pslot {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 40px;
    background: rgba(255,255,255,0.04);
    border: 1.5px solid rgba(255,255,255,0.08);
    position: relative;
    transition: border-color 0.25s, background 0.25s;
}
.pslot-active { border-color: #22c55e; background: rgba(34,197,94,0.1); }
.pslot-me { border-color: #6366f1; }
.pslot-active.pslot-me { border-color: #22c55e; }
.pslot-avatar {
    width: 30px; height: 30px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 900; font-size: 0.85rem; color: #000;
    flex-shrink: 0;
}
.pslot-name { font-weight: 700; font-size: 0.82rem; line-height: 1.2; }
.pslot-count { color: rgba(255,255,255,0.4); font-size: 0.75rem; }
.pslot-turn-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 8px #22c55e;
    animation: pulse 1.2s ease-in-out infinite;
    margin-left: 4px;
}
@@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.8)} }

/* ── Center (top card) ───────────────────────────────────────── */
.mpg-center {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 18px;
    padding: 20px;
}
.mpg-topcard-wrap { position: relative; }
.mpg-stacked-badge {
    position: absolute;
    top: -10px; right: -14px;
    background: #f97316;
    color: #fff;
    font-weight: 900;
    font-size: 1rem;
    padding: 4px 10px;
    border-radius: 20px;
    box-shadow: 0 0 12px rgba(249,115,22,0.6);
}
.mpg-dir-badge {
    color: rgba(255,255,255,0.35);
    font-size: 0.8rem;
    letter-spacing: 1px;
    text-transform: uppercase;
}

/* ── Bottom action zone ──────────────────────────────────────── */
.mpg-bottom {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    padding: 18px 18px 28px;
    background: rgba(0,0,0,0.3);
    border-top: 1px solid rgba(255,255,255,0.06);
}
.mpg-turn-label {
    font-size: 1rem;
    font-weight: 700;
    color: #22c55e;
    letter-spacing: 1px;
    margin: 0;
}
.mpg-waiting-msg {
    color: rgba(255,255,255,0.4);
    font-size: 0.95rem;
    text-align: center;
}

/* ── Card hand ───────────────────────────────────────────────── */
.mpg-hand {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: center;
    max-width: 100%;
}
.mpg-hand-waiting { opacity: 0.35; pointer-events: none; }

/* ── Buttons ─────────────────────────────────────────────────── */
.mpg-btns-row { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
.mpg-action-btn {
    background: rgba(255,255,255,0.08);
    border: 1.5px solid rgba(255,255,255,0.15);
    border-radius: 14px;
    color: #fff;
    padding: 12px 28px;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    letter-spacing: 0.5px;
    transition: background 0.2s, transform 0.1s, box-shadow 0.2s;
}
.mpg-action-btn:hover { background: rgba(255,255,255,0.15); transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,0,0,0.4); }
.mpg-btn-danger { background: rgba(239,68,68,0.15); border-color: #ef4444; color: #ef4444; }
.mpg-btn-danger:hover { background: rgba(239,68,68,0.25); }
.mpg-btn-uno { background: rgba(234,179,8,0.15); border-color: #eab308; color: #eab308; }
.mpg-btn-uno:hover { background: rgba(234,179,8,0.28); }
.mpg-cancel-btn {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 10px;
    color: rgba(255,255,255,0.4);
    padding: 8px 14px;
    cursor: pointer;
    font-size: 1rem;
}

/* ── Color picker ────────────────────────────────────────────── */
.mpg-color-row { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; align-items: center; }
.mpg-color-btn {
    width: 76px; height: 54px;
    border-radius: 12px;
    border: 2px solid rgba(255,255,255,0.25);
    color: #fff;
    font-weight: 800;
    font-size: 0.8rem;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: transform 0.15s, box-shadow 0.15s;
}
.mpg-color-btn:hover { transform: scale(1.1); box-shadow: 0 4px 16px rgba(0,0,0,0.4); border-color: #fff; }
.mpg-color-btn-red    { background: #dc2626; }
.mpg-color-btn-blue   { background: #2563eb; }
.mpg-color-btn-green  { background: #16a34a; }
.mpg-color-btn-yellow { background: #ca8a04; }

/* ── UNO Card ────────────────────────────────────────────────── */
.uno-card {
    width: 64px; height: 96px;
    border-radius: 10px;
    border: 2.5px solid rgba(255,255,255,0.25);
    position: relative;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: transform 0.18s cubic-bezier(0.175,0.885,0.32,1.275), box-shadow 0.18s;
    flex-shrink: 0;
    user-select: none;
    overflow: hidden;
}
.uno-card-playable { border-color: rgba(255,255,255,0.7); }
.uno-card-playable:hover {
    transform: translateY(-14px) scale(1.07);
    box-shadow: 0 16px 32px rgba(0,0,0,0.6), 0 0 20px rgba(255,255,255,0.15);
    z-index: 10;
}
.uno-card-dim { opacity: 0.38; cursor: not-allowed; }

/* card colors */
.uno-card-red    { background: linear-gradient(145deg, #ef4444, #b91c1c); }
.uno-card-blue   { background: linear-gradient(145deg, #3b82f6, #1d4ed8); }
.uno-card-green  { background: linear-gradient(145deg, #22c55e, #15803d); }
.uno-card-yellow { background: linear-gradient(145deg, #eab308, #a16207); }
.uno-card-wild   { background: linear-gradient(135deg, #ef4444 25%, #3b82f6 25% 50%, #22c55e 50% 75%, #eab308 75%); }
.uno-card-back   { background: linear-gradient(145deg, #1e1b4b, #312e81); cursor: default; }

/* inner oval */
.uno-card-oval {
    width: 42px; height: 66px;
    background: rgba(255,255,255,0.18);
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.3);
    display: flex; align-items: center; justify-content: center;
    position: relative;
    transform: rotate(-30deg);
}
.uno-card-center-val {
    transform: rotate(30deg);
    font-size: 1.35rem;
    font-weight: 900;
    color: #fff;
    text-shadow: 0 1px 4px rgba(0,0,0,0.6);
    line-height: 1;
}
/* corners */
.uno-card-corner {
    position: absolute;
    font-size: 0.6rem;
    font-weight: 900;
    color: #fff;
    text-shadow: 0 1px 2px rgba(0,0,0,0.5);
    line-height: 1;
}
.uno-card-corner-tl { top: 4px; left: 5px; }
.uno-card-corner-br { bottom: 4px; right: 5px; transform: rotate(180deg); }

/* top card larger */
.mpg-topcard-wrap .uno-card {
    width: 90px; height: 135px;
    border-radius: 14px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.6);
    cursor: default;
}
.mpg-topcard-wrap .uno-card:hover { transform: none; box-shadow: 0 8px 32px rgba(0,0,0,0.6); }
.mpg-topcard-wrap .uno-card-oval { width: 60px; height: 94px; }
.mpg-topcard-wrap .uno-card-center-val { font-size: 2rem; }
.mpg-topcard-wrap .uno-card-corner { font-size: 0.85rem; }
.mpg-topcard-wrap .uno-card-corner-tl { top: 6px; left: 8px; }
.mpg-topcard-wrap .uno-card-corner-br { bottom: 6px; right: 8px; }
</style>

@code {
    private GameStateDto? _state;
    private string? _pendingWildCardId;
    private static readonly JsonSerializerOptions _jsonOpts = new() { PropertyNameCaseInsensitive = true };

    private static readonly string[] _avatarColors = { "#22c55e","#3b82f6","#f97316","#a855f7","#ec4899","#14b8a6" };

    protected override void OnInitialized()
    {
        LobbyService.StateUpdated += OnStateUpdated;
    }

    private void OnStateUpdated(string json)
    {
        try
        {
            _state = JsonSerializer.Deserialize<GameStateDto>(json, _jsonOpts);
            InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    private void OnCardClicked(CardDto card)
    {
        if (_state == null || !_state.IsMyTurn || !card.IsPlayable) return;
        if (card.Color == "Wild")
        {
            _pendingWildCardId = card.Id;
            return;
        }
        _ = SendPlayMove(card.Id, null, null);
    }

    private async Task SendPlayMove(string cardId, string? color, int? targetIndex)
    {
        await LobbyService.SendMoveAsync(new MoveDto
        {
            PlayerIndex = LobbyService.MyPlayerIndex,
            Type        = "play",
            CardId      = cardId,
            Color       = color,
            TargetIndex = targetIndex
        });
    }

    private async Task SendSimpleMove(string type)
    {
        await LobbyService.SendMoveAsync(new MoveDto
        {
            PlayerIndex = LobbyService.MyPlayerIndex,
            Type        = type
        });
    }

    private async Task SendColorMove(string color)
    {
        if (_pendingWildCardId == null) return;
        var cardId = _pendingWildCardId;
        _pendingWildCardId = null;
        await SendPlayMove(cardId, color, null);
    }

    private async Task SendColorOnlyMove(string color)
    {
        await LobbyService.SendMoveAsync(new MoveDto
        {
            PlayerIndex = LobbyService.MyPlayerIndex,
            Type        = "color",
            Color       = color
        });
    }

    private async Task SendUno()
    {
        await LobbyService.SendMoveAsync(new MoveDto
        {
            PlayerIndex = LobbyService.MyPlayerIndex,
            Type        = "uno"
        });
    }

    private void BackToLobby()
    {
        LobbyService.ResetGame();
        Nav.NavigateTo("/lobby");
    }

    private static string FormatLabel(string? value) => value switch
    {
        "DrawTwo"   => "+2",
        "WildDraw4" => "+4",
        "Skip"      => "⊘",
        "Reverse"   => "↺",
        "Wild"      => "W",
        "Vortex"    => "◉",
        "Zero"      => "0",
        "One"       => "1",
        "Two"       => "2",
        "Three"     => "3",
        "Four"      => "4",
        "Five"      => "5",
        "Six"       => "6",
        "Seven"     => "7",
        "Eight"     => "8",
        "Nine"      => "9",
        null        => "?",
        _           => value
    };

    private static string AvatarColor(int idx) => _avatarColors[idx % _avatarColors.Length];

    private static string FirstLetter(string name) =>
        name.Length > 0 ? name[0].ToString().ToUpper() : "?";

    public void Dispose()
    {
        LobbyService.StateUpdated -= OnStateUpdated;
    }
}
