    {
        await LobbyService.SendMoveAsync(new MoveDto
        {
            PlayerIndex = MyIdx,
            Type        = "play",
            CardId      = cardId,
            Color       = color,
            TargetIndex = targetIndex
        });
    }

    private async Task SendSimpleMove(string type)
    {
        await LobbyService.SendMoveAsync(new MoveDto { PlayerIndex = MyIdx, Type = type });
    }

    private async Task SendColorOnlyMove(string color)
