@using UnoEngine
@using UnoEngine.Models
@using UnoApp.Components

@if (Game != null)
{
    <div class="game-container @(_animClass)">

        <!-- Grid Spacers -->
        <div class="grid-tl"></div>
        <div class="grid-tr"></div>
        <div class="grid-bl"></div>

        <!-- CPU 2 (TOP) -->
        <div class="player-slot slot-cpu-2">
            <div class="cpu-badge" style="position:relative">
                <PlayerProfile Player="@Game.Players[2]" IsActive="@(Game.CurrentPlayerIndex == 2)" />
                @if (_skippedPlayerIndex == 2)
                {
                    <div class="skip-overlay" @key="_skipKey">
                        <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="50" cy="50" r="45" stroke="#cc0000" stroke-width="10" fill="rgba(180,0,0,0.15)"/>
                            <line x1="18" y1="18" x2="82" y2="82" stroke="#cc0000" stroke-width="10" stroke-linecap="round"/>
                        </svg>
                    </div>
                }
            </div>
            <div class="hand @(IsSwapPartner(2) ? "swap-anim" : "") @(_rotateAnim)">
@{
                    // During ingest we use the frozen snapshot so the DOM elements
                    // stay alive for the full CSS transition before data is mutated.
                    int cpu2Count = _vortexHandSnapshot != null
                        ? _vortexHandSnapshot[2]
                        : Math.Min(Game.Players[2].Hand.Count, 5);
                }
                @for (int i = 0; i < cpu2Count; i++)
                {
                    <div class="hand-card-wrapper @(_isSwallowingCards ? "vortex-ingest" : "") @(_isSpittingCards ? "vortex-eject" : "")">
                        <UnoCardComponent IsBack="true" />
                    </div>
                }
            </div>
        </div>

        <!-- CPU 1 (LEFT) -->
        <div class="player-slot slot-cpu-1">
            <div class="cpu-badge" style="position:relative">
                <PlayerProfile Player="@Game.Players[1]" IsActive="@(Game.CurrentPlayerIndex == 1)" />
                @if (_skippedPlayerIndex == 1)
                {
                    <div class="skip-overlay" @key="_skipKey">
                        <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="50" cy="50" r="45" stroke="#cc0000" stroke-width="10" fill="rgba(180,0,0,0.15)"/>
                            <line x1="18" y1="18" x2="82" y2="82" stroke="#cc0000" stroke-width="10" stroke-linecap="round"/>
                        </svg>
                    </div>
                }
            </div>
            <div class="hand @(IsSwapPartner(1) ? "swap-anim" : "") @(_rotateAnim)">
@{
                    int cpu1Count = _vortexHandSnapshot != null
                        ? _vortexHandSnapshot[1]
                        : Math.Min(Game.Players[1].Hand.Count, 5);
                }
                @for (int i = 0; i < cpu1Count; i++)
                {
                    <div class="hand-card-wrapper @(_isSwallowingCards ? "vortex-ingest" : "") @(_isSpittingCards ? "vortex-eject" : "")">
                        <UnoCardComponent IsBack="true" />
                    </div>
                }
            </div>
        </div>

        <!-- CENTER AREA (THE HUB) -->
        <div class="center-area">
            <!-- Turn Direction Indicator -->
            <div class="turn-indicator @(Game.GameDirection == 1 ? "clockwise" : "counter-clockwise")">
                <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <!-- Base subtle track -->
                    <circle cx="100" cy="100" r="95" stroke="rgba(255,255,255,0.05)" stroke-width="2"/>
                    <!-- Sleek rotating arrows -->
                    <path d="M100 5 A 95 95 0 0 1 195 100" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                    <path d="M195 100 A 95 95 0 0 1 100 195" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                    <path d="M100 195 A 95 95 0 0 1 5 100" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                    <path d="M5 100 A 95 95 0 0 1 100 5" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                    
                    <!-- Right (pointing DOWN) -->
                    <polygon points="190,95 200,95 195,105" fill="currentColor" class="arrow-head arrow-right" />
                    <!-- Bottom (pointing LEFT) -->
                    <polygon points="105,190 105,200 95,195" fill="currentColor" class="arrow-head arrow-bottom" />
                    <!-- Left (pointing UP) -->
                    <polygon points="0,105 10,105 5,95" fill="currentColor" class="arrow-head arrow-left" />
                    <!-- Top (pointing RIGHT) -->
                    <polygon points="95,0 95,10 105,5" fill="currentColor" class="arrow-head arrow-top" />
                </svg>
            </div>

            <div class="draw-pile" @onclick="HandleDraw">
                <UnoCardComponent IsBack="true" />
            </div>
            <div class="discard-pile" style="position: relative;">
                <div @key="Game.TopCard?.Id" class="discard-anim-@Game.LastPlayerIndex">
                    <UnoCardComponent Card="@Game.TopCard" />
                </div>
                @if (Game.PendingDrawCount > 0)
                {
                    <div class="stack-badge">
                        +@Game.PendingDrawCount
                    </div>
                }
                @if (Game.Status == GameStatus.WaitingForJumpIn)
                {
                    <svg class="qte-ring" viewBox="0 0 100 100" style="--qte-duration: @(Game.Settings.JumpInTimerSeconds.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))s;">
                        <circle cx="50" cy="50" r="45"></circle>
                    </svg>
                }
            </div>

            @if (_showVortexAnimation)
            {
                <div class="vortex-animation-overlay">
                    <img src="/images/image_144935.png" alt="Vortex Swirl" class="vortex-swirl-graphic" />
                </div>
            }
        </div>

        <!-- CPU 3 (RIGHT) -->
        <div class="player-slot slot-cpu-3">
            <div class="cpu-badge" style="position:relative">
                <PlayerProfile Player="@Game.Players[3]" IsActive="@(Game.CurrentPlayerIndex == 3)" />
                @if (_skippedPlayerIndex == 3)
                {
                    <div class="skip-overlay" @key="_skipKey">
                        <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="50" cy="50" r="45" stroke="#cc0000" stroke-width="10" fill="rgba(180,0,0,0.15)"/>
                            <line x1="18" y1="18" x2="82" y2="82" stroke="#cc0000" stroke-width="10" stroke-linecap="round"/>
                        </svg>
                    </div>
                }
            </div>
            <div class="hand @(IsSwapPartner(3) ? "swap-anim" : "") @(_rotateAnim)">
@{
                    int cpu3Count = _vortexHandSnapshot != null
                        ? _vortexHandSnapshot[3]
                        : Math.Min(Game.Players[3].Hand.Count, 5);
                }
                @for (int i = 0; i < cpu3Count; i++)
                {
                    <div class="hand-card-wrapper @(_isSwallowingCards ? "vortex-ingest" : "") @(_isSpittingCards ? "vortex-eject" : "")">
                        <UnoCardComponent IsBack="true" />
                    </div>
                }
            </div>
        </div>

        <!-- HUMAN (BOTTOM) -->
        <div class="player-slot slot-human">
            <div class="human-profile-wrapper" style="position:relative">
                <PlayerProfile Player="@Game.Players[0]" IsActive="@(Game.CurrentPlayerIndex == 0)" />
                @if (_skippedPlayerIndex == 0)
                {
                    <div class="skip-overlay" @key="_skipKey">
                        <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="50" cy="50" r="45" stroke="#cc0000" stroke-width="10" fill="rgba(180,0,0,0.15)"/>
                            <line x1="18" y1="18" x2="82" y2="82" stroke="#cc0000" stroke-width="10" stroke-linecap="round"/>
                        </svg>
                    </div>
                }
            </div>
            <div class="hand @(IsSwapPartner(0) ? "swap-anim" : "") @(_rotateAnim)">
                @{
                    // Sort by color group then by value
                    var humanHand = Game.Players[0].Hand
                        .OrderBy(c => c.Color switch {
                            CardColor.Red    => 0,
                            CardColor.Yellow => 1,
                            CardColor.Green  => 2,
                            CardColor.Blue   => 3,
                            _                => 4  // Wild
                        })
                        .ThenBy(c => (int)c.Value)
                        .ToList();
                    int count = humanHand.Count;
                    double middleIndex = (count - 1) / 2.0;
                    // Scale angle down as hand grows to prevent cards going off-screen
                    double anglePerCard = count <= 7  ? 5.0
                                       : count <= 12 ? 3.5
                                       : count <= 18 ? 2.5
                                       : 1.8;
                    // Scale the translateY down too for large hands
                    double tyFactor = count <= 7 ? 1.5 : count <= 14 ? 0.8 : 0.4;
                }
@{
                    // Freeze count during ingest so the human's cards stay in the DOM
                    int humanCount = _vortexHandSnapshot != null ? _vortexHandSnapshot[0] : count;
                    double snapshotMiddle = (humanCount - 1) / 2.0;
                }
                @for (int i = 0; i < humanCount; i++)
                {
                    // During ingest we don't have real card references for ghost slots,
                    // so we fall back to the real hand where possible.
                    var card = i < humanHand.Count ? humanHand[i] : null;
                    double offset = i - snapshotMiddle;
                    double rotateAngle = offset * anglePerCard;
                    double translateY = Math.Pow(offset, 2) * tyFactor;

                    <div @key="@(card != null ? card.Id.ToString() : $"ghost-{i}")" class="hand-card-wrapper @(_isSwallowingCards ? "vortex-ingest" : "") @(_isSpittingCards ? "vortex-eject" : "")" style="--card-rot: @(rotateAngle.ToString(System.Globalization.CultureInfo.InvariantCulture))deg; --card-ty: @(translateY.ToString(System.Globalization.CultureInfo.InvariantCulture))px; z-index: @i;">
                        @if (card != null && !_isSwallowingCards)
                        {
                            <UnoCardComponent Card="@card" OnClick="() => OnCardClicked(card)" />
                        }
                        else
                        {
                            <UnoCardComponent IsBack="true" />
                        }
                    </div>
                }
            </div>
        </div>


    </div>

    <!-- Modals (Color Selection, Win Screen, etc.) -->
    @if (Game.Status == GameStatus.WaitingForColorSelection && Game.CurrentPlayerIndex == 0)
    {
        <div class="modal-overlay glass-modal">
            <div class="glass-panel color-picker-panel">
                <h3>Select Color</h3>
                <div class="color-options">
                    <button class="color-btn btn-red" @onclick="() => FinalizeColor(CardColor.Red)"></button>
                    <button class="color-btn btn-blue" @onclick="() => FinalizeColor(CardColor.Blue)"></button>
                    <button class="color-btn btn-green" @onclick="() => FinalizeColor(CardColor.Green)"></button>
                    <button class="color-btn btn-yellow" @onclick="() => FinalizeColor(CardColor.Yellow)"></button>
                </div>
            </div>
        </div>
    }

    @if (Game.Status == GameStatus.WaitingForSwapTarget && Game.CurrentPlayerIndex == 0)
    {
        <div class="modal-overlay glass-modal">
            <div class="glass-panel swap-picker-panel">
                <h3>Select Player to Swap Hands</h3>
                <div class="swap-options">
                    @foreach (var p in Game.Players.Where(p => p != Game.Players[0]))
                    {
                        <button class="swap-btn" @onclick="() => FinalizeSwap(p)">
                            <div class="swap-avatar">
                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
                                </svg>
                            </div>
                            <span class="swap-name">@p.Name</span>
                            <span class="swap-count">@p.Hand.Count Cards</span>
                        </button>
                    }
                </div>
            </div>
        </div>
    }

    @if (Game.Status == GameStatus.WaitingForUnoCall)
    {
        <div class="modal-overlay uno-qte-overlay">
            <div class="uno-qte-container">
                <svg class="qte-ring uno-ring" viewBox="0 0 100 100" style="--qte-duration: 2.5s;">
                    <circle cx="50" cy="50" r="45"></circle>
                </svg>
                <button class="mega-uno-btn" @onclick="() => Game.AttemptUnoCallAsync(Game.Players[0])">
                    UNO!
                </button>
                @if (Game.PlayerAtRisk == Game.Players[0])
                {
                    <div class="uno-hint">CALL IT FAST!</div>
                }
                else
                {
                    <div class="uno-hint">CATCH @Game.PlayerAtRisk?.Name.ToUpper()!</div>
                }
            </div>
        </div>
    }

    @if (Game.Status == GameStatus.GameOver)
    {
        <div class="modal-overlay glass-modal">
            <div class="glass-panel game-over-panel">
                <h1 class="winner-title">WINNER: @Game.Winner?.Name</h1>
                <p class="winner-score">Score: @Game.WinnerScore</p>
                <button class="new-game-btn" @onclick="() => OnStartGame.InvokeAsync()">NEW GAME</button>
            </div>
        </div>
    }
}

@code {
    [Parameter] public UnoGame? Game { get; set; }
    [Parameter] public EventCallback OnStartGame { get; set; }

    private bool _isProcessingAction = false;
    private string _animClass = "";
    private int _skippedPlayerIndex = -1;
    private int _skipKey = 0;
    private int _swapP1 = -1;
    private int _swapP2 = -1;
    private string _rotateAnim = ""; // "rotate-cw" or "rotate-ccw" — applied to ALL hands
    private bool _showVortexAnimation = false;
    private bool _isAnimating = false;
    private bool _isSwallowingCards = false;
    private bool _isSpittingCards = false;
    // Snapshot counts used during ingest so DOM elements stay alive for CSS transition
    private int[]? _vortexHandSnapshot = null;

    private bool IsSwapPartner(int playerIndex) =>
        _swapP1 == playerIndex || _swapP2 == playerIndex;

    protected override void OnParametersSet()
    {
        if (Game != null)
        {
            Game.OnBoardAnimation -= HandleBoardAnimation;
            Game.OnBoardAnimation += HandleBoardAnimation;
        }
    }

    private async Task HandleBoardAnimation(string animType)
    {
        // Skip overlay
        if (animType.StartsWith("skip-") && int.TryParse(animType.Split('-')[1], out int skipIdx))
        {
            _skipKey++;
            _skippedPlayerIndex = skipIdx;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(1200);
            _skippedPlayerIndex = -1;
            await InvokeAsync(StateHasChanged);
            return;
        }

        // Swap animation — only pulse the two involved hands
        if (animType.StartsWith("swap-"))
        {
            var parts = animType.Split('-');
            if (parts.Length == 3 && int.TryParse(parts[1], out int p1) && int.TryParse(parts[2], out int p2))
            {
                _swapP1 = p1; _swapP2 = p2;
                await InvokeAsync(StateHasChanged);
                await Task.Delay(900);
                _swapP1 = -1; _swapP2 = -1;
                await InvokeAsync(StateHasChanged);
            }
            return;
        }

        // Rotate animation — pulse all hands
        if (animType == "rotate-cw" || animType == "rotate-ccw")
        {
            _rotateAnim = "rotate-anim";
            await InvokeAsync(StateHasChanged);
            await Task.Delay(900);
            _rotateAnim = "";
            await InvokeAsync(StateHasChanged);
            return;
        }

        // Vortex animation
        if (animType == "vortex-shuffle")
        {
            // Step A: Fire Vortex Opening — show swirl, lock input
            _showVortexAnimation = true;
            _isAnimating = true;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(400); // cinematic opening beat

            // Step B: Snapshot current hand counts BEFORE touching data.
            // This keeps the DOM elements alive so the CSS transition has
            // something to actually animate (the critical decoupling fix).
            if (Game != null)
            {
                _vortexHandSnapshot = new int[]
                {
                    Math.Min(Game.Players[0].Hand.Count, 10), // human
                    Math.Min(Game.Players[1].Hand.Count, 5),  // cpu1
                    Math.Min(Game.Players[2].Hand.Count, 5),  // cpu2
                    Math.Min(Game.Players[3].Hand.Count, 5),  // cpu3
                };
            }

            // Step C: Trigger the suction class — cards physically fly inward.
            // The DOM count is still the snapshot, so elements are still present.
            _isSwallowingCards = true;
            await InvokeAsync(StateHasChanged);

            // Step D: Wait the full CSS transition duration before mutating data
            await Task.Delay(900);

            // Step E: Peak churn — NOW mutate the underlying data.
            // Cards are invisible (opacity 0) so the DOM wipe is seamless.
            _vortexHandSnapshot = null; // release snapshot, let real data render
            if (Game != null)
            {
                var activePlayer = Game.Players[Game.LastPlayerIndex];
                Game.ResolveVortex(activePlayer);
            }
            _isSwallowingCards = false;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(400); // brief peak churn hold

            // Step F: Ejection — new cards bounce out from center to their slots
            _isSpittingCards = true;
            await InvokeAsync(StateHasChanged);

            // Step G: Await ejection animation, then clean everything up
            await Task.Delay(900);
            _isSpittingCards = false;
            _showVortexAnimation = false;
            _isAnimating = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        // Other animations via container class
        _animClass = animType;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(1000);
        _animClass = "";
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnCardClicked(UnoCard card)
    {
        if (Game == null || _isProcessingAction || _isAnimating) return;
        _isProcessingAction = true;
        try
        {
            if (Game.CurrentPlayerIndex != 0)
            {
                await Game.JumpInAsync(Game.Players[0], card);
                return;
            }
            
            await Game.PlayCardAsync(Game.Players[0], card);
        }
        finally
        {
            _isProcessingAction = false;
        }
    }

    private async Task HandleDraw()
    {
        if (Game == null || Game.CurrentPlayerIndex != 0 || _isProcessingAction || _isAnimating) return;
        _isProcessingAction = true;
        try
        {
            if (Game.PendingDrawCount > 0)
            {
                await Game.HandlePendingDrawAsync();
            }
            else
            {
                var drawn = await Game.DrawCardAsync(Game.Players[0]);
                
                if (!Game.CanPlayCard(drawn))
                {
                    // Not playable — end turn automatically
                    Game.LogAction($"{Game.Players[0].Name} drew and passed.");
                    await Task.Delay(600);
                    await Game.PassTurnAfterDraw();
                }
                // If playable, card is already in hand — human clicks it themselves
                else
                {
                    Game.LogAction($"{Game.Players[0].Name} drew a playable card.");
                }
            }
        }
        finally
        {
            _isProcessingAction = false;
        }
    }

    private async Task FinalizeColor(CardColor color)
    {
        if (Game == null || Game.PendingCard == null || _isProcessingAction) return;
        _isProcessingAction = true;
        try
        {
            await Game.PlayCardAsync(Game.Players[0], Game.PendingCard, color);
        }
        finally
        {
            _isProcessingAction = false;
        }
    }

    private async Task FinalizeSwap(Player target)
    {
        if (Game == null || Game.PendingCard == null || _isProcessingAction) return;
        _isProcessingAction = true;
        try
        {
            await Game.PlayCardAsync(Game.Players[0], Game.PendingCard, null, target);
        }
        finally
        {
            _isProcessingAction = false;
        }
    }
}
