@using UnoEngine
@using UnoEngine.Models
@using UnoApp.Components
@implements IDisposable

@if (Game != null)
{
    <div class="game-container @(_animClass)">

        <!-- Opponents dynamically rendered along 3D ellipse -->
        @for (int j = 0; j < Opponents.Count; j++)
        {
            var opponent = Opponents[j];
            var opponentIndex = Game.Players.IndexOf(opponent);
            var opponentStyle = GetOpponentStyle(j, Opponents.Count);
            var opponentPositionClass = GetOpponentPositionClass(j, Opponents.Count);
            
            <div class="player-slot slot-opponent @opponentPositionClass" style="@opponentStyle">
                <div class="cpu-badge" style="position:relative">
                    <PlayerProfile Player="@opponent" IsActive="@(Game.CurrentPlayerIndex == opponentIndex)" IsUnoDeclared="@(opponent.Hand.Count == 1 && Game.PlayerAtRisk != opponent)" />
                    @if (_skippedPlayerIndex == opponentIndex)
                    {
                        <div class="skip-overlay" @key="_skipKey">
                            <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                                <circle cx="50" cy="50" r="45" stroke="#cc0000" stroke-width="10" fill="rgba(180,0,0,0.15)"/>
                                <line x1="18" y1="18" x2="82" y2="82" stroke="#cc0000" stroke-width="10" stroke-linecap="round"/>
                            </svg>
                        </div>
                    }
                </div>
                <div class="hand @(IsSwapPartner(opponentIndex) ? "swap-anim" : "") @(_rotateAnim)">
                    @{
                        int maxDisplay = Opponents.Count >= 4 ? 10 : 15;
                        int cardCount = _vortexHandSnapshot != null && opponentIndex < _vortexHandSnapshot.Length
                            ? _vortexHandSnapshot[opponentIndex]
                            : Math.Min(opponent.Hand.Count, maxDisplay);
                            
                        double oppMiddleIndex = (cardCount - 1) / 2.0;
                        double oppAnglePerCard = cardCount <= 7  ? 5.0
                                           : cardCount <= 12 ? 3.5
                                           : 2.5;
                        double oppTyFactor = cardCount <= 7 ? 1.0 : cardCount <= 12 ? 0.6 : 0.3;
                    }
                    @for (int i = 0; i < cardCount; i++)
                    {
                        double offset = i - oppMiddleIndex;
                        double rotateAngle = offset * oppAnglePerCard;
                        double translateY = Math.Pow(offset, 2) * oppTyFactor;
                        <div class="hand-card-wrapper @(_isSwallowingCards ? "vortex-ingest" : "") @(_isSpittingCards ? "vortex-eject" : "")" style="--card-rot: @(rotateAngle.ToString(System.Globalization.CultureInfo.InvariantCulture))deg; --card-ty: @(translateY.ToString(System.Globalization.CultureInfo.InvariantCulture))px; z-index: @i;@GetVortexDelayStyle(i)">
                            <UnoCardComponent IsBack="true" />
                        </div>
                    }
                </div>
            </div>
        }

        <!-- DRAW PILE (direct child of game-container for absolute positioning) -->
        <div class="draw-pile" @onclick="HandleDraw">
            <UnoCardComponent IsBack="true" />
        </div>

        <!-- CENTER AREA (THE HUB) -->
        <div class="center-area">
            <!-- Turn Direction Indicator -->
            <div class="turn-indicator-container">
                @if (GameState.IsClockwise)
                {
                    <svg viewBox="0 0 100 100" class="turn-indicator-svg spin-clockwise">
                        <defs>
                            <filter id="neon-glow-cw" x="-30%" y="-30%" width="160%" height="160%">
                                <feGaussianBlur stdDeviation="1.2" result="blur" />
                                <feComponentTransfer in="blur" result="brightBlur">
                                    <feFuncA type="linear" slope="0.5"/>
                                </feComponentTransfer>
                                <feMerge>
                                    <feMergeNode in="brightBlur" />
                                    <feMergeNode in="SourceGraphic" />
                                </feMerge>
                            </filter>
                            <marker id="arrowhead-cw" viewBox="0 0 10 10" refX="0" refY="5" markerWidth="11" markerHeight="11" orient="auto" markerUnits="userSpaceOnUse">
                                <path d="M 0,1.5 L 9,5 L 0,8.5 Z" fill="rgba(255, 255, 255, 0.28)" />
                            </marker>
                            <g id="arrow-half-cw">
                                <path d="M 17.2,58.8 A 34,34 0 0,1 74.0,26.0" fill="none" stroke="rgba(255, 255, 255, 0.28)" stroke-width="4.5" stroke-linecap="round" marker-end="url(#arrowhead-cw)" />
                            </g>
                        </defs>
                        <g filter="url(#neon-glow-cw)">
                            <use href="#arrow-half-cw" />
                            <use href="#arrow-half-cw" transform="rotate(180 50 50)" />
                        </g>
                    </svg>
                }
                else
                {
                    <svg viewBox="0 0 100 100" class="turn-indicator-svg spin-counter">
                        <defs>
                            <filter id="neon-glow-ccw" x="-30%" y="-30%" width="160%" height="160%">
                                <feGaussianBlur stdDeviation="1.2" result="blur" />
                                <feComponentTransfer in="blur" result="brightBlur">
                                    <feFuncA type="linear" slope="0.5"/>
                                </feComponentTransfer>
                                <feMerge>
                                    <feMergeNode in="brightBlur" />
                                    <feMergeNode in="SourceGraphic" />
                                </feMerge>
                            </filter>
                            <marker id="arrowhead-ccw" viewBox="0 0 10 10" refX="0" refY="5" markerWidth="11" markerHeight="11" orient="auto" markerUnits="userSpaceOnUse">
                                <path d="M 0,1.5 L 9,5 L 0,8.5 Z" fill="rgba(255, 255, 255, 0.28)" />
                            </marker>
                            <g id="arrow-half-ccw">
                                <path d="M 17.2,58.8 A 34,34 0 0,1 74.0,26.0" fill="none" stroke="rgba(255, 255, 255, 0.28)" stroke-width="4.5" stroke-linecap="round" marker-end="url(#arrowhead-ccw)" />
                            </g>
                        </defs>
                        <g filter="url(#neon-glow-ccw)" transform="translate(50, 50) scale(-1, 1) translate(-50, -50)">
                            <use href="#arrow-half-ccw" />
                            <use href="#arrow-half-ccw" transform="rotate(180 50 50)" />
                        </g>
                    </svg>
                }
            </div>


            <div class="discard-pile">
                @{
                    var history = Game.DiscardHistory;
                    
                    // Determine the active color glow
                    string glowClass = "";
                    if (Game.TopCard != null && Game.Status != GameStatus.WaitingForColorSelection)
                    {
                        glowClass = Game.TopCard.Color switch
                        {
                            CardColor.Red => "active-glow-red",
                            CardColor.Blue => "active-glow-blue",
                            CardColor.Green => "active-glow-green",
                            CardColor.Yellow => "active-glow-yellow",
                            _ => ""
                        };
                    }
                }
                
                <div class="discard-glow-ring" style="display: none;"></div>

                @for (int i = 0; i < history.Count; i++)
                {
                    var card = history[i];
                    var isTop = (i == history.Count - 1);
                    var displayCard = card;
                    var messyStyle = GetMessyStyle(displayCard, isTop);
                    
                    if (isTop)
                    {
                        <div @key="displayCard.Id" class="discard-active-card" style="@messyStyle @GetDiscardAnimStyle(Game.LastPlayerIndex, displayCard)">
                            <UnoCardComponent Card="@displayCard" SizeClass="w-16 h-24" />
                        </div>
                    }
                    else
                    {
                        <div @key="card.Id" class="discard-history-card" style="@messyStyle">
                            <UnoCardComponent Card="@card" SizeClass="w-16 h-24" />
                        </div>
                    }
                }

                @if (Game.PendingDrawCount > 0)
                {
                    <div class="stack-badge">
                        +@Game.PendingDrawCount
                    </div>
                }
                @if (Game.Status == GameStatus.WaitingForJumpIn)
                {
                    <svg class="qte-ring" viewBox="0 0 100 100" style="--qte-duration: @(Game.Settings.JumpInTimerSeconds.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))s;">
                        <circle cx="50" cy="50" r="45"></circle>
                    </svg>
                }
            </div>

            @if (_showVortexAnimation)
            {
                <div class="vortex-animation-overlay">
                    <img src="/images/image_144935.png" alt="Vortex Swirl" class="vortex-swirl-graphic" />
                </div>
            }
        </div>

        <!-- HUMAN (BOTTOM) -->
        @{
            int humanCountCurrent = Game.Players[0].Hand.Count;
            int overlap = humanCountCurrent > 20 ? -55 : (humanCountCurrent > 12 ? -45 : -35);
        }
        <div class="player-slot slot-human" style="--overlap: @(overlap)px; --draw-origin-x: -14vw; --draw-origin-y: -48vh;">
            <div class="human-profile-wrapper" style="position:relative">
                <PlayerProfile Player="@Game.Players[0]" IsActive="@(Game.CurrentPlayerIndex == 0)" IsUnoDeclared="@(Game.Players[0].Hand.Count == 1 && Game.PlayerAtRisk != Game.Players[0])" />
                @if (_skippedPlayerIndex == 0)
                {
                    <div class="skip-overlay" @key="_skipKey">
                        <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="50" cy="50" r="45" stroke="#cc0000" stroke-width="10" fill="rgba(180,0,0,0.15)"/>
                            <line x1="18" y1="18" x2="82" y2="82" stroke="#cc0000" stroke-width="10" stroke-linecap="round"/>
                        </svg>
                    </div>
                }
            </div>
            <div class="hand @(IsSwapPartner(0) ? "swap-anim" : "") @(_rotateAnim)">
                @{
                    // Sort by color group then by value
                    var humanHand = Game.Players[0].Hand
                        .OrderBy(c => c.Color switch {
                            CardColor.Red    => 0,
                            CardColor.Yellow => 1,
                            CardColor.Green  => 2,
                            CardColor.Blue   => 3,
                            _                => 4  // Wild
                        })
                        .ThenBy(c => (int)c.Value)
                        .ToList();
                    int count = humanHand.Count;
                    double middleIndex = (count - 1) / 2.0;
                    double anglePerCard = count <= 7  ? 5.0
                                       : count <= 12 ? 3.5
                                       : count <= 18 ? 2.5
                                       : count <= 25 ? 1.5
                                       : 1.0;
                    // Scale the translateY down too for large hands
                    double tyFactor = count <= 7 ? 1.5 : count <= 14 ? 0.8 : count <= 20 ? 0.4 : 0.2;
                }
@{
                    // Freeze count during ingest so the human's cards stay in the DOM
                    int humanCount = _vortexHandSnapshot != null ? _vortexHandSnapshot[0] : count;
                    double snapshotMiddle = (humanCount - 1) / 2.0;
                }
                @for (int i = 0; i < humanCount; i++)
                {
                    // During ingest we don't have real card references for ghost slots,
                    // so we fall back to the real hand where possible.
                    var card = i < humanHand.Count ? humanHand[i] : null;
                    double offset = i - snapshotMiddle;
                    double rotateAngle = offset * anglePerCard;
                    double translateY = Math.Pow(offset, 2) * tyFactor;

                    bool isJumpIn = card != null && Game.CurrentPlayerIndex != 0 && Game.IsEligibleForJumpIn(card) && Game.Settings.ShowJumpInGlow;
                    <div @key="@(card != null ? card.Id.ToString() : $"ghost-{i}")" class="hand-card-wrapper @(_isSwallowingCards ? "vortex-ingest" : "") @(_isSpittingCards ? "vortex-eject" : "") @(card != null && card == _drawnPlayableCard ? "drawn-card-highlight" : "") @(isJumpIn ? "jump-in-highlight" : "")" style="--card-rot: @(rotateAngle.ToString(System.Globalization.CultureInfo.InvariantCulture))deg; --card-ty: @(translateY.ToString(System.Globalization.CultureInfo.InvariantCulture))px; z-index: @(card != null && card == _drawnPlayableCard ? 1000 : (isJumpIn ? 500 : i));@GetVortexDelayStyle(i)">
                        @if (card != null && !_isSwallowingCards && !_zeroRotateActive)
                        {
                            <UnoCardComponent Card="@card" OnClick="() => OnCardClicked(card)" />
                            @if (card == _drawnPlayableCard)
                            {
                                <div class="drawn-card-bubble">
                                    <button class="bubble-btn bubble-play" @onclick="PlayDrawnCard" @onclick:stopPropagation>PLAY</button>
                                    @if (!Game.Settings.ForcedPlay)
                                    {
                                        <button class="bubble-btn bubble-keep" @onclick="KeepDrawnCard" @onclick:stopPropagation>KEEP</button>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <UnoCardComponent IsBack="true" />
                        }
                    </div>
                }
            </div>
        </div>


    </div>

    @if (Game.Status == GameStatus.WaitingForColorSelection)
    {
        <div class="color-picker-overlay">
            <div class="color-picker-diamond @(Game.PendingColorSelector == Game.Players[0] ? "interactive" : "")">
                <button class="color-btn color-btn-red @(_highlightedColor == CardColor.Red ? "cpu-pick" : "")" @onclick="() => FinalizeColor(CardColor.Red)">
                    <span class="btn-shine"></span>
                </button>
                <button class="color-btn color-btn-yellow @(_highlightedColor == CardColor.Yellow ? "cpu-pick" : "")" @onclick="() => FinalizeColor(CardColor.Yellow)">
                    <span class="btn-shine"></span>
                </button>
                <button class="color-btn color-btn-green @(_highlightedColor == CardColor.Green ? "cpu-pick" : "")" @onclick="() => FinalizeColor(CardColor.Green)">
                    <span class="btn-shine"></span>
                </button>
                <button class="color-btn color-btn-blue @(_highlightedColor == CardColor.Blue ? "cpu-pick" : "")" @onclick="() => FinalizeColor(CardColor.Blue)">
                    <span class="btn-shine"></span>
                </button>
            </div>
        </div>
    }

    @if ((Game.Status == GameStatus.WaitingForSwapTarget && Game.CurrentPlayerIndex == 0) || _sevenOverlayActive)
    {
        var isHumanChoosing = (Game.Status == GameStatus.WaitingForSwapTarget && Game.CurrentPlayerIndex == 0);
        var actorName = isHumanChoosing ? Game.Players[0].Name : Game.Players[_sevenActorIndex].Name;
        
        <div class="seven-swap-overlay">
            <div class="seven-backdrop"></div>
            
            <div class="seven-center-card">
                <div class="giant-seven">7</div>
            </div>

            @for (int i = 0; i < Game.Players.Count; i++)
            {
                int actorIdx = isHumanChoosing ? 0 : _sevenActorIndex;
                if (i == actorIdx) continue;

                    var p = Game.Players[i];
                    var pos = GetPlayerArrowPosition(i);
                    var culture = System.Globalization.CultureInfo.InvariantCulture;
                    bool isTarget = (!isHumanChoosing && i == _sevenCpuTargetIndex);
                    
                    string arrowClass = "seven-target-arrow";
                    if (isHumanChoosing) arrowClass += " clickable";
                    else if (isTarget) arrowClass += " cpu-target";
                    else arrowClass += " hidden";

                    var xStr = pos.x.ToString("0.0", culture);
                    // Center the popup container at the original player's position
                    var yStr = pos.y.ToString("0.0", culture);

                    <div class="@arrowClass" style="left: @xStr%; top: @yStr%;" @onclick="() => { if (isHumanChoosing) FinalizeSwap(p); }">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                        <PlayerProfile Player="@p" IsActive="false" IsUnoDeclared="@(p.Hand.Count == 1 && Game.PlayerAtRisk != p)" />
                    </div>
                }

            <div class="seven-instruction-bar">
                @if (isHumanChoosing)
                {
                    <span>Choose who to swap hands with!</span>
                }
                else
                {
                    <span>@actorName is swapping with @Game.Players[_sevenCpuTargetIndex].Name!</span>
                }
            </div>
        </div>
    }

    <div class="hud-action-container">
        @if (GameState.Players[0].Hand.Count == 1 && GameState.PlayerAtRisk == GameState.Players[0])
        {
            <button class="ubisoft-uno-btn" @onclick="DeclareUno">UNO!</button>
        }

        @if (GameState.CanChallengeUno)
        {
            <button class="ubisoft-catch-btn" @onclick="HandleCatchAction">!</button>
        }
    </div>

    @if (!string.IsNullOrEmpty(GameState.ActiveNotificationBanner))
    {
        <div class="ubisoft-announcement-banner">
            <div class="banner-glitch-line"></div>
            <span class="banner-text">@GameState.ActiveNotificationBanner</span>
        </div>
    }

    @if (Game.Status == GameStatus.GameOver)
    {
        <div class="modal-overlay glass-modal">
            <div class="glass-panel game-over-panel">
                <h1 class="winner-title">WINNER: @Game.Winner?.Name</h1>
                <p class="winner-score">Score: @Game.WinnerScore</p>
                <button class="new-game-btn" @onclick="() => OnStartGame.InvokeAsync()">NEW GAME</button>
            </div>
        </div>
    }

}

@code {
    [Parameter] public UnoGame? Game { get; set; }
    [Parameter] public EventCallback OnStartGame { get; set; }

    private List<Player> Opponents => Game?.Players.Skip(1).ToList() ?? new();

    private string GetOpponentStyle(int j, int totalOpponents)
    {
        if (totalOpponents <= 0) return "";
        
        double x = 50;
        double y = 15;
        double scale = 0.7;

        if (totalOpponents == 1)
        {
            x = 50; y = 15; scale = 0.7;
        }
        else if (totalOpponents == 2)
        {
            if (j == 0) { x = 10; y = 45; scale = 0.85; }
            else { x = 90; y = 45; scale = 0.85; }
        }
        else if (totalOpponents == 3)
        {
            if (j == 0) { x = 10; y = 45; scale = 0.85; }
            else if (j == 1) { x = 50; y = 15; scale = 0.7; }
            else { x = 90; y = 45; scale = 0.85; }
        }
        else if (totalOpponents == 4)
        {
            if (j == 0) { x = 10; y = 45; scale = 0.85; }
            else if (j == 1) { x = 35; y = 15; scale = 0.7; }
            else if (j == 2) { x = 65; y = 15; scale = 0.7; }
            else { x = 90; y = 45; scale = 0.85; }
        }
        else if (totalOpponents == 5)
        {
            if (j == 0) { x = 10; y = 45; scale = 0.85; }
            else if (j == 1) { x = 25; y = 15; scale = 0.7; }
            else if (j == 2) { x = 50; y = 15; scale = 0.7; }
            else if (j == 3) { x = 75; y = 15; scale = 0.7; }
            else { x = 90; y = 45; scale = 0.85; }
        }

        var culture = System.Globalization.CultureInfo.InvariantCulture;
        double dx = 36.0 - x;
        double dy = 40.0 - y;
        
        return $"position: absolute; left: {x.ToString("0.0", culture)}%; top: {y.ToString("0.0", culture)}%; transform: translate(-50%, -50%) scale({scale.ToString("0.0", culture)}); --draw-origin-x: {dx.ToString("0.0", culture)}vw; --draw-origin-y: {dy.ToString("0.0", culture)}vh;";
    }

    private (double x, double y) GetPlayerArrowPosition(int playerIndex)
    {
        if (playerIndex == 0) return (50.0, 88.0); // Human position

        int totalOpponents = Game?.Players.Count - 1 ?? 1;
        int j = playerIndex - 1; 
        
        double x = 50;
        double y = 15;

        if (totalOpponents == 1)
        {
            x = 50; y = 15;
        }
        else if (totalOpponents == 2)
        {
            if (j == 0) { x = 10; y = 45; }
            else { x = 90; y = 45; }
        }
        else if (totalOpponents == 3)
        {
            if (j == 0) { x = 10; y = 45; }
            else if (j == 1) { x = 50; y = 15; }
            else { x = 90; y = 45; }
        }
        else if (totalOpponents == 4)
        {
            if (j == 0) { x = 10; y = 45; }
            else if (j == 1) { x = 35; y = 15; }
            else if (j == 2) { x = 65; y = 15; }
            else { x = 90; y = 45; }
        }
        else if (totalOpponents == 5)
        {
            if (j == 0) { x = 10; y = 45; }
            else if (j == 1) { x = 25; y = 15; }
            else if (j == 2) { x = 50; y = 15; }
            else if (j == 3) { x = 75; y = 15; }
            else { x = 90; y = 45; }
        }
        return (x, y);
    }

    private string GetOpponentPositionClass(int j, int totalOpponents)
    {
        if (totalOpponents == 1) return "slot-cpu-top";
        if (totalOpponents == 2) return j == 0 ? "slot-cpu-left" : "slot-cpu-right";
        if (totalOpponents == 3)
        {
            if (j == 0) return "slot-cpu-left";
            if (j == 1) return "slot-cpu-top";
            return "slot-cpu-right";
        }
        if (totalOpponents == 4)
        {
            if (j == 0) return "slot-cpu-left";
            if (j == 1) return "slot-cpu-top";
            if (j == 2) return "slot-cpu-top";
            return "slot-cpu-right";
        }
        if (totalOpponents == 5)
        {
            if (j == 0) return "slot-cpu-left";
            if (j == 1 || j == 2 || j == 3) return "slot-cpu-top";
            return "slot-cpu-right";
        }
        return "slot-cpu-top";
    }

    private string GetMessyStyle(UnoCard card, bool isActiveTop)
    {
        if (card == null) return "";
        
        // Use the Guid hash code to generate pseudo-random numbers for deterministic offsets
        int hash = card.Id.GetHashCode();
        
        // Read persistent tilt
        double rotation = card.RotationAngle;
        
        // X offset between -10px and 10px
        double offsetX = (Math.Abs(hash % 17)) / 16.0 * 20.0 - 10.0;
        
        // Y offset between -10px and 10px
        double offsetY = (Math.Abs((hash >> 4) % 17)) / 16.0 * 20.0 - 10.0;

        var culture = System.Globalization.CultureInfo.InvariantCulture;
        string style = $"position: absolute; left: calc(50% + {offsetX.ToString("0.0", culture)}px); top: calc(50% + {offsetY.ToString("0.0", culture)}px); transform: translate(-50%, -50%) rotate({rotation.ToString("0.0", culture)}deg);";
        
        if (isActiveTop)
        {
            style += " z-index: 10;"; // highest z-index for active top card
        }
        else
        {
            style += " z-index: 2; opacity: 0.85;"; // slightly faded and lower z-index
        }
        
        return style;
    }

    private string GetDiscardAnimStyle(int lastPlayerIndex, UnoCard card)
    {
        if (lastPlayerIndex < 0 || Game == null) return "";
        
        var culture = System.Globalization.CultureInfo.InvariantCulture;
        
        if (lastPlayerIndex == 0)
        {
            // Human player
            return "animation: play-from-human 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);";
        }
        else
        {
            // Opponent player
            int totalOpponents = Game.Players.Count - 1;
            int j = lastPlayerIndex - 1;
            
            double x = 50;
            double y = 15;
            
            if (totalOpponents == 1) { x = 50; y = 15; }
            else if (totalOpponents == 2) { x = (j == 0) ? 10 : 90; y = 45; }
            else if (totalOpponents == 3) {
                if (j == 0) { x = 10; y = 45; }
                else if (j == 1) { x = 50; y = 15; }
                else { x = 90; y = 45; }
            }
            else if (totalOpponents == 4) {
                if (j == 0) { x = 10; y = 45; }
                else if (j == 1) { x = 35; y = 15; }
                else if (j == 2) { x = 65; y = 15; }
                else { x = 90; y = 45; }
            }
            else if (totalOpponents == 5) {
                if (j == 0) { x = 10; y = 45; }
                else if (j == 1) { x = 25; y = 15; }
                else if (j == 2) { x = 50; y = 15; }
                else if (j == 3) { x = 75; y = 15; }
                else { x = 90; y = 45; }
            }

            double dx = x - 50.0;
            double dy = y - 50.0;

            return $"--play-origin-x: {dx.ToString("0.0", culture)}vw; --play-origin-y: {dy.ToString("0.0", culture)}vh; animation: play-from-opponent 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);";
        }
    }

    private bool _isProcessingAction = false;
    private string _animClass = "";
    private int _skippedPlayerIndex = -1;
    private int _skipKey = 0;
    private int _swapP1 = -1;
    private int _swapP2 = -1;
    private string _rotateAnim = ""; // "rotate-cw" or "rotate-ccw" — applied to ALL hands
    private bool _showVortexAnimation = false;
    private bool _zeroRotateActive = false;
    private bool _isAnimating = false;
    private bool _isSwallowingCards = false;
    private bool _isSpittingCards = false;
    // Snapshot counts used during ingest so DOM elements stay alive for CSS transition
    private int[]? _vortexHandSnapshot = null;
    private CardColor? _highlightedColor = null;

    private bool _sevenOverlayActive = false;
    private int _sevenActorIndex = -1;
    private int _sevenCpuTargetIndex = -1;

    private UnoCard? _drawnPlayableCard = null;

    private async Task PlayDrawnCard()
    {
        if (_drawnPlayableCard == null || _isProcessingAction || Game == null) return;
        _isProcessingAction = true;
        try
        {
            var cardToPlay = _drawnPlayableCard;
            _drawnPlayableCard = null; // hide overlay
            await Task.Delay(100);
            await Game.PlayCardAsync(Game.Players[0], cardToPlay);
        }
        finally
        {
            _isProcessingAction = false;
        }
    }

    private async Task KeepDrawnCard()
    {
        if (_drawnPlayableCard == null || _isProcessingAction || Game == null) return;
        _isProcessingAction = true;
        try
        {
            _drawnPlayableCard = null; // hide overlay
            await Task.Delay(100);
            Game.LogAction($"{Game.Players[0].Name} drew and kept the card.");
            await Game.PassTurnAfterDraw();
        }
        finally
        {
            _isProcessingAction = false;
        }
    }

    private bool IsSwapPartner(int playerIndex) =>
        _swapP1 == playerIndex || _swapP2 == playerIndex;

    private string GetVortexDelayStyle(int cardIndex)
    {
        if (!_isSwallowingCards && !_isSpittingCards) return "";
        double delay = cardIndex * 0.07;
        return $" --vortex-delay: {delay.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)}s;";
    }

    private UnoGame GameState => Game!;
    private System.Threading.CancellationTokenSource? _bannerCts;
    private string _lastObservedBanner = "";

    protected override void OnParametersSet()
    {
        if (Game != null)
        {
            Game.OnBoardAnimation -= HandleBoardAnimation;
            Game.OnBoardAnimation += HandleBoardAnimation;

            Game.OnStateChanged -= HandleStateChanged;
            Game.OnStateChanged += HandleStateChanged;
        }
    }

    private void HandleStateChanged()
    {
        if (Game != null && Game.ActiveNotificationBanner != _lastObservedBanner)
        {
            _lastObservedBanner = Game.ActiveNotificationBanner;
            if (!string.IsNullOrEmpty(_lastObservedBanner))
            {
                ShowBanner(_lastObservedBanner);
            }
        }
        InvokeAsync(StateHasChanged);
    }

    private void ShowBanner(string message)
    {
        if (Game == null) return;

        _bannerCts?.Cancel();
        _bannerCts = new System.Threading.CancellationTokenSource();
        var token = _bannerCts.Token;

        Game.ActiveNotificationBanner = message;
        StateHasChanged();

        _ = Task.Delay(3000, token).ContinueWith(t => {
            if (!t.IsCanceled && Game != null)
            {
                Game.ActiveNotificationBanner = "";
                InvokeAsync(StateHasChanged);
            }
        });
    }

    private async Task HandleBoardAnimation(string animType)
    {
        // Skip overlay
        if (animType.StartsWith("skip-") && int.TryParse(animType.Split('-')[1], out int skipIdx))
        {
            _skipKey++;
            _skippedPlayerIndex = skipIdx;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(1200);
            _skippedPlayerIndex = -1;
            await InvokeAsync(StateHasChanged);
            return;
        }

        // Swap and Rotate animations
        if (animType.StartsWith("swap-") || animType == "rotate-cw" || animType == "rotate-ccw")
        {
            _isAnimating = true;
            await InvokeAsync(StateHasChanged);
            
            // Snapshot the hands so Blazor doesn't move elements while CSS animates them
            if (Game != null)
            {
                _vortexHandSnapshot = Game.Players.Select(p => p.Hand.Count).ToArray();
            }

            // ── STEP 1: FLIP TO BACKS + FOLD ──
            _zeroRotateActive = true;
            _animClass = "zero-fold";
            await InvokeAsync(StateHasChanged);
            await Task.Delay(600);

            // ── STEP 2: FLY ──
            _animClass = "zero-fold " + animType;
            await InvokeAsync(StateHasChanged);
            
            // Wait for fly animation to reach destination and fade out
            await Task.Delay(1000);

            // ── STEP 3: REVEAL ──
            _vortexHandSnapshot = null;
            _zeroRotateActive = false;
            _animClass = "zero-reveal";
            await InvokeAsync(StateHasChanged);

            _ = Task.Delay(600).ContinueWith(_ =>
            {
                InvokeAsync(() =>
                {
                    _animClass = "";
                    _isAnimating = false;
                    StateHasChanged();
                });
            });

            return;
        }

        // Seven Preview animation
        if (animType.StartsWith("seven-preview-"))
        {
            var parts = animType.Split('-');
            if (parts.Length == 4 && int.TryParse(parts[2], out int actor) && int.TryParse(parts[3], out int target))
            {
                _sevenActorIndex = actor;
                _sevenCpuTargetIndex = target;
                _sevenOverlayActive = true;
                await InvokeAsync(StateHasChanged);
                await Task.Delay(2500); // Overlay visible time
                _sevenOverlayActive = false;
                await InvokeAsync(StateHasChanged);
            }
            return;
        }

        // Vortex animation
        if (animType == "vortex-shuffle")
        {
            // Step A: Fire Vortex Opening — show swirl, lock input
            _showVortexAnimation = true;
            _isAnimating = true;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(350); // cinematic opening beat

            // Step B: Snapshot current hand counts BEFORE touching data.
            // Caps at 10 for human and 5 for CPUs to keep animation snappy.
            if (Game != null)
            {
                _vortexHandSnapshot = Game.Players.Select((p, idx) => 
                    idx == 0 ? Math.Min(p.Hand.Count, 10) : Math.Min(p.Hand.Count, 5)
                ).ToArray();
            }

            // Step C: Trigger the suction class — each card flies in one by one
            // via staggered animation-delay controlled by --vortex-delay CSS var.
            _isSwallowingCards = true;
            await InvokeAsync(StateHasChanged);

            // Step D: Wait for ALL staggered ingest animations to complete.
            // Max delay = (maxCards-1)*0.07s + 0.5s animation = ~1.13s for 10 cards.
            await Task.Delay(1400);

            // Step E: Peak churn — NOW mutate the underlying data.
            // All cards are scale(0)/opacity(0) so the DOM wipe is seamless.
            _vortexHandSnapshot = null; // release snapshot, let real data render
            if (Game != null)
            {
                var activePlayer = Game.Players[Game.LastPlayerIndex];
                Game.ResolveVortex(activePlayer);
            }
            _isSwallowingCards = false;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(250); // brief peak churn hold

            // Step F: Ejection — new cards burst out one by one from vortex center
            _isSpittingCards = true;
            await InvokeAsync(StateHasChanged);

            // Step G: Await all staggered eject animations, then clean up
            await Task.Delay(1400);
            _isSpittingCards = false;
            _showVortexAnimation = false;
            _isAnimating = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (animType.StartsWith("cpu-color-pick-") && Enum.TryParse<CardColor>(animType.Substring(15), out var pickedColor))
        {
            _highlightedColor = pickedColor;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(800);
            _highlightedColor = null;
            await InvokeAsync(StateHasChanged);
            return;
        }

        // Other animations via container class
        _animClass = animType;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(1000);
        _animClass = "";
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnCardClicked(UnoCard card)
    {
        if (Game == null || _isProcessingAction || _isAnimating) return;
        _isProcessingAction = true;
        try
        {
            if (Game.CurrentPlayerIndex != 0)
            {
                await Game.JumpInAsync(Game.Players[0], card);
                return;
            }
            
            await Game.PlayCardAsync(Game.Players[0], card);
        }
        finally
        {
            _isProcessingAction = false;
        }
    }

    private async Task HandleDraw()
    {
        if (Game == null || Game.CurrentPlayerIndex != 0 || _isProcessingAction || _isAnimating) return;
        
        // Check if ForcedPlay is enabled and player has playable card
        if (Game.Settings.ForcedPlay && Game.PendingDrawCount == 0)
        {
            var hasPlayableCard = Game.Players[0].Hand.Any(card => Game.CanPlayCard(card));
            if (hasPlayableCard)
            {
                // Forced Play is enabled and player has playable card, cannot draw
                Game.ActiveNotificationBanner = "YOU MUST PLAY A CARD!";
                Game.LogAction($"{Game.Players[0].Name} must play a card instead of drawing.");
                ShowBanner("YOU MUST PLAY A CARD!");
                return;
            }
        }
        
        // Check if AllowReneging is disabled and player has playable card
        if (!Game.Settings.AllowReneging && Game.PendingDrawCount == 0)
        {
            var hasPlayableCard = Game.Players[0].Hand.Any(card => Game.CanPlayCard(card));
            if (hasPlayableCard)
            {
                // Reneging is disabled and player has playable card, cannot draw
                Game.ActiveNotificationBanner = "YOU MUST PLAY A CARD!";
                Game.LogAction($"{Game.Players[0].Name} must play a card instead of drawing.");
                ShowBanner("YOU MUST PLAY A CARD!");
                return;
            }
        }
        
        _isProcessingAction = true;
        try
        {
            if (Game.PendingDrawCount > 0)
            {
                await Game.HandlePendingDrawAsync();
            }
            else
            {
                var drawn = await Game.DrawCardAsync(Game.Players[0]);
                if (drawn == null)
                {
                    ShowBanner("YOU MUST PLAY A CARD!");
                    return;
                }
                
                if (!Game.CanPlayCard(drawn))
                {
                    // Not playable — end turn automatically
                    Game.LogAction($"{Game.Players[0].Name} drew and passed.");
                    await Task.Delay(600);
                    await Game.PassTurnAfterDraw();
                }
                // If playable, ask player to play or keep
                else
                {
                    Game.LogAction($"{Game.Players[0].Name} drew a playable card.");
                    _drawnPlayableCard = drawn;
                }
            }
        }
        finally
        {
            _isProcessingAction = false;
        }
    }

    private async Task FinalizeColor(CardColor color)
    {
        if (Game == null || Game.PendingColorSelector != Game.Players[0] || _isProcessingAction) return;
        _isProcessingAction = true;
        try
        {
            await Game.SetWildColorAsync(color);
        }
        finally
        {
            _isProcessingAction = false;
        }
    }

    private async Task FinalizeSwap(Player target)
    {
        if (Game == null || Game.PendingCard == null || _isProcessingAction) return;
        _isProcessingAction = true;
        try
        {
            await Game.PlayCardAsync(Game.Players[0], Game.PendingCard, null, target);
        }
        finally
        {
            _isProcessingAction = false;
        }
    }

    private async Task HandleCatchAction()
    {
        if (Game == null || Game.PlayerAtRisk == null) return;
        var targetPlayer = Game.PlayerAtRisk;
        Game.LogAction($"PLAYER clicked Catch on {targetPlayer.Name}!");
        await Game.AttemptUnoCallAsync(Game.Players[0]);
    }

    private async Task DeclareUno()
    {
        if (Game == null) return;
        if (Game.Status == GameStatus.WaitingForUnoCall)
        {
            await Game.AttemptUnoCallAsync(Game.Players[0]);
            StateHasChanged();
        }
        else
        {
            Game.IsUnoCalled = true;
            Game.LogAction("PLAYER proactively declared UNO!");
            ShowBanner("YOU DECLARED UNO!");
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        if (Game != null)
        {
            Game.OnBoardAnimation -= HandleBoardAnimation;
            Game.OnStateChanged -= HandleStateChanged;
        }
        _bannerCts?.Cancel();
        _bannerCts?.Dispose();
    }
}
